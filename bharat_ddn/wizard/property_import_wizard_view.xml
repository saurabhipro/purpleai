<odoo>
    <record id="view_property_import_wizard_form" model="ir.ui.view">
        <field name="name">property.import.wizard.form</field>
        <field name="model">property.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Property Data">
                <group>
                    <field name="import_type" widget="radio" options="{'horizontal': true}"/>
                    <field name="filename" invisible="1"/>
                    <field name="data_file" filename="filename"/>
                    <field name="available_sheets" invisible="not available_sheets"/>
                    <field name="sheet_name" placeholder="Leave empty for first sheet" invisible="not available_sheets"/>
                    <field name="import_limit_option" widget="radio" options="{'horizontal': true}"/>
                    <field name="limit_count" invisible="import_limit_option == 'all'"/>
                    <field name="error_file" filename="error_filename" readonly="1" invisible="not error_file"/>
                    <field name="error_filename" invisible="1"/>
                </group>
                <div class="alert alert-info" role="alert" style="margin-top: 10px;" invisible="import_type != 'property_id'">
                    <strong>Expected Excel Format:</strong><br/>
                    Ensure your Excel sheet contains the following columns:<br/>
                    <ul>
                        <li><b>Zone</b> (e.g., Zone 1)</li>
                        <li><b>Ward</b> (e.g., Ward 10)</li>
                        <li><b>Property ID</b> (Unique ID)</li>
                        <li><b>Owner Name</b></li>
                        <li><b>Address</b></li>
                        <li><b>Mobile No</b></li>
                        <li><b>Colony</b></li>
                    </ul>
                    <small><i>Note: Duplicates based on Property ID will be skipped.</i></small>
                </div>
                <div class="alert alert-info" role="alert" style="margin-top: 10px;" invisible="import_type != 'upic'">
                    <strong>Expected Excel Format:</strong><br/>
                    Ensure your Excel sheet contains the following columns:<br/>
                    <ul>
                        <li><b>company</b> (e.g., indore)</li>
                        <li><b>upicno</b> (Unique ID)</li>
                        <li><b>unit_no</b></li>
                        <li><b>zone</b> (e.g., Zone 1)</li>
                        <li><b>ward</b> (e.g., Ward 10)</li>
                        <li><b>colony</b></li>
                    </ul>
                    <small><i>Note: Duplicates based on UPIC NO will be skipped.</i></small>
                </div>
                <footer>
                    <button name="action_import" type="object" string="Import" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_property_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Property ID Data</field>
        <field name="res_model">property.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_property_import_wizard_form"/>
    </record>
</odoo> 