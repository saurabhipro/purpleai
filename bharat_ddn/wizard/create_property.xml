<odoo>
    <record id="view_property_create_wizard_form" model="ir.ui.view">
        <field name="name">property.create.wizard.form</field>
        <field name="model">property.create.wizard</field>
        <field name="arch" type="xml">
            <form string="create Property Data">
                <group>
                    <field name="zone_id" options="{'no_create_edit':True, 'no_create':True, 'no_open':True}"/>
                    <field name="ward_id" domain="[('zone_id','=',zone_id)]" options="{'no_create_edit':True, 'no_create':True, 'no_open':True}"/>
                    <field name="colony_id" domain="[('ward_id','=',ward_id)]" options="{'no_create_edit':True, 'no_create':True, 'no_open':True}"/>
                    <field name="no_of_property"/>
                </group>
                <footer>
                    <button name="action_create" type="object" string="create" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_property_create_wizard" model="ir.actions.act_window">
        <field name="name">create Property ID Data</field>
        <field name="res_model">property.create.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_property_create_wizard_form"/>
    </record>
</odoo> 