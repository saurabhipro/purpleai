<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- QR Scan Export Wizard Form View -->
        <record id="qr_scan_export_wizard_form" model="ir.ui.view">
            <field name="name">qr.scan.export.wizard.form</field>
            <field name="model">qr.scan.export.wizard</field>
            <field name="arch" type="xml">
                <form string="Export QR Scans to Excel">
                    <sheet>
                        <group invisible="state != 'choose'">
                            <field name="state" invisible="1"/>
                            <div class="alert alert-info mb-3" role="alert">
                                <i class="fa fa-info-circle"/> <strong>Note:</strong> This will export <strong>ALL</strong> QR scan records from the database (sorted by most recent first).
                            </div>
                            <p class="text-muted">
                                The Excel report will include the following columns:
                            </p>
                            <ul class="text-muted">
                                <li>Scan Date &amp; Time</li>
                                <li>UUID</li>
                                <li>Property UPIC</li>
                                <li>Zone, Ward, Colony</li>
                                <li>Property Type</li>
                                <li>Latitude &amp; Longitude</li>
                                <li>Scanned URL</li>
                            </ul>
                        </group>
                        
                        <group invisible="state != 'download'">
                            <field name="state" invisible="1"/>
                            <label for="excel_file" string="Download File"/>
                            <div>
                                <field name="excel_file" filename="filename" widget="binary" readonly="1"/>
                                <field name="filename" invisible="1"/>
                            </div>
                            <p class="text-success">
                                <i class="fa fa-check-circle"/> Report generated successfully! Click above to download.
                            </p>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_export_excel" 
                                string="Export to Excel" 
                                type="object" 
                                class="btn-primary" 
                                invisible="state != 'choose'"/>
                        <button name="action_close" 
                                string="Close" 
                                type="object" 
                                class="btn-secondary" 
                                invisible="state != 'download'"/>
                        <button string="Cancel" 
                                class="btn-secondary" 
                                special="cancel" 
                                invisible="state != 'choose'"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Server Action to Open Export Wizard -->
        <record id="action_qr_scan_export_to_excel" model="ir.actions.server">
            <field name="name">Export All Scans to Excel</field>
            <field name="model_id" ref="model_ddn_qr_scan"/>
            <field name="binding_model_id" ref="model_ddn_qr_scan"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'qr.scan.export.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {'active_ids': env.context.get('active_ids', [])}
}
            </field>
        </record>

    </data>
</odoo>
