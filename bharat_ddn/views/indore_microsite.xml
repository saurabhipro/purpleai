<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="id_indore_microsite_template" name="Bharat DDN">
    <t t-call="website.layout">
      <!-- External CSS -->
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
      <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
      <style>
        .govt-services-section {
          background: none !important;
          padding: 0 !important;
          margin: 0 !important;
          border: none !important;
        }
        .govt-services-box {
          background: #fff;
          
          border-radius: 22px;
          box-shadow: 0 2px 16px 0 rgba(0,0,0,0.10);
          padding: 2rem 1rem 1.5rem 1rem;
          max-width: 700px;
          margin: 0 auto;
        }
        .govt-service-icon-box {
          width: 64px;
          height: 64px;
          border-radius: 16px;
          display: flex;
          align-items: center;
          justify-content: center;
          margin: 0 auto 0.5rem auto;
          background: rgba(255, 255, 255, 0.7);
          border: 2.5px solid;
          border-image: linear-gradient(135deg, #ff9800 0%, #e91e63 100%);
          border-image-slice: 1;
        }
        .govt-service-icon-box i {
          font-size: 2rem;
          color: #e65100;
        }
        .govt-service-label {
          font-size: 1.08rem;
          margin-top: 0.1rem;
          color: #222;
          font-weight: 800;
        }
        .govt-services-row {
          overflow-x: auto;
          flex-wrap: nowrap;
        }
        .header-gradient {
          background: none !important; /* Remove brown gradient */
          border: none !important;
          margin: 0 !important;
          padding: 0 !important;
        }
        .emergency-card {
          border: 2.5px solid #e0e0e0;   /* Light gray border for all */
          border-radius: 18px;
          color: #fff;
          font-weight: 600;
          font-size: 1.08rem;
          box-shadow: 0 2px 12px 0 rgba(0,0,0,0.08);
          display: flex;
          align-items: center;
          justify-content: center;
          min-height: 90px;
          transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
          cursor: pointer;
          background-clip: padding-box;
        }
        .emergency-card:hover {
          transform: translateY(-4px) scale(1.03);
          box-shadow: 0 6px 24px 0 rgba(0,0,0,0.13);
          opacity: 0.95;
          border-color: #7b223c; /* Highlight border on hover */
        }
        .emergency-icon {
          font-size: 2rem;
          margin-bottom: 0.3rem;
          display: block;
        }
        .emergency-bg-red {
          background: #fdebed;
          color: #b71c1c; /* deep red for text/icon */
          border-color: #f8bbbc;
        }
        .emergency-bg-blue {
          background: #e3f2fd;
          color: #1565c0; /* deep blue for text/icon */
          border-color: #b3d6f7;
        }
        .emergency-bg-yellow {
          background: #fff7e0;
          color: #b26a00; /* deep gold for text/icon */
          border-color: #ffe9b3;
        }
        .emergency-bg-cyan {
          background: #e0f7fa;
          color: #00838f; /* teal for text/icon */
          border-color: #b3e6ea;
        }
        .emergency-bg-purple {
          background: #f3e5f5;
          color: #6a1b9a; /* purple for text/icon */
          border-color: #e1c6f3;
        }
        .emergency-bg-green {
          background: #e8f5e9;
          color: #2e7d32; /* green for text/icon */
          border-color: #bfe5c7;
        }
        .emergency-bg-gold {
          background: #fffde7;
          color: #bfa600; /* gold for text/icon */
          border-color: #fff7b3;
        }
        .emergency-bg-indigo {
          background: #e8eaf6;
          color: #283593; /* indigo for text/icon */
          border-color: #c6c8f3;
        }
        .emergency-label {
          font-size: 1.08rem;
          font-weight: 600;
          margin-top: 0.2rem;
          letter-spacing: 0.2px;
        }
        .container { max-width: 100% !important; }
        .main-section-card {
          background: #fff;
          border-radius: 24px;
          max-width: 1100px;
          margin-left: 5%;
          margin-right: 5%;
          margin-bottom: 2rem;
          box-shadow: 0 2px 16px 0 rgba(0,0,0,0.10);
          padding: 0.7rem 0.5rem;
        }
        @media (max-width: 767.98px) {
          .govt-services-section .card-body {
            padding: 1.2rem !important;
          }
          .govt-service-label {
            font-size: 1rem;
          }
          .main-section-card {
            margin-left: 2%;
            margin-right: 2%;
            padding: 1rem 0.5rem;
          }
          .d-flex.flex-nowrap {
            gap: 1rem !important;
          }
        }
        .govt-services-scroll {
          gap: 1.5rem;
          padding-bottom: 0.5rem;
          /* Optional: hide scrollbar for webkit browsers */
          scrollbar-width: thin;
          scrollbar-color: #ccc #fff;
        }
        .govt-services-scroll::-webkit-scrollbar {
          height: 8px;
          background: #fff;
        }
        .govt-services-scroll::-webkit-scrollbar-thumb {
          background: #eee;
          border-radius: 4px;
        }
        .service-box {
          background: #fff;
          border-radius: 18px;
          box-shadow: 0 2px 12px 0 rgba(0,0,0,0.08);
          width: 100%;
          padding: 1.5rem 1rem;
          margin-bottom: 0;
          display: flex;
          flex-direction: row;
          align-items: stretch;
          justify-content: space-between;
          gap: 1.5rem;
        }
        @media (max-width: 767.98px) {
          .service-box {
            flex-direction: column;
            gap: 1rem;
            padding: 1rem 0.5rem;
          }
        }
        .header-content-box {
          max-width: 700px;
          margin: 0 auto;
          padding-left: 2rem;
          padding-right: 2rem;
          border-radius: 18px;
          /* Optional: add a subtle shadow for a card effect */
          /* box-shadow: 0 2px 16px 0 rgba(0,0,0,0.10); */
        }
        @media (max-width: 767.98px) {
          .header-content-box {
            max-width: 100%;
            padding-left: 1rem;
            padding-right: 1rem;
          }
        }
        .center-section {
          max-width: 900px;
          margin: 0 auto 0.3rem auto;
          display: flex;
          flex-direction: column;
          align-items: center;
        }
        .main-section-card {
          width: 100%;
          padding: 0.7rem 0.5rem;
        }
        .card-body {
          padding: 1rem !important;
        }
        @media (max-width: 991.98px) {
          .center-section {
            max-width: 98vw;
            margin-left: 1vw;
            margin-right: 1vw;
          }
        }
        .o_footer, footer, .footer {
          display: none !important;
        }
        /* Officer Card Customization */
        .officer-card {
          border: 2.5px solid #bdbdbd; /* Subtle gray border */
          border-radius: 18px;
          background: #fff;
          color: #222 !important;
          box-shadow: 0 2px 12px 0 rgba(0,0,0,0.08);
          font-weight: 600;
          font-size: 1.08rem;
          display: flex;
          align-items: center;
          justify-content: center;
          min-height: 120px;
          transition: transform 0.12s, box-shadow 0.12s;
          cursor: pointer;
        }
        .officer-card:hover {
          transform: translateY(-4px) scale(1.03);
          box-shadow: 0 6px 24px 0 rgba(0,0,0,0.13);
          opacity: 0.97;
          border-color: #7b223c; /* Highlight border on hover */
        }
        .officer-card .officer-label {
          color: #222 !important;
          font-size: 1.08rem;
          font-weight: 700;
          margin-top: 0.2rem;
          letter-spacing: 0.2px;
        }
        .officer-card .officer-name,
        .officer-card .officer-phone {
          color: #333 !important;
          font-size: 0.95rem;
          font-weight: 500;
          opacity: 1;
          margin-top: 0.2rem;
        }
        .officer-card .officer-phone {
          text-decoration: none;
          display: block;
          margin-top: 0.1rem;
        }
        .govt-payment-row {
          display: flex;
          flex-direction: row;
          gap: 1.2rem;
          justify-content: center;
          align-items: stretch;
          flex-wrap: nowrap;
          overflow-x: auto;
          padding-bottom: 0.5rem;
          margin-left: 0;
          margin-right: 0;
        }
        .govt-payment-box {
          background: #fff;
          border-radius: 18px;
          box-shadow: 0 2px 12px 0 rgba(0,0,0,0.08);
          border: none;
          min-width: 120px;
          flex: 1 0 120px;
          max-width: 180px;
          padding: 1.2rem 0.5rem 1rem 0.5rem;
          margin-bottom: 0;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: flex-start;
        }
        .govt-payment-scroll::-webkit-scrollbar {
          height: 8px;
          background: #fff;
        }
        .govt-payment-scroll::-webkit-scrollbar-thumb {
          background: #eee;
          border-radius: 4px;
        }
        @media (max-width: 767.98px) {
          .govt-payment-row {
            gap: 1rem;
            padding-left: 0.5rem;
            padding-right: 0.5rem;
          }
          .govt-payment-box {
            min-width: 120px;
            max-width: 160px;
            flex: 0 0 70vw;
          }
        }
        .payment-services-row {
          width: 100%;
          gap: 2rem;
          margin: 0 auto;
          padding: 0;
          flex-wrap: nowrap;
          justify-content: center;
          align-items: flex-start;
        }
        .payment-service-box {
          flex: 0 1 140px;
          min-width: 100px;
          max-width: 160px;
          padding: 0.5rem 0.2rem 0.3rem 0.2rem;
          background: none;
          box-shadow: none;
          border-radius: 0;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: flex-start;
        }
        .icon-gradient-box {
          width: 54px;
          height: 54px;
          border-radius: 14px;
          display: flex;
          align-items: center;
          justify-content: center;
          background: linear-gradient(135deg, #ff9800 0%, #e91e63 100%);
          box-shadow: 0 2px 8px 0 rgba(0,0,0,0.10);
          border: 2.5px solid #fff;
        }
        .icon-gradient-box i {
          font-size: 2rem;
          color: #fff;
        }
        .govt-service-label {
          font-size: 1.08rem;
          margin-top: 0.1rem;
          color: #222;
          font-weight: 800;
        }
        /* New styles for section titles with colored background strips */
        .section-title-container {
          position: relative;
          margin-top: 1.5rem;
          margin-bottom: 1.5rem;
          text-align: center;
          display: flex;
          justify-content: center;
        }
        .section-title-bg {
          background: linear-gradient(135deg, #7b223c 0%, #b85b2c 100%);
          color: #fff;
          padding: 0.8rem 2rem;
          border-radius: 25px;
          font-weight: 700;
          font-size: 1.3rem;
          letter-spacing: 1px;
          box-shadow: 0 4px 12px rgba(123,34,60,0.2);
          position: relative;
          z-index: 2;
          width: 350px;         /* Set a fixed width for all headers */
          max-width: 90vw;      /* Responsive for small screens */
          text-align: center;
          display: block;       /* Ensures width is respected */
        }
        .section-title-bg::before {
          content: '';
          position: absolute;
          top: 50%;
          left: -20px;
          right: -20px;
          height: 12px;
          background: none;
          box-shadow: 0 0 16px 4px #7b223c33;
          opacity: 0.3;
          transform: translateY(-50%);
          z-index: -1;
          pointer-events: none;
        }
        @media (max-width: 767.98px) {
          .payment-services-row {
            gap: 0.5rem;
          }
          .payment-service-box {
            min-width: 80px;
            max-width: 110px;
            padding: 0.3rem 0.1rem 0.2rem 0.1rem;
          }
          .icon-gradient-box {
            width: 38px;
            height: 38px;
            border-radius: 8px;
          }
          .icon-gradient-box i {
            font-size: 1.2rem;
          }
          .govt-service-label {
            font-size: 0.92rem;
          }
          .section-title-bg {
            font-size: 1.1rem;
            padding: 0.6rem 1.5rem;
          }
        }
        @media (max-width: 400px) {
          .section-title-bg {
            width: 98vw;
            font-size: 1.1rem;
            padding: 0.6rem 0.2rem;
          }
        }
        .o_mail_navbar_item, .o_notification_counter, .o_mail_navbar_systray_item {
            display: none !important;
        }
        .welcome-strip {
          width: 100vw;
          background: linear-gradient(90deg, #7b223c 0%, #b85b2c 100%);
          color: #fff;
          font-weight: 600;
          font-size: 1rem;
          letter-spacing: 1px;
          text-align: center;
          padding: 0.4rem 0;
          margin: 0;
          border: none;
          box-shadow: 0 2px 8px rgba(123,34,60,0.08);
          z-index: 100;
          position: relative;
        }
        .header-carousel,
        .carousel-inner,
        .carousel-item,
        .carousel-content-hero {
          border-radius: 0 !important;
          overflow: hidden;
        }
        .carousel-content-hero {
          width: 100%;
          height: 100%;
          display: flex;
          flex-direction: column;
          justify-content: center;      /* Vertically center */
          align-items: center;          /* Horizontally center */
          text-align: center;           /* Center text */
          padding: 2rem 3vw;
          background: rgba(0,0,0,0.25); /* Optional: overlay for readability */
          z-index: 2;
        }
        .carousel-title-hero, .carousel-subtitle-hero {
          /* Keep or enhance text shadow for readability */
          text-shadow: 0 4px 24px rgba(0,0,0,0.7), 0 2px 8px rgba(0,0,0,0.5), 0 1px 0 #000;
        }
        .carousel-title-hero {
          font-size: clamp(1.5rem, 5vw, 2.5rem);
          font-weight: 900;
          letter-spacing: 1.5px;
          color: #fff;
          margin-bottom: 1rem;
          line-height: 1.1;
          text-transform: uppercase;
        }
        .carousel-subtitle-hero {
          font-size: clamp(1rem, 2.5vw, 1.25rem);
          font-weight: 500;
          color: #fff;
          margin-bottom: 0;
          line-height: 1.5;
          letter-spacing: 0.5px;
        }
        .carousel-control-prev,
        .carousel-control-next {
          z-index: 3;
          width: 5%;
        }
        .carousel-control-prev-icon,
        .carousel-control-next-icon {
          filter: drop-shadow(0 0 4px #000);
        }
        @media (max-width: 767.98px) {
          .header-carousel, .carousel-inner, .carousel-item {
            min-height: 180px;
            max-height: 220px;
            height: 180px;
            padding: 0;
          }
          .carousel-content-hero {
            padding: 0.5rem 0.2rem;
            max-width: 98vw;
            border-radius: 8px;
          }
          .carousel-title-hero {
            font-size: 1rem;
            line-height: 1.1;
            margin-bottom: 0.5rem;
          }
          .carousel-subtitle-hero {
            font-size: 0.8rem;
            line-height: 1.2;
            margin-bottom: 0;
          }
        }
        .captured-images-row {
          display: flex;
          flex-wrap: nowrap;
          width: 100%;
          max-width: 380px;
          margin: 0 auto;
          justify-content: center;
          gap: 1.2rem;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
        }
        .captured-image-wrapper {
          width: 100%;
          max-width: 180px;
          min-width: 150px;
          flex: 1 1 150px;
          height: 286px;
          border: 1.5px solid #e0bfc9;
          border-radius: 18px;
          box-shadow: 0 4px 18px 0 rgba(123,34,60,0.10);
          background: #fff;
          overflow: hidden;
          padding: 0;
          margin: 0 0 0.5rem 0;
        }
        .captured-image-wrapper img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          border-radius: inherit;
          display: block;
          margin: 0;
        }
        .property-icon-theme {
          color: #7b223c !important;
        }
        .property-header {
          font-size: 1.45rem;
          font-weight: 700;
          letter-spacing: 0.5px;
          display: flex;
          align-items: center;
          gap: 0.7rem;
          margin-bottom: 1.2rem;
          border-bottom: 3px solid #7b223c;
          padding-bottom: 0.3rem;
        }
        .property-label {
          font-weight: 800 !important;
          border-bottom: 2px solid #e0e0e0;
          padding-bottom: 2px;
          margin-bottom: 0.2rem;
          display: inline-block;
          font-size: 1.19rem;
          color: #7b223c !important;
          letter-spacing: 0.5px;
        }
        .property-value {
          font-weight: 600;
          font-size: 1.15rem;
          color: #222;
        }
        .property-card-container {
          margin-left: 1.5rem;
          margin-right: 1.5rem;
          margin-bottom: 0.5rem;
        }
        @media (max-width: 767.98px) {
          .property-card-container {
            margin-left: 0.2rem;
            margin-right: 0.2rem;
            margin-bottom: 0.2rem;
          }
        }
        .row.g-2 > .col-6,
        .row.g-2 > .col-12 {
          margin-bottom: 0.7rem;
        }
        .btn-theme-brown {
          background: #7b223c !important;
          color: #fff !important;
          border: none;
          
        }
        .btn-theme-brown:hover, .btn-theme-brown:focus {
          background: #5a182c !important;
          color: #fff !important;
        }
        .disclaimer-card {
          background: #fff8e1;
          border-left: 5px solid #e53935;
          border-radius: 10px;
          padding: 1rem 1.2rem;  /* Add this padding */
          margin-bottom: 1rem;
          box-shadow: 0 2px 8px 0 rgba(229,57,53,0.07);
        }
        .disclaimer-title {
          color: #b85b2c;
          font-size: 1.08rem;
          font-weight: 700;
          margin-bottom: 0.3rem;
        }
        .disclaimer-text {
          color: #333;
          font-size: 0.98rem;
          margin-bottom: 0;
        }
      </style>
      <div class="body-gradient-bg">
        <section class="id_indore_microsite_template">
          <!-- Header Section with Carousel -->
          <div class="welcome-strip">
            <span>Welcome to Digital Pata</span><br/>
            <span>Indore Municipal Corporation.</span>
          </div>
          <header class="header-gradient text-white py-0" style="position:relative;">
            <!-- 1. Build a flat list of banners -->
            <t t-set="banners" t-value="[]"/>
            <t t-foreach="services" t-as="srv">
              <t t-foreach="srv.banner_line_ids" t-as="banner">
                <t t-if="banner.is_active and banner.icon">
                  <t t-set="banners" t-value="banners + [banner]"/>
                </t>
              </t>
            </t>
            
            <!-- 2. Render the carousel with only one .active -->
            <div id="headerCarousel" class="carousel slide header-carousel" data-bs-ride="carousel" data-bs-interval="4000">
              <div class="carousel-inner">
                <t t-set="first" t-value="True"/>
                <t t-foreach="banners" t-as="banner">
                  <div t-attf-class="carousel-item #{'active' if first else ''}"
                       t-attf-style="background-image: url('/web/image?model=banner.officer.line&amp;id={{ banner.id }}&amp;field=icon&amp;unique=1');">
                    <div class="carousel-content-hero">
                      <h1 class="carousel-title-hero"><t t-out="banner.name"/></h1>
                      <p class="carousel-subtitle-hero"><t t-out="banner.text"/></p>
                    </div>
                  </div>
                  <t t-set="first" t-value="False"/>
                </t>
                <t t-if="not banners">
                  <div class="carousel-item active" style="background-image: linear-gradient(135deg, #7b223c 0%, #b85b2c 100%);">
                    <div class="carousel-content-hero">
                      <h1 class="carousel-title-hero">Welcome to DDN Indore</h1>
                      <p class="carousel-subtitle-hero">Digital Pata</p>
                    </div>
                  </div>
                </t>
              </div>
              <t t-if="banners and len(banners) > 1">
                <button class="carousel-control-prev" type="button" data-bs-target="#headerCarousel" data-bs-slide="prev">
                  <span class="carousel-control-prev-icon"></span>
                  <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#headerCarousel" data-bs-slide="next">
                  <span class="carousel-control-next-icon"></span>
                  <span class="visually-hidden">Next</span>
                </button>
              </t>
            </div>
          </header>
      
          <!-- Property Details Section -->
          <section class="py-1">
            <div class="center-section">
              <div class="card p-4 position-relative border border-white rounded-4 property-card-container" style="margin-top:0;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <div class="property-header">
                    <i class="bi bi-house-door-fill property-icon-theme" style="font-size:1.5em;"></i>
                    <span>Property Details</span>
                  </div>
                </div>
                <div class="row g-2">
                  <div class="col-6">
                    <div class="property-label">
                      <i class="bi bi-hash me-1 property-icon-theme"></i> Unit No.
                    </div>
                    <div class="property-value">
                      <t t-if="property.unit_no"><t t-out="property.unit_no"/></t>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="property-label">
                      <i class="bi bi-qr-code me-1 property-icon-theme"></i> Digital Pata
                    </div>
                    <div class="property-value">
                      <t t-if="property.upic_no"><t t-out="property.upic_no"/></t>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="property-label">
                      <i class="bi bi-geo-alt-fill me-1 property-icon-theme"></i> Zone
                    </div>
                    <div class="property-value">
                      <t t-if="property.zone_id and property.zone_id.name"><t t-out="property.zone_id.name"/></t>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="property-label">
                      <i class="bi bi-grid-1x2-fill me-1 property-icon-theme"></i> Ward
                    </div>
                    <div class="property-value">
                      <t t-if="property.ward_id and property.ward_id.name"><t t-out="property.ward_id.name"/></t>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="property-label">
                      <i class="bi bi-house-door-fill me-1 property-icon-theme"></i> Colony
                    </div>
                    <div class="property-value">
                      <t t-if="property.colony_id and property.colony_id.name">
                        <t t-out="property.colony_id.name"/>
                      </t>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="property-label">
                      <i class="bi bi-fingerprint me-1 property-icon-theme"></i> Property Id
                    </div>
                    <div class="property-value">
                      <t t-if="property.property_id">
                        <t t-out="property.property_id"/>
                      </t>
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="d-flex align-items-center property-label" style="gap: 0.5rem;">
                      <span><i class="bi bi-globe me-1 property-icon-theme"></i> Latitude &amp; Longitude</span>
                      <t t-if="property.uuid">
                        <t t-set="property_url" t-value="(property.company_id.website or request.httprequest.url_root).strip('/') + '/get/' + property.uuid"/>
                        <t t-set="has_coordinates" t-value="property.survey_line_ids and property.survey_line_ids[0] and property.survey_line_ids[0].latitude is not None and property.survey_line_ids[0].longitude is not None and property.survey_line_ids[0].latitude != '' and property.survey_line_ids[0].longitude != ''"/>
                        <t t-if="has_coordinates">
                          <t t-set="lat" t-value="str(property.survey_line_ids[0].latitude)"/>
                          <t t-set="lng" t-value="str(property.survey_line_ids[0].longitude)"/>
                          <t t-set="valid_coords" t-value="lat != '1.2' and lng != '1.1' and lat != '0.0' and lng != '0.0' and float(lat) != 0.0 and float(lng) != 0.0"/>
                          <t t-if="valid_coords">
                            <!-- Google Maps URL with pin -->
                            <t t-set="maps_url" t-value="'https://www.google.com/maps?q=' + lat + ',' + lng + '&amp;z=16'"/>
                            <!-- Enhanced Navigation URLs for different travel modes -->
                            <t t-set="directions_driving" t-value="'https://www.google.com/maps/dir/?api=1&amp;destination=' + lat + ',' + lng + '&amp;travelmode=driving'"/>
                            <t t-set="directions_walking" t-value="'https://www.google.com/maps/dir/?api=1&amp;destination=' + lat + ',' + lng + '&amp;travelmode=walking'"/>
                            <t t-set="directions_transit" t-value="'https://www.google.com/maps/dir/?api=1&amp;destination=' + lat + ',' + lng + '&amp;travelmode=transit'"/>
                            <t t-set="share_text" t-value="'Check out this property on Bharat DDN!' + '%0A%0A' + property_url + '%0A%0A📍 Location: ' + lat + ', ' + lng + '%0A🗺️ View on Map: ' + maps_url + '%0A🚗 Drive: ' + directions_driving + '%0A🚶 Walk: ' + directions_walking + '%0A🚌 Transit: ' + directions_transit"/>
                          </t>
                          <t t-else="">
                            <t t-set="maps_url" t-value="''"/>
                            <t t-set="directions_driving" t-value="''"/>
                            <t t-set="directions_walking" t-value="''"/>
                            <t t-set="directions_transit" t-value="''"/>
                            <t t-set="share_text" t-value="'Check out this property on Bharat DDN!' + '%0A%0A' + property_url"/>
                          </t>
                        </t>
                        <t t-else="">
                          <t t-set="maps_url" t-value="''"/>
                          <t t-set="directions_driving" t-value="''"/>
                          <t t-set="directions_walking" t-value="''"/>
                          <t t-set="directions_transit" t-value="''"/>
                          <t t-set="share_text" t-value="'Check out this property on Bharat DDN!' + '%0A%0A' + property_url"/>
                          <t t-set="valid_coords" t-value="False"/>
                        </t>
                      </t>
                      <t t-else="">
                        <t t-set="maps_url" t-value="''"/>
                        <t t-set="directions_driving" t-value="''"/>
                        <t t-set="directions_walking" t-value="''"/>
                        <t t-set="directions_transit" t-value="''"/>
                        <t t-set="share_text" t-value="'Check out this property on Bharat DDN!' + '%0A%0A' + property_url"/>
                        <t t-set="valid_coords" t-value="False"/>
                      </t>
                      <a t-att-href="'https://wa.me/?text=' + share_text"
                         class="btn btn-theme-red btn-sm d-flex align-items-center"
                         style="font-weight:600; padding:2px 12px; font-size:0.95rem;"
                         target="_blank">
                      </a>
                    </div>
                    <div class="property-value" style="margin-bottom:0;">
                      <t t-if="property.survey_line_ids and property.survey_line_ids[0]">
                        <t t-if="property.survey_line_ids[0].latitude and property.survey_line_ids[0].longitude">
                          <t t-out="property.survey_line_ids[0].latitude"/> &amp; <t t-out="property.survey_line_ids[0].longitude"/>
                        </t>
                      </t>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- DIGIPIN Section -->
          <div class="center-section mt-3">
            <div class="card p-4 position-relative rounded-4 property-card-container"
                 style="max-width: 420px; overflow:visible; border:3px solid #e53935; box-shadow:0 2px 16px 0 rgba(229,57,53,0.10);">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div style="font-weight:700; color:#7b223c; font-size:1.1rem;">Your DIGIPIN</div>
                <button type="button" class="btn-close" aria-label="Close" style="opacity:0.5; pointer-events:none;"></button>
              </div>
              <div style="font-size:2.2rem; font-weight:900; letter-spacing:2px; color:#222;">
                <t t-if="property.digipin"><t t-out="property.digipin"/></t>
              </div>
              <div style="font-size:1.1rem; color:#7b223c; font-weight:600;">
                <t t-if="property.survey_line_ids and property.survey_line_ids[0]">
                  <t t-if="property.survey_line_ids[0].latitude and property.survey_line_ids[0].longitude">
                    <t t-out="property.survey_line_ids[0].latitude"/>, <t t-out="property.survey_line_ids[0].longitude"/>
                  </t>
                </t>
              </div>
              <div class="d-flex align-items-center mt-3" style="gap:1.2rem;">
                 <a t-att-href="'https://wa.me/?text=' + share_text"
                         class="btn btn-sm d-flex align-items-center"
                         style="font-weight:600; padding:2px 12px; font-size:0.95rem; background:#e53935; color:#fff;"
                         target="_blank">
                         <i class="bi bi-share" style="font-size:1.5rem; color:#fff;"></i>
                 </a>
              </div>
              <!-- India Post Logo, absolutely positioned at bottom right -->
              <img src="/bharat_ddn/static/images/india_post.svg"
                   alt="India Post"
                   style="position:absolute; bottom:10px; right:10px; height:70px; width:auto; z-index:2; background:transparent; box-shadow:none;"/>
            </div>
          </div>
          <!-- End DIGIPIN Section -->

          <!-- Captured Images Section -->
          <div class="center-section mt-3">
            <div class="card p-4 position-relative border border-white rounded-4 property-card-container">
              <div class="col-12">
                <h3 class="fw-bold mb-2 px-1 d-flex align-items-center" style="font-size:1.1rem; border-bottom: 2.5px solid #7b223c; padding-bottom: 0.2rem;">
                  <i class="bi bi-images property-icon-theme me-2" style="font-size:1.3rem;"></i>
                  Property Images
                </h3>
              </div>
              <div class="captured-images-row">
                <t t-if="property.survey_line_ids and property.survey_line_ids[0]">
                  <t t-set="img1" t-value="property.survey_line_ids[0].image1_s3_url"/>
                  <t t-set="img2" t-value="property.survey_line_ids[0].image2_s3_url"/>
                  <t t-if="img1">
                    <div class="captured-image-wrapper">
                      <img t-att-src="img1" class="img-fluid" alt="Captured Image 1" onerror="this.style.display='none'"/>
                    </div>
                  </t>
                  <t t-if="img2">
                    <div class="captured-image-wrapper">
                      <img t-att-src="img2" class="img-fluid" alt="Captured Image 2" onerror="this.style.display='none'"/>
                    </div>
                  </t>
                </t>
              </div>
            </div>
          </div>
          <!-- End Captured Images Section -->

          <!-- Government Payment Services -->
          <t t-foreach="services" t-as="srv">
            <div class="center-section mt-3">
              <div class="card p-4 position-relative border border-white rounded-4">
                <div class="section-title-container">
                  <div class="section-title-bg">Government Payment Services</div>
                </div>
                <div class="d-flex justify-content-center align-items-stretch payment-services-row">

                  <t t-foreach="srv.govt_line_ids" t-as="govt">
                    <t t-if="govt.is_active">
                      <div class="payment-service-box text-center">
                        <div class="icon-gradient-box mb-2 mx-auto">
                          <div class="govt-service-label">
                            <t t-out="Markup(govt.icon)"/>
                          </div>
                        </div>
                        <div class="govt-service-label">
                          <t t-out="govt.name"/>
                        </div>
                      </div>
                    </t>
                  </t>

                </div>
              </div>
            </div>


            <!-- Emergency Services -->
            <section class="py-1">
              <div class="center-section">
                <div class="card p-4 position-relative border border-white rounded-4">
                  <div class="section-title-container">
                    <div class="section-title-bg">Emergency Services</div>
                  </div>
                  <div class="card-body p-4">
                    <div class="row g-3">

                      <t t-foreach="srv.dial_line_ids" t-as="dial"> 
                        <t t-if="dial.is_active">

                            <div class="col-6 col-md-3">
                              <a t-att-href="'tel:+%s' % dial.mobile" class="ui-link text-decoration-none">
                                <div t-att-class="'emergency-card emergency-bg-' + dial.bg_color + ' text-center'">
                                  <div>
                                    <t t-out="Markup(dial.icon)"/>
                                    <div class="emergency-label"><t t-out="dial.name"/></div>
                                  </div>
                                </div>
                              </a>
                            </div>
                        </t>
                      </t>
                     
                    </div>
                  </div>
                </div>
              </div>
            </section>

            <!-- Your Officer Section -->
            <section class="py-1">
              <div class="center-section">
                <div class="card p-4 position-relative border border-white rounded-4">
                  <div class="card-body p-4">
                    <div class="section-title-container">
                      <div class="section-title-bg">Know Your Officers</div>
                    </div>
                    <div class="row g-3">
                      <t t-foreach="srv.know_officer_line_ids" t-as="officer"> 

                        <t t-if="property.zone_id == officer.zone_id and property.ward_id == officer.ward_id and officer.is_active or officer.is_global">
                          <!-- Zone Officer -->
                          <div class="col-6 col-md-3">
                            <a t-att-href="'tel:+%s' % officer.mobile" class="ui-link text-decoration-none">
                              <div class="officer-card text-center">
                                <div>
                                  <t t-out="Markup(officer.icon)"/>
                                  <div class="officer-label"><t t-out="officer.header"/></div>
                                  <div class="officer-name"><t t-out="officer.name"/></div>
                                  <t t-out="officer.mobile"/>
                                </div>
                              </div>
                            </a>
                          </div>
                        </t>
                      </t>
                    </div>
                  </div>
                </div>
              </div>            
            </section>
          </t>
          
        </section>

        <!-- Professional Disclaimer Section -->
        <section class="disclaimer-section mt-5">
          <div class="center-section">
            <div class="card p-4 position-relative border border-white rounded-4">
              <div class="section-title-container">
                <div class="section-title-bg">Legal Disclaimers</div>
              </div>
              <div class="row g-4">
                <div class="col-12 col-lg-6">
                  <div class="professional-disclaimer-card">
                    <div class="disclaimer-header">
                      <i class="bi bi-shield-exclamation disclaimer-icon"></i>
                      <h4 class="disclaimer-title">DigiPin™ Disclaimer</h4>
                    </div>
                    <div class="disclaimer-content">
                      <p>"DigiPIn"™ is a trademark of the Department of Posts, Government of India. The usage of the DIGIPIN / India Post logo on this portal is solely to identify India Post's open-source DigiPIn functionality. Indore Municipal Corporation has implemented the publicly available logic as provided by the Department of Posts. The Corporation is not responsible for any disconnected data, outdated content, or broken links displayed here.</p>
                    </div>
                  </div>
                </div>
                <div class="col-12 col-lg-6">
                  <div class="professional-disclaimer-card">
                    <div class="disclaimer-header">
                      <i class="bi bi-info-circle disclaimer-icon"></i>
                      <h4 class="disclaimer-title">Data Accuracy Disclaimer</h4>
                    </div>
                    <div class="disclaimer-content">
                      <p>Property and other records shown here are updated from the latest available municipal data. For corrections or updates—such as ownership, dimensions, addresses, etc.—please contact the Corporation or the Assistant Revenue Officer (ARO). Any decisions based on this information are at the user's own risk.</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
        <!-- End Professional Disclaimer Section -->

        <!-- Custom Microsite Footer -->
        <footer class="footer-gradient mt-5 custom-microsite-footer" style="border-radius: 0; display: block !important;">
          <div class="container py-4">
            <div class="row align-items-center">
              <div class="col-12 text-center footer-social mb-2">
                <a href="https://www.facebook.com/SwachhIndore/" class="social-link me-2" target="_blank" title="Facebook"><i class="bi bi-facebook"></i></a>
                <a href="https://x.com/swachhindore/" class="social-link me-2" target="_blank" title="Twitter"><i class="bi bi-twitter"></i></a>
                <a href="https://www.instagram.com/swachhindore/" class="social-link" target="_blank" title="Instagram"><i class="bi bi-instagram"></i></a>
              </div>
            </div>
            <div class="row mt-2">
              <div class="col-12 text-center" style="font-size:1rem;">
                This project is being undertaken by Indore Municipal Corporation
              </div>
            </div>
            <div class="row mt-2">
              <div class="col-12 text-center" style="font-size:1rem; margin-top:1rem;">
                Designed and Implemented by<br/>
                <span style="font-weight:600;">Redmelon Business Solutions Pvt Ltd</span>
              </div>
            </div>
          </div>
        </footer>
        <style>
          .custom-microsite-footer {
            display: block !important;
            background: linear-gradient(135deg, #7b223c 0%, #b85b2c 100%);
            color: #fff;
            position: relative;
            z-index: 1000;
          }
          .footer-social .social-link {
            color: #fffde7;
            font-size: 1.3rem;
            margin-right: 0.5rem;
            transition: color 0.2s;
          }
          .footer-social .social-link:hover {
            color: #ffd54f;
          }
          .footer-bottom {
            font-size: 0.95rem;
          }
          .powered-by {
            font-size: 0.9rem;
            opacity: 0.9;
          }
          .powered-link {
            color: #ffd54f;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
          }
          .powered-link:hover {
            color: #fff;
            text-decoration: underline;
          }
          .disclaimer-section {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            padding: 3rem 0 3rem 0;
            border-top: 1px solid #dee2e6;
            border-bottom: 1px solid #dee2e6;
          }
          .professional-disclaimer-card {
            background: #ffffff;
            border: 1px solid #e9ecef;
            border-radius: 16px;
            padding: 2rem 2rem 1.8rem 2rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 4px 20px 0 rgba(0,0,0,0.08);
            min-height: 240px;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
          }
          .professional-disclaimer-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #7b223c 0%, #b85b2c 100%);
          }
          .professional-disclaimer-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px 0 rgba(0,0,0,0.12);
            border-color: #7b223c;
          }
          .disclaimer-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.2rem;
            padding-bottom: 0.8rem;
            border-bottom: 1px solid #f1f3f4;
          }
          .disclaimer-title {
            color: #2c3e50;
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0;
            letter-spacing: 0.3px;
          }
          .disclaimer-icon {
            color: #7b223c;
            font-size: 1.8rem;
            background: linear-gradient(135deg, #7b223c 0%, #b85b2c 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
          }
          .disclaimer-content p {
            color: #495057;
            font-size: 1.05rem;
            margin-bottom: 0;
            margin-top: 0;
            font-weight: 400;
            line-height: 1.6;
            letter-spacing: 0.2px;
          }
          .disclaimer-content p:first-of-type {
            margin-top: 0.5rem;
          }
          @media (max-width: 991.98px) {
            .disclaimer-section {
              padding: 2rem 0 2rem 0;
            }
            .disclaimer-section .row.g-4 {
              flex-direction: column;
            }
            .professional-disclaimer-card {
              min-height: unset;
              margin-bottom: 1.5rem;
              padding: 1.5rem 1.5rem 1.3rem 1.5rem;
            }
            .disclaimer-title {
              font-size: 1.2rem;
            }
            .disclaimer-content p {
              font-size: 1rem;
            }
          }
        </style>
        <!-- End Custom Microsite Footer -->

      </div>
    </t>
  </template>
</odoo>
