<odoo>
    <record id="action_ddn_services" model="ir.actions.act_window">
        <field name="name">DDN Services</field>
        <field name="res_model">ddn.services</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item Binding -->


    <!-- Tree View -->
    <record id="view_ddn_services_tree" model="ir.ui.view">
        <field name="name">ddn.services.list</field>
        <field name="model">ddn.services</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="header"/>
                <field name="header2"/>
                <field name="sub_header"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
<record id="view_ddn_services_form" model="ir.ui.view">
    <field name="name">ddn.services.form</field>
    <field name="model">ddn.services</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="header"/>
                    <field name="header2"/>
                    <field name="sub_header"/>
                    <field name="company_id"/>
                </group>
            </sheet>

            <notebook>
                <page name="govt_line_ids" string="Payment Services">
                    <!-- Payment Services -->
                <field name="govt_line_ids">
                    <list>
                        <field name="name"/>
                        <field name="icon"/>
                        <field name="text"/>
                        <field name="hyperlink"/>
                        <field name="is_global"/>
                        <field name="is_active"/>
                    </list>
                    <form>
                        <group>
                            <field name="name"/>
                            <field name="icon"/>
                            <field name="text"/>
                            <field name="hyperlink"/>
                            <field name="is_global"/>
                            <field name="is_active"/>
                        </group>
                    </form>
                </field>
                </page>


                <!-- Tracking Services -->
                <page string="Tracking Services">
                    <field name="tracking_line_ids">
                        <list>
                            <field name="name"/>
                            <field name="icon"/>
                            <field name="text"/>
                            <field name="hyperlink"/>
                            <field name="is_global"/>
                            <field name="is_active"/>
                        </list>
                        <form>
                            <group>
                                <group>
                                    <field name="name"/>
                                    <field name="icon"/>
                                    <field name="hyperlink"/>
                                </group>
                                <group>
                                    <field name="text"/>
                                    <field name="is_global"/>
                                    <field name="is_active"/>
                                </group>
                            </group>
                        </form>
                    </field>
                </page>

                <!-- Know Officer Services -->
                <page string="Know Officer Services">
                    <field name="know_officer_line_ids">
                        <list>
                            <field name="header"/>
                            <field name="name"/>
                            <field name="mobile"/>
                            <field name="icon"/>
                            <field name="is_global"/>
                            <field name="company_id"/>
                            <field name="zone_id"/>
                            <field name="ward_id" domain="[('zone_id','=',zone_id)]"/>
                            <field name="is_active" default="1"/>
                        </list>
                        <form>
                            <group>
                                <group>
                                    <field name="header"/>
                                    <field name="name"/>
                                    <field name="mobile"/>
                                    <field name="icon"/>
                                    <field name="company_id"/>
                                    <field name="zone_id" domain="[('company_id','=',company_id)]" invisible="is_global" options="{'no_create':True, 'no_create_edit':True}"/>
                                    <field name="ward_id" domain="[('zone_id','=',zone_id),('company_id','=',company_id)]" invisible="is_global" options="{'no_create':True, 'no_create_edit':True}"/>
                                </group>
                                <group>
                                    <field name="is_global"/>
                                    <field name="is_active" default="1"/>
                                </group>
                            </group>
                        </form>
                    </field>
                </page>

                <!-- Emergency Services -->
                <page string="Emergency Services">
                    <field name="dial_line_ids">
                        <list>
                            <field name="name"/>
                            <field name="mobile"/>
                            <field name="icon"/>
                            <field name="bg_color"/>
                            <field name="is_global"/>
                            <field name="is_active"/>
                        </list>
                        <form>
                            <group>
                                <group>
                                    <field name="name"/>
                                    <field name="mobile"/>
                                    <field name="icon"/>
                                    <field name="bg_color"/>
                                </group>
                                <group>
                                    <field name="is_global"/>
                                    <field name="is_active"/>
                                </group>
                            </group>
                        </form>
                    </field>
                </page>

                <!-- Other Services -->
                <page string="Other Services">
                    <field name="other_line_ids">
                        <list>
                            <field name="name"/>
                            <field name="icon"/>
                            <field name="text"/>
                            <field name="hyperlink"/>
                            <field name="is_global"/>
                            <field name="is_active"/>
                        </list>
                        <form>
                            <group>
                                <group>
                                    <field name="name"/>
                                    <field name="icon"/>
                                    <field name="text"/>
                                </group>
                                <group>
                                    <field name="hyperlink"/>
                                    <field name="is_global"/>
                                    <field name="is_active"/>
                                </group>
                            </group>
                        </form>
                    </field>
                </page>

                <!-- Banner Services -->
                <page string="Banner Services">
                    <field name="banner_line_ids">
                        <list>
                            <field name="name"/>
                            <field name="icon"/>
                            <field name="text"/>
                            <field name="hyperlink"/>
                            <field name="is_global"/>
                            <field name="is_active"/>
                        </list>
                        <form>
                            <group>
                                <group>
                                    <field name="name"/>
                                    <field name="icon" widget="image"/>
                                    <field name="text"/>
                                </group>
                                <group>
                                    <field name="hyperlink"/>
                                    <field name="is_global"/>
                                    <field name="is_active"/>
                                </group>
                            </group>
                        </form>
                    </field>
                </page>
            </notebook>
        </form>
    </field>
</record>

</odoo>
