<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- list and Form View for Zone Model -->
        <record id="view_colony_list" model="ir.ui.view">
            <field name="name">ddn.colony.list</field>
            <field name="model">ddn.colony</field>
            <field name="arch" type="xml">
                <list string="Colonies">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="ward_id"/>
                    <field name="property_count"/>
                    <field name="company_id"/>
                    <field name="pdf_status" widget="badge" decoration-success="pdf_status == 'uploaded'" decoration-danger="pdf_status == 'not_uploaded'" string="PDF"/>
                    <field name="pdf_url" widget="copy_clipboard" string="PDF URL"/>
                </list>
            </field>
        </record>

        <record id="view_colony_form" model="ir.ui.view">
            <field name="name">ddn.colony.form</field>
            <field name="model">ddn.colony</field>
            <field name="arch" type="xml">
                <form string="Colony">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                        <button type="object"
                                class="oe_stat_button"
                                icon="fa-home"
                                name="action_open_property">
                            <field name="property_count" widget="statinfo"
                                   string="property"/>
                        </button>
                    </div>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="ward_id"/>
                            <field name="property_count"/>
                            <field name="company_id" options="{'no_create_edit':True, 'no_create':True, 'no_open':True}"/>
                            <field name="pdf_url" widget="url" readonly="1" attrs="{'invisible': [('pdf_urls_html', '!=', False)]}"/>
                            <field name="pdf_urls_html" widget="html" readonly="1" string="PDF Download Links" attrs="{'invisible': [('pdf_urls_html', '=', False)]}"/>
                        </group>
                    </sheet>
                    <chatter/>

                </form>
            </field>
        </record>

        <record id="action_colony" model="ir.actions.act_window">
            <field name="name">Colonies</field>
            <field name="res_model">ddn.colony</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_colony_list"/>
        </record>

        <record id="model_ddn_colony_action_server" model="ir.actions.server">
            <field name="name">Create PDF</field>
            <field name="model_id" ref="bharat_ddn.model_ddn_colony"/>
            <field name="binding_model_id" ref="bharat_ddn.model_ddn_colony"/>
            <field name="binding_view_types">form</field>
            <field name="state">code</field>
            <field name="code">action = records.update_ward()
            </field>
        </record>

    </data>
</odoo>