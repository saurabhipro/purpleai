<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- QR Scan List View -->
        <record id="view_qr_scan_list" model="ir.ui.view">
            <field name="name">ddn.qr.scan.list</field>
            <field name="model">ddn.qr.scan</field>
            <field name="arch" type="xml">
                <list string="QR Code Scans" create="false" edit="false" default_order="scan_time desc">
                    <header>
                        <button name="%(action_qr_scan_export_to_excel)d" 
                                string="Export All Scans to Excel" 
                                type="action" 
                                class="btn-primary"
                                icon="fa-file-excel-o"/>
                    </header>
                    <field name="scan_time" string="Scan Date &amp; Time"/>
                    <field name="uuid" string="UUID"/>
                    <field name="upic_no" string="Property UPIC"/>
                    <field name="property_id" string="Property" optional="hide"/>
                    <field name="scan_url" string="Scanned URL"/>
                </list>
            </field>
        </record>

        <!-- QR Scan Form View -->
        <record id="view_qr_scan_form" model="ir.ui.view">
            <field name="name">ddn.qr.scan.form</field>
            <field name="model">ddn.qr.scan</field>
            <field name="arch" type="xml">
                <form string="QR Code Scan" create="false" edit="false">
                    <sheet>
                        <group>
                            <group>
                                <field name="scan_time" string="Scan Date &amp; Time"/>
                                <field name="uuid" string="UUID"/>
                                <field name="upic_no" string="Property UPIC"/>
                            </group>
                            <group>
                                <field name="property_id" string="Property"/>
                                <field name="scan_url" string="Scanned URL" widget="url"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- QR Scan Action -->
        <record id="action_qr_scan" model="ir.actions.act_window">
            <field name="name">QR Code Scans</field>
            <field name="res_model">ddn.qr.scan</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_qr_scan_list"/>
        </record>

    </data>
</odoo>
