<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Hide Notification -->
    <t t-inherit="mail.MessagingMenu" t-inherit-mode="extension">
        <xpath expr="//*[@t-name='mail.MessagingMenu']/div[contains(@t-att-class, 'discussSystray.class')]" position="replace">
            <div t-att-class="discussSystray.class" style="display: none !important"/>
        </xpath>
    </t>

    <!-- Hide Activity -->
    <t t-inherit="mail.ActivityMenu" t-inherit-mode="extension">
        <xpath expr="//*[@t-name='mail.ActivityMenu']/Dropdown[contains(@menuClass, 'discussSystray.menuClass')]/button" position="replace">
            <button style="display: none !important"/>
        </xpath>
    </t>
</templates>