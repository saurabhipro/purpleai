<templates xml:space="preserve">
    <t t-name="smkc.OwlCrmTemplate" owl="1">
        <style>
        .dashboard-card {
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center;
            border: none;
            border-radius: 0px;
            box-shadow: 0 4px 16px rgba(33, 150, 243, 0.10);
            margin-bottom: 16px;
            min-width: 0;
            min-height: 78px;
            height: 78px;
            max-width: 100%;
            flex: 1 1 0;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 10px 8px 8px 18px;
            transition: box-shadow 0.2s;
            clip-path: polygon(8px 0%, 100% 0%, 100% 100%, 0% 100%, 0% 8px);
        }
        .bg-orange {
            background-image: url('/bharat_ddn/static/images/orange_pattern.jpg');
            border-left: 4px solid #ffa726;
        }
        .bg-green {
            background-image: url('/bharat_ddn/static/images/green_pattern.jpg');
            border-left: 4px solid #66bb6a;
        }
        .bg-blue {
            background-image: url('/bharat_ddn/static/images/blue_pattern.jpg');
            border-left: 4px solid #42a5f5;
        }
        .bg-pink {
            background-image: url('/bharat_ddn/static/images/pink_pattern.jpg');
            border-left: 4px solid #ec407a;
        }
        .bg-purple {
            background-image: url('/bharat_ddn/static/images/purple_pattern.jpg');
            border-left: 4px solid #ab47bc;
        }
        .bg-yellow {
            background-image: url('/bharat_ddn/static/images/yellow_pattern.jpg');
            border-left: 4px solid #ffee58;
        }
        .dashboard-card .count,
        .dashboard-card .label,
        .dashboard-card .bg-icon {
            color: #111 !important;
        }
        .dashboard-card .count {
            font-size: 1.08rem;
            font-weight: bold;
            margin-bottom: 0.1em;
            text-align: center;
        }
        .dashboard-card .label {
            font-size: 0.84rem;
            font-weight: 700;
            text-align: center;
        }
        .dashboard-card .bg-icon {
            opacity: 0.6;
            color: #fff !important;
            font-size: 1.44rem;
            position: absolute;
            right: 10px;
            bottom: 8px;
        }
        .property-dashboard {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            column-gap: 18px;
            row-gap: 4px;
            width: 100%;
            margin-left: 0;
            padding-left: 0;
        }
        .dashboard-card:hover {
            box-shadow: 0 4px 16px rgba(33, 150, 243, 0.18);
        }
        .property-ward-table {
            width: 100%;
            box-sizing: border-box;
            /* Optional: add max-width if needed */
            /* max-width: 100%; */
        }
        /* Tablet: 3 columns */
        @media (max-width: 1024px) {
            .property-dashboard {
                grid-template-columns: repeat(3, 1fr);
            }
        }
        /* Mobile: 1 column */
        @media (max-width: 600px) {
            .property-dashboard {
                grid-template-columns: 1fr;
            }
            .dashboard-card {
                min-width: 0;
                width: 100%;
                margin-bottom: 12px;
            }
            .dashboard-card .count {
                font-size: 1rem;
            }
            .dashboard-card .label {
                font-size: 0.75rem;
            }
            .dashboard-card {
                padding: 8px 4px 6px 10px;
            }
        }
        .cursor-pointer {
            cursor: pointer;
        }
        .highlight-survey-row {
            background-color: #fff9c4 !important; /* Pastel yellow highlight */
            border-left: 4px solid #fbc02d;
        }
        .property-ward-table tbody tr:hover {
            background-color: rgba(33, 150, 243, 0.1); 
        }
        </style>
        <div class="vh-100 overflow-auto bg-muted">
            <div class="row m-3">
                <div class="col">
                    <div class="property-dashboard">
                        <div t-on-click="_onClickPropertyStatusCard">
                            <a href="#" class="dashboard-card bg-orange" target="_blank" >
                                <span class="bg-icon"><i class="fa fa-upload"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['total_count']"/></div>
                                <div class="label">Plates Printed</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickPropertyStatusCard">
                            <a href="#" class="dashboard-card bg-green" target="_blank" t-att-status="'pdf_downloaded'">
                                <span class="bg-icon"><i class="fa fa-file-pdf-o"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['total_pdf_downloaded']"/></div>
                                <div class="label">Plates Remaining</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickPropertyStatusCard">
                            <a href="#" class="dashboard-card bg-orange" target="_blank" t-att-status="'visit_again'">
                                <span class="bg-icon"><i class="fa fa-repeat"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['total_visit_again']"/></div>
                                <div class="label">Visit Again</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickPropertyStatusCard">
                            <a href="#" class="dashboard-card bg-green" target="_blank" t-att-status="'discovered'">
                                <span class="bg-icon"><i class="fa fa-search"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['total_discovered']"/></div>
                                <div class="label">Discovered</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickPropertyStatusCard">
                            <a href="#" class="dashboard-card bg-purple" target="_blank" t-att-status="'surveyed'">
                                <span class="bg-icon"><i class="fa fa-check-square-o"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['total_surveyed']"/></div>
                                <div class="label">Plates Activated</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickTodaySurveyed">
                            <a href="#" class="dashboard-card bg-yellow" target="_blank">
                                <span class="bg-icon"><i class="fa fa-calendar-check-o"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['surveys_today'] || 0"/></div>
                                <div class="label">Surveyed Today</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickZone">
                            <a href="#" class="dashboard-card bg-orange" target="_blank">
                                <span class="bg-icon"><i class="fa fa-th-large"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['total_zones']"/></div>
                                <div class="label">Zones</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickWard">
                            <a href="#" class="dashboard-card bg-green" target="_blank">
                                <span class="bg-icon"><i class="fa fa-th-list"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['total_wards']"/></div>
                                <div class="label">Wards</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickColony">
                            <a href="#" class="dashboard-card bg-orange" target="_blank">
                                <span class="bg-icon"><i class="fa fa-building"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['total_colonies']"/></div>
                                <div class="label">Colonies</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickSurveyors">
                            <a href="#" class="dashboard-card bg-green" target="_blank">
                                <span class="bg-icon"><i class="fa fa-user"></i></span>
                                <div class="count"><t t-esc="this.state.property_info['total_surveyors']"/></div>
                                <div class="label">Surveyors</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickScansToday">
                            <a href="#" class="dashboard-card bg-blue" target="_blank">
                                <span class="bg-icon"><i class="fa fa-qrcode"></i></span>
                                <div class="count">
                                    <t t-esc="(this.state.property_info['total_qr_scans_today'] || 0) + ' / ' + (this.state.property_info['unique_qr_scans_today'] || 0)"/>
                                </div>
                                <div class="label">Scans Today</div>
                            </a>
                        </div>
                        <div t-on-click="_onClickTotalScans">
                            <a href="#" class="dashboard-card bg-pink" target="_blank">
                                <span class="bg-icon"><i class="fa fa-qrcode"></i></span>
                                <div class="count">
                                    <t t-esc="(this.state.property_info['total_qr_scans'] || 0) + ' / ' + (this.state.property_info['unique_qr_scans'] || 0)"/>
                                </div>
                                <div class="label">Total Scans</div>
                            </a>
                        </div>
                    </div>
                    <div>
                        <div class="property-map-header dashboard-header">
                            <div class="dashboard-header-content">
                                <span class="dashboard-header-icon"><i class="fa fa-map-marker"></i></span>
                                <span class="dashboard-header-title">Survey Summary</span>
                            </div>
                        </div>
                        <div class="property-map-content">
                            <table class="property-ward-table">
                                <thead>
                                    <tr>
                                        <th>Zone</th>
                                        <th>Ward</th>
                                        <th>Total</th>
                                        <th>Uploaded</th>
                                        <th>Plates Remaining</th>
                                        <th>Surveyed</th>
                                        <th>% Surveyed</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="state.property_info.ward_data || []" t-as="ward" t-key="ward.ward" 
                                        t-att-class="'cursor-pointer ' + (ward.has_surveys_today ? 'highlight-survey-row' : '')"
                                        t-on-click="_onClickWardRow"
                                        t-att-data-ward="ward.ward"
                                        t-att-data-zone="ward.zone">
                                        <td><t t-esc="ward.zone"/></td>
                                        <td><t t-esc="ward.ward"/></td>
                                        <td><t t-esc="ward.total_count"/></td>
                                        <td><t t-esc="ward.uploaded_count"/></td>
                                        <td><t t-esc="ward.pdf_downloaded_count"/></td>
                                        <td><t t-esc="ward.surveyed_count"/></td>
                                        <td><t t-esc="ward.surveyed_percent"/>%</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row m-3">
                <div class="col-md-3 d-flex align-items-stretch">
                    <GraphComponent canvas_id="'pie'" chart_type="'pie'" chart_data="state.property_info.pie_data"/>
                </div>
                <div class="col-md-3 d-flex align-items-stretch">
                    <GraphComponent canvas_id="'bar'" chart_type="'bar'" chart_data="state.property_info.pie_data"/>
                </div>
                <div class="col-md-3 d-flex align-items-stretch">
                    <GraphComponent canvas_id="'line'" chart_type="'line'" chart_data="state.property_info.pie_data"/>
                </div>
                <div class="col-md-3 d-flex align-items-stretch">
                    <GraphComponent canvas_id="'doughnut'" chart_type="'doughnut'" chart_data="state.property_info.pie_data"/>
                </div>
            </div>
            <div class="row m-3">
                <div class="col-md-3">
                    <label>Start Date</label>
                    <input t-ref="startDate" type="date" class="form-control"/>
                </div>
                <div class="col-md-3">
                    <label>End Date</label>
                    <input t-ref="endDate" type="date" class="form-control"/>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button t-on-click="loadGraphData" class="btn btn-primary">Load Survey Stats</button>
                </div>
            </div>
            <div class="row m-3">
                <div class="col d-flex align-items-stretch">
                    <GraphComponent canvas_id="'surveyedPerDayChart'" chart_type="'bar'" chart_data="state.survey_data"/>
                </div>
            </div>
            <br/>
            <br/>
            <br/>


            <!-- <div class="row m-3">
                <div t-if="state.error" class="alert alert-danger" role="alert">
                    <t t-esc="state.error"/>
                </div>
                
                <div>
                    <div class="property-map-header dashboard-header">
                        <div class="dashboard-header-content">
                            <span class="dashboard-header-icon"><i class="fa fa-map-marker"></i></span>
                            <span class="dashboard-header-title">Property Map</span>
                        </div>
                    </div>
                    <PropertyMapView/>
                </div>
            </div> -->
        </div>
    </t>
</templates>