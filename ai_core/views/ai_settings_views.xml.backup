<odoo>
    <data>
        <record id="view_ai_core_settings_general" model="ir.ui.view">
            <field name="name">res.config.settings.ai.core.general</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="120"/>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='general_settings']/block[1]" position="before">
                    <block title="AI Core Configuration" name="ai_core_settings_block">
                            <setting title="Primary AI Provider" help="These shared AI Core settings are used by Purple Invoices and Memo AI.">
                                <field name="provider" widget="radio" class="o_field_radio_vertical"/>
                            </setting>

                            <setting title="Test AI Connection" help="Click to verify your AI provider configuration is working correctly.">
                                <button
                                    name="action_test_ai_connection"
                                    type="object"
                                    string="Test AI Connection"
                                    class="btn btn-primary"
                                    icon="fa-plug"
                                />
                            </setting>

                            <setting title="OpenAI" help="Credentials and default model when provider is OpenAI." invisible="provider != 'openai'">
                                <div class="content-group">
                                    <field name="openai_key" password="True" placeholder="sk-..."/>
                                    <field name="openai_model" placeholder="gpt-4o"/>
                                    <div class="text-muted small mt-2">
                                        <a href="https://platform.openai.com/api-keys" class="oe_link" target="_blank" rel="noreferrer">OpenAI Platform — API keys</a>
                                        ·
                                        <a href="https://platform.openai.com/docs/overview" class="oe_link" target="_blank" rel="noreferrer">Documentation</a>
                                    </div>
                                </div>
                            </setting>

                            <setting title="Google Gemini" help="Credentials and default model when provider is Google Gemini." invisible="provider != 'gemini'">
                                <div class="content-group">
                                    <field name="gemini_key" password="True" placeholder="AIzaSy..."/>
                                    <field name="gemini_model" placeholder="gemini-2.5-flash"/>
                                    <div class="text-muted small mt-2">
                                        <a href="https://aistudio.google.com/app/apikey" class="oe_link" target="_blank" rel="noreferrer">Google AI Studio — Get API key</a>
                                        ·
                                        <a href="https://ai.google.dev/gemini-api/docs" class="oe_link" target="_blank" rel="noreferrer">Gemini API docs</a>
                                    </div>
                                </div>
                            </setting>

                            <setting title="Azure OpenAI - Chat/Completion" help="Used for normal chat/completion requests when provider is Azure OpenAI." invisible="provider != 'azure'">
                                <div class="content-group">
                                    <label for="azure_endpoint"/>
                                    <field name="azure_endpoint" placeholder="https://&lt;resource&gt;.openai.azure.com/"/>
                                    <label for="azure_key"/>
                                    <field name="azure_key" password="True"/>
                                    <label for="azure_deployment"/>
                                    <field name="azure_deployment" placeholder="gpt-4o"/>
                                </div>
                            </setting>

                            <setting title="Azure OpenAI - Embeddings (Separate Optional Credentials)" help="Use this when embedding model is hosted on a different Azure resource/key." invisible="provider != 'azure'">
                                <div class="content-group">
                                    <label for="azure_embedding_endpoint"/>
                                    <field name="azure_embedding_endpoint" placeholder="https://&lt;resource&gt;.openai.azure.com/"/>
                                    <label for="azure_embedding_key"/>
                                    <field name="azure_embedding_key" password="True"/>
                                    <label for="azure_embedding_deployment"/>
                                    <field name="azure_embedding_deployment" placeholder="text-embedding-3-small"/>
                                    <field name="azure_api_version" placeholder="2024-12-01-preview"/>
                                    <div class="text-muted small mt-2">
                                        Leave Endpoint/API Key empty to reuse Chat credentials above.
                                    </div>
                                    <div class="text-muted small mt-2">
                                        <a href="https://portal.azure.com/#create/Microsoft.CognitiveServicesOpenAI" class="oe_link" target="_blank" rel="noreferrer">Azure Portal — Create OpenAI resource</a>
                                        ·
                                        <a href="https://oai.azure.com/" class="oe_link" target="_blank" rel="noreferrer">Azure OpenAI Studio</a>
                                        ·
                                        <a href="https://learn.microsoft.com/azure/ai-services/openai/how-to/create-resource" class="oe_link" target="_blank" rel="noreferrer">Microsoft Learn — setup guide</a>
                                    </div>
                                </div>
                            </setting>

                            <setting title="Embedding Strategy" help="Choose local or cloud embeddings for vector search.">
                                <field name="use_local_embeddings"/>
                                <field name="local_embedding_model" invisible="not use_local_embeddings" placeholder="sentence-transformers/all-MiniLM-L6-v2"/>
                            </setting>

                            <setting title="Generation Controls" help="Core generation behavior used by all AI calls.">
                                <field name="temperature"/>
                                <field name="max_tokens"/>
                            </setting>

                            <setting title="Cost Controls" help="Per 1M token rates used for cost calculations and reporting.">
                                <field name="prompt_cost"/>
                                <field name="completion_cost"/>
                            </setting>

                            <setting title="Invoice AI Processing Cost" help="Used by Invoice AI processing calculations (per 1M tokens in INR).">
                                <label for="tender_ai_input_cost" string="Processing Input Cost (per 1M tokens)"/>
                                <field name="tender_ai_input_cost"/>
                                <label for="tender_ai_output_cost" string="Processing Output Cost (per 1M tokens)"/>
                                <field name="tender_ai_output_cost"/>
                            </setting>

                            <setting title="React UI (development)" help="Optional integration for the Purple AI React app (folder purpleai_ui, script run_purpleai). Use a long random dev key; keep it private.">
                                <field name="react_dev_api_key" password="True" placeholder="e.g. openssl rand -hex 32"/>
                                <field name="react_cors_origins" placeholder="http://localhost:5173"/>
                            </setting>
                    </block>
                </xpath>

                <xpath expr="//app[@name='general_settings']/block[1]" position="after">
                    <block title="OCR Settings" name="ocr_settings_block">
                        <setting title="OCR Processing" help="Core OCR extraction settings">
                            <label for="ocr_dpi" string="Image DPI"/>
                            <field name="ocr_dpi"/>
                            <label for="ocr_languages" string="Tesseract Languages"/>
                            <field name="ocr_languages" placeholder="hin+eng"/>
                            <label for="ocr_timeout_per_page" string="Timeout Per Page (seconds)"/>
                            <field name="ocr_timeout_per_page"/>
                            <label for="ocr_timeout_total" string="Total Timeout (seconds)"/>
                            <field name="ocr_timeout_total"/>
                        </setting>

                        <setting title="Image Preprocessing" help="Preprocessing options for better OCR accuracy">
                            <field name="ocr_preprocess_denoise" string="Enable Denoising"/>
                            <field name="ocr_preprocess_deskew" string="Enable Deskewing"/>
                            <field name="ocr_preprocess_contrast" string="Enhance Contrast"/>
                            <field name="ocr_preprocess_threshold" string="Convert to B/W"/>
                            <label for="ocr_image_mode" string="Image Mode"/>
                            <field name="ocr_image_mode"/>
                        </setting>

                        <setting title="Tesseract Engine" help="OCR engine configuration">
                            <label for="ocr_psm_mode" string="Page Segmentation Mode (PSM)"/>
                            <field name="ocr_psm_mode"/>
                            <label for="ocr_oem_mode" string="OCR Engine Mode (OEM)"/>
                            <field name="ocr_oem_mode"/>
                        </setting>

                        <setting title="Performance &amp; Resources" help="Memory and concurrency settings">
                            <label for="ocr_max_memory_mb" string="Max Memory (MB)"/>
                            <field name="ocr_max_memory_mb"/>
                            <label for="ocr_concurrent_jobs" string="Concurrent Jobs"/>
                            <field name="ocr_concurrent_jobs"/>
                        </setting>

                        <setting title="PDF Processing" help="PDF-specific OCR options">
                            <label for="ocr_render_scale_factor" string="Render Scale Factor"/>
                            <field name="ocr_render_scale_factor"/>
                            <field name="ocr_check_searchability" string="Check Searchability First"/>
                            <label for="ocr_searchability_threshold" string="Searchability Threshold (chars)"/>
                            <field name="ocr_searchability_threshold"/>
                        </setting>

                        <setting title="Bounding Box Refinement" help="Text box detection refinement">
                            <field name="ocr_enable_box_refinement" string="Enable Box Refinement"/>
                            <label for="ocr_box_refinement_threshold" string="Match Score Threshold"/>
                            <field name="ocr_box_refinement_threshold"/>
                        </setting>

                        <setting title="Error Handling" help="Fallback and retry behavior">
                            <field name="ocr_enable_ocr_fallback" string="OCR Fallback on AI Failure"/>
                            <field name="ocr_retry_on_error" string="Retry on Error"/>
                        </setting>

                        <setting title="Debug &amp; Troubleshooting" help="Logging and debug output">
                            <field name="ocr_enable_debug_logging" string="Enable Debug Logging"/>
                            <field name="ocr_save_debug_images" string="Save Debug Images"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>

        <record id="view_ai_core_hide_dev_about" model="ir.ui.view">
            <field name="name">res.config.settings.ai.core.hide.dev.about</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="130"/>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//widget[@name='res_config_dev_tool']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//div[@id='about']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
