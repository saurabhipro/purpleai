<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_my_ai_settings_form" model="ir.ui.view">
        <field name="name">my.ai.settings.form</field>
        <field name="model">my.ai.settings</field>
        <field name="arch" type="xml">
            <form string="MyAI Settings">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="D-ID Configuration" name="did_config">
                            <group>
                                <group string="API Settings">
                                    <field name="did_api_key" password="True" 
                                           help="Your D-ID API key. Get it from https://studio.d-id.com/"/>
                                    <field name="did_api_url" 
                                           help="D-ID API base URL"/>
                                    <field name="did_default_avatar_url" 
                                           help="Default avatar image URL for video generation"/>
                                    <field name="did_default_voice_id" 
                                           help="Default Microsoft voice ID (e.g., en-US-JennyNeural, en-US-GuyNeural)"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Server Action to Load Settings -->
    <record id="action_my_ai_settings" model="ir.actions.server">
        <field name="name">MyAI Settings</field>
        <field name="model_id" ref="model_my_ai_settings"/>
        <field name="binding_model_id" ref="model_my_ai_settings"/>
        <field name="state">code</field>
        <field name="code">
# Get or create settings record
settings = env['my.ai.settings'].get_settings()
# Return action to open the settings form
action = {
    'type': 'ir.actions.act_window',
    'name': 'MyAI Settings',
    'res_model': 'my.ai.settings',
    'res_id': settings.id,
    'view_mode': 'form',
    'target': 'current',
}
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_my_ai_settings"
              name="Settings"
              parent="menu_my_ai_root"
              action="action_my_ai_settings"
              sequence="10"/>
</odoo>

