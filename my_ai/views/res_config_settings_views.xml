<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_my_ai" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.my.ai</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <block title="MyAI Settings" id="my_ai_settings">
                    <setting string="D-ID API Key">
                        <field name="did_api_key" password="True"/>
                        <div class="text-muted mt-2">
                            Your D-ID API key. Get it from <a href="https://studio.d-id.com/" target="_blank">https://studio.d-id.com/</a>
                        </div>
                    </setting>
                    <setting string="D-ID API URL">
                        <field name="did_api_url"/>
                        <div class="text-muted mt-2">
                            D-ID API base URL (default: https://api.d-id.com/talks)
                        </div>
                    </setting>
                    <setting string="Default Avatar Image URL">
                        <field name="did_default_avatar_url"/>
                        <div class="text-muted mt-2">
                            Default avatar image URL for video generation
                        </div>
                    </setting>
                    <setting string="Default Voice ID">
                        <field name="did_default_voice_id"/>
                        <div class="text-muted mt-2">
                            Default Microsoft voice ID (e.g., en-US-JennyNeural, en-US-GuyNeural)
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>

