<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_my_ai_base_tree" model="ir.ui.view">
        <field name="name">my.ai.base.list</field>
        <field name="model">my.ai.base</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="MyAI Base">
                <field name="name"/>
                <field name="active"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_my_ai_base_form" model="ir.ui.view">
        <field name="name">my.ai.base.form</field>
        <field name="model">my.ai.base</field>
        <field name="arch" type="xml">
            <form string="MyAI Base">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Enter description..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_my_ai_base_search" model="ir.ui.view">
        <field name="name">my.ai.base.search</field>
        <field name="model">my.ai.base</field>
        <field name="arch" type="xml">
            <search string="MyAI Base">
                <field name="name"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_my_ai_base" model="ir.actions.act_window">
        <field name="name">MyAI Base</field>
        <field name="res_model">my.ai.base</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first MyAI record!
            </p>
        </field>
    </record>
</odoo>

