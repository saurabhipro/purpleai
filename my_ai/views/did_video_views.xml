<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_did_video_list" model="ir.ui.view">
        <field name="name">my.ai.did.video.list</field>
        <field name="model">my.ai.did.video</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="D-ID Videos">
                <field name="title"/>
                <field name="upic_no"/>
                <field name="status" widget="badge" decoration-success="status == 'done'" decoration-warning="status == 'processing'" decoration-danger="status == 'error'"/>
                <field name="video_url" widget="url" invisible="status != 'done'"/>
                <field name="shareable_link" widget="url" invisible="not shareable_link"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_did_video_form" model="ir.ui.view">
        <field name="name">my.ai.did.video.form</field>
        <field name="model">my.ai.did.video</field>
        <field name="arch" type="xml">
            <form string="D-ID Video Generation">
                <header>
                    <button name="action_generate_video" string="Generate Video" type="object" 
                            class="btn-primary" invisible="status == 'processing' or status == 'done'"/>
                    <button name="action_check_status" string="Check Status" type="object" 
                            class="btn-secondary" invisible="status != 'processing'"/>
                    <button name="action_view_video" string="View Video" type="object" 
                            class="btn-info" icon="fa-video" invisible="status != 'done' or not video_url"/>
                    <button name="action_download_and_store_video" string="Download &amp; Store Video" type="object" 
                            class="btn-success" invisible="status != 'done' or attachment_id"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,processing,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_generate_video" 
                                icon="fa-video" invisible="status == 'processing' or status == 'done'">
                            <field name="status" widget="statinfo" string="Generate"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="upic_no" placeholder="Enter UPIC number to auto-generate greeting..."/>
                            <field name="property_id" readonly="1" invisible="not property_id"/>
                            <field name="title" placeholder="Video title (auto-filled from UPIC)"/>
                            <field name="status" readonly="1"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="write_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Script" invisible="not script_text">
                        <field name="script_text" placeholder="Script will be auto-generated when you enter UPIC number..." 
                               nolabel="1" widget="text"/>
                    </group>
                    <group string="Video Links" invisible="status != 'done'">
                        <field name="video_url" readonly="1" widget="url" string="Video URL" 
                               help="Click to open or copy this URL to share the original video"/>
                        <field name="shareable_link" readonly="1" widget="url" string="Shareable Link" 
                               invisible="not shareable_link"
                               help="Public link to share the video (stored in Odoo)"/>
                        <field name="talk_id" readonly="1" invisible="1"/>
                        <field name="attachment_id" readonly="1" invisible="1"/>
                    </group>
                    <group string="Error Details" invisible="status != 'error'">
                        <field name="error_message" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_did_video_search" model="ir.ui.view">
        <field name="name">my.ai.did.video.search</field>
        <field name="model">my.ai.did.video</field>
        <field name="arch" type="xml">
            <search string="D-ID Videos">
                <field name="title"/>
                <field name="upic_no"/>
                <field name="script_text"/>
                <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                <filter string="Processing" name="processing" domain="[('status', '=', 'processing')]"/>
                <filter string="Done" name="done" domain="[('status', '=', 'done')]"/>
                <filter string="Error" name="error" domain="[('status', '=', 'error')]"/>
                <separator/>
                <filter string="My Videos" name="my_videos" domain="[('create_uid', '=', uid)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_did_video" model="ir.actions.act_window">
        <field name="name">D-ID Video Generation</field>
        <field name="res_model">my.ai.did.video</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first AI-generated video!
            </p>
            <p>
                Use D-ID API to generate talking avatar videos from text scripts.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_did_video"
              name="D-ID Video Generation"
              parent="menu_my_ai_root"
              action="action_did_video"
              sequence="20"/>
</odoo>

