<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_audit_dashboard_form" model="ir.ui.view">
        <field name="name">audit.dashboard.form</field>
        <field name="model">audit.dashboard</field>
        <field name="arch" type="xml">
            <form string="Audit Dashboard" create="0" delete="0" edit="0">
                <style>
                    .dashboard-container {
                        padding: 20px;
                        background-color: #f6f7fa;
                        min-height: 100vh;
                    }
                    .dashboard-header {
                        margin-bottom: 30px;
                        color: #4c4c4c;
                    }
                    .kpi-card {
                        border: none;
                        border-radius: 10px;
                        color: white;
                        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                        transition: transform 0.2s;
                        cursor: pointer;
                        overflow: hidden;
                        margin-bottom: 20px;
                        display: flex;
                        flex-direction: column;
                        justify-content: space-between;
                        min-height: 140px;
                    }
                    .kpi-card:hover {
                        transform: translateY(-5px);
                        box-shadow: 0 6px 12px rgba(0,0,0,0.15);
                    }
                    .kpi-main {
                        padding: 20px;
                    }
                    .kpi-value {
                        font-size: 3rem;
                        font-weight: bold;
                        line-height: 1.2;
                    }
                    .kpi-label {
                        font-size: 1.1rem;
                        font-weight: 500;
                        opacity: 0.9;
                        margin-top: 5px;
                    }
                    .kpi-footer {
                        background-color: rgba(0,0,0,0.1);
                        padding: 10px 20px;
                        font-size: 0.9rem;
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                    }
                    /* Colors */
                    .bg-primary-gradient { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
                    .bg-info-gradient { background: linear-gradient(135deg, #30cfd0 0%, #330867 100%); }
                    .bg-warning-gradient { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
                    .bg-success-gradient { background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%); } 
                    /* Better Success Green */
                    .bg-custom-green { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color: #005c4b; }
                    .bg-custom-blue { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
                    .bg-custom-orange { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
                    .bg-custom-purple { background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%); }
                    
                    .section-title {
                        font-size: 1.2rem;
                        font-weight: bold;
                        color: #555;
                        margin: 25px 0 15px 0;
                        padding-bottom: 10px;
                        border-bottom: 2px solid #e9ecef;
                    }
                </style>
                
                <div class="dashboard-container">
                    <div class="dashboard-header oe_title">
                        <h1><i class="fa fa-tachometer text-primary"/> Audit Tool Dashboard</h1>
                    </div>
                    
                    <!-- Main Stats Row -->
                    <div class="row">
                        <div class="col-md-4 col-sm-12">
                            <div class="kpi-card bg-primary-gradient">
                                <div class="kpi-main">
                                    <div class="kpi-value"><field name="total_memos" readonly="1"/></div>
                                    <div class="kpi-label">Total Memos</div>
                                </div>
                                <div class="kpi-footer">
                                    <span>System Wide</span>
                                    <i class="fa fa-database"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="section-title">
                        <i class="fa fa-tasks"/> Memo Status Overview
                    </div>
                    
                    <div class="row">
                        <!-- Step 1: Draft -->
                        <div class="col-md-3 col-sm-6">
                            <button name="action_open_draft" type="object" class="kpi-card bg-custom-purple" style="width:100%; text-align:left;">
                                <div class="kpi-main">
                                    <div class="kpi-value"><field name="draft_memos" readonly="1"/></div>
                                    <div class="kpi-label">Draft (Step 1)</div>
                                </div>
                                <div class="kpi-footer">
                                    <span>View Details</span>
                                    <i class="fa fa-arrow-right"/>
                                </div>
                            </button>
                        </div>

                        <!-- Step 2: Partner Review -->
                        <div class="col-md-3 col-sm-6">
                            <button name="action_open_pending_partner" type="object" class="kpi-card bg-custom-blue" style="width:100%; text-align:left;">
                                <div class="kpi-main">
                                    <div class="kpi-value"><field name="pending_partner" readonly="1"/></div>
                                    <div class="kpi-label">Partner Review (Step 2)</div>
                                </div>
                                <div class="kpi-footer">
                                    <span>Pending Approval</span>
                                    <i class="fa fa-user-tie"/>
                                </div>
                            </button>
                        </div>

                        <!-- Step 3+: In Progress -->
                        <div class="col-md-3 col-sm-6">
                            <button name="action_open_in_progress" type="object" class="kpi-card bg-custom-orange" style="width:100%; text-align:left;">
                                <div class="kpi-main">
                                    <div class="kpi-value"><field name="in_progress" readonly="1"/></div>
                                    <div class="kpi-label">In Progress (Step 3-4)</div>
                                </div>
                                <div class="kpi-footer">
                                    <span>Preparer / NPSG</span>
                                    <i class="fa fa-cogs"/>
                                </div>
                            </button>
                        </div>
                        
                         <!-- Review -->
                        <div class="col-md-3 col-sm-6">
                            <button name="action_open_review" type="object" class="kpi-card bg-info-gradient" style="width:100%; text-align:left;">
                                <div class="kpi-main">
                                    <div class="kpi-value"><field name="pending_review" readonly="1"/></div>
                                    <div class="kpi-label">In Review (Level 1 &amp; Final)</div>
                                </div>
                                <div class="kpi-footer">
                                    <span>Review Stage</span>
                                    <i class="fa fa-check-square-o"/>
                                </div>
                            </button>
                        </div>

                        <!-- Approved -->
                        <div class="col-md-3 col-sm-6">
                            <button name="action_open_approved" type="object" class="kpi-card bg-custom-green" style="width:100%; text-align:left;">
                                <div class="kpi-main">
                                    <div class="kpi-value"><field name="approved" readonly="1"/></div>
                                    <div class="kpi-label">Approved</div>
                                </div>
                                <div class="kpi-footer">
                                    <span>Completed</span>
                                    <i class="fa fa-check-circle"/>
                                </div>
                            </button>
                        </div>

                        <!-- Rejected -->
                        <div class="col-md-3 col-sm-6">
                            <button name="action_open_rejected" type="object" class="kpi-card bg-warning-gradient" style="width:100%; text-align:left;">
                                <div class="kpi-main">
                                    <div class="kpi-value"><field name="rejected" readonly="1"/></div>
                                    <div class="kpi-label">Rejected / Returned</div>
                                </div>
                                <div class="kpi-footer">
                                    <span>Attention Needed</span>
                                    <i class="fa fa-exclamation-triangle"/>
                                </div>
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </field>
    </record>

    <!-- Server Action to Open Dashboard properly -->
    <record id="action_open_audit_dashboard_server" model="ir.actions.server">
        <field name="name">Audit Dashboard</field>
        <field name="model_id" ref="model_audit_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

</odoo>
