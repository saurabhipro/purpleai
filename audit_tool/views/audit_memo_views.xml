<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_audit_memo_form" model="ir.ui.view">
        <field name="name">audit.memo.form</field>
        <field name="model">audit.memo</field>
        <field name="arch" type="xml">
            <form string="Audit Memo">
                <header>
                    <button name="action_submit_to_partner" string="Submit to Partner" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    
                    <button name="action_partner_approve" string="Approve (Partner)" type="object" class="oe_highlight" invisible="state != 'partner_review'" groups="audit_tool.group_audit_ep"/>
                    <button name="action_partner_reject" string="Reject" type="object" class="btn-danger" invisible="state != 'partner_review'" groups="audit_tool.group_audit_ep"/>
                    
                    <button name="action_assign_preparer" string="Assign Preparer" type="object" class="oe_highlight" invisible="state != 'npsg_assignment'" groups="audit_tool.group_audit_npsg"/>
                    
                    <button name="action_submit_to_review_1" string="Submit to Level 1 Review" type="object" class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_submit_to_final_review" string="Submit to Final Review" type="object" class="oe_highlight" invisible="state != 'in_progress'"/>
                    
                    <button name="action_review_1_approve" string="Approve (L1)" type="object" class="oe_highlight" invisible="state != 'level_1_review'" groups="audit_tool.group_audit_reviewer"/>
                    <button name="action_request_changes" string="Request Changes" type="object" invisible="state not in ('level_1_review', 'final_review')" groups="audit_tool.group_audit_reviewer"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state not in ('level_1_review', 'final_review')" groups="audit_tool.group_audit_reviewer"/>
                    <button name="action_hold" string="Put On Hold" type="object" invisible="state not in ('level_1_review', 'final_review')" groups="audit_tool.group_audit_reviewer"/>

                    <button name="action_final_approve" string="Final Approve" type="object" class="oe_highlight" invisible="state != 'final_review'" groups="audit_tool.group_audit_reviewer"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                        <label for="subject" class="oe_edit_only"/>
                        <h1>
                            <field name="subject" placeholder="Audit Memo Subject..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="engagement_team_user_id"/>
                            <field name="engagement_partner_id"/>
                            <field name="npsg_user_id"/>
                        </group>
                        <group>
                            <field name="preparer_id"/>
                            <field name="reviewer_1_id"/>
                            <field name="reviewer_final_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Memo Details">
                            <group string="Description">
                                <field name="description" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Analysis &amp; Views">
                            <group string="Understanding of Facts">
                                <field name="facts_of_case" nolabel="1"/>
                            </group>
                            <group string="NPSG Research">
                                <field name="npsg_research" nolabel="1"/>
                            </group>
                            <group string="NPSG Views">
                                <field name="npsg_views" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Additional Info">
                            <field name="additional_info"/>
                        </page>
                        <page string="Custom Fields" name="custom_fields">
                            <button name="action_refresh_custom_fields" string="Update Fields from Settings" type="object" icon="fa-refresh" class="btn-secondary mb-2"/>
                            <field name="custom_field_ids" mode="list">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="Question / Field"/>
                                    <field name="value" string="Answer"/>
                                </list>
                            </field>
                        </page>
                        <page string="Documents">
                            <field name="document_ids" widget="one2many" mode="list,kanban">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="file_name" column_invisible="True"/>
                                    <field name="file" filename="file_name"/>
                                    <field name="uploaded_by"/>
                                    <field name="upload_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_audit_memo_kanban" model="ir.ui.view">
        <field name="name">audit.memo.kanban</field>
        <field name="model">audit.memo</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" quick_create="false" group_create="false" records_draggable="false">
                <field name="color"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="name"/>
                <field name="subject"/>
                <field name="engagement_partner_id"/>
                <field name="preparer_id"/>
                <field name="activity_ids"/>
                <field name="activity_state"/>
                <progressbar field="activity_state" colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="{{!selection_mode ? 'oe_kanban_color_' + kanban_getcolor(record.color.raw_value) : ''}} oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                        <span class="o_kanban_record_subtitle"><field name="subject"/></span>
                                    </div>
                                    <div class="o_dropdown_kanban dropdown">
                                        <a class="dropdown-toggle o-no-caret btn" role="button" data-toggle="dropdown" data-display="static" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                            <span class="fa fa-ellipsis-v"/>
                                        </a>
                                        <div class="dropdown-menu" role="menu">
                                            <t t-if="widget.editable"><a role="menuitem" type="edit" class="dropdown-item">Edit</a></t>
                                            <t t-if="widget.deletable"><a role="menuitem" type="delete" class="dropdown-item">Delete</a></t>
                                            <ul class="oe_kanban_colorpicker" data-field="color"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="priority" widget="priority"/>
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="engagement_partner_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_audit_memo_graph" model="ir.ui.view">
        <field name="name">audit.memo.graph</field>
        <field name="model">audit.memo</field>
        <field name="arch" type="xml">
            <graph string="Audit Analysis" type="bar">
                <field name="state"/>
                <field name="engagement_partner_id"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_audit_memo_pivot" model="ir.ui.view">
        <field name="name">audit.memo.pivot</field>
        <field name="model">audit.memo</field>
        <field name="arch" type="xml">
            <pivot string="Audit Analysis">
                <field name="state" type="row"/>
                <field name="engagement_partner_id" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_audit_memo_tree" model="ir.ui.view">
        <field name="name">audit.memo.list</field>
        <field name="model">audit.memo</field>
        <field name="arch" type="xml">
            <list string="Audit Memos">
                <field name="name"/>
                <field name="subject"/>
                <field name="engagement_team_user_id"/>
                <field name="engagement_partner_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'approved'"/>
                <field name="activity_exception_decoration" widget="activity_exception"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_audit_memo_search" model="ir.ui.view">
        <field name="name">audit.memo.search</field>
        <field name="model">audit.memo</field>
        <field name="arch" type="xml">
            <search string="Audit Memos">
                <field name="name"/>
                <field name="subject"/>
                <field name="engagement_team_user_id"/>
                <filter string="My Memos" name="my_memos" domain="[('engagement_team_user_id', '=', uid)]"/>
                <filter string="My Pending Actions" name="my_pending" domain="['|', '|', '|','|', ('engagement_partner_id', '=', uid), ('preparer_id', '=', uid), ('reviewer_1_id', '=', uid), ('reviewer_final_id', '=', uid), ('engagement_team_user_id', '=', uid)]"/> 
                <!-- Note: The pending logic is simplified above, ideally it matches State + User -->
                <filter string="Action Required: Partner" name="action_partner" domain="[('state', '=', 'partner_review')]"/>
                <filter string="Action Required: Reviewer" name="action_reviewer" domain="[('state', 'in', ('level_1_review', 'final_review'))]"/>
                
                <filter string="Pending Approval" name="pending_approval" domain="[('state', 'not in', ('draft', 'approved', 'rejected'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Partner" name="group_by_partner" context="{'group_by': 'engagement_partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Main Action -->
    <record id="action_audit_memo" model="ir.actions.act_window">
        <field name="name">Audit Memos</field>
        <field name="res_model">audit.memo</field>
        <field name="view_mode">kanban,list,form,graph,pivot</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Audit Memo (v1.1)
            </p>
        </field>
    </record>

     <!-- Dashboard Action (My Actions) -->
    <record id="action_audit_dashboard" model="ir.actions.act_window">
        <field name="name">My Dashboard</field>
        <field name="res_model">audit.memo</field>
        <field name="view_mode">kanban,graph,list,form</field>
        <field name="domain">[]</field> <!-- Can filter strictly if needed, but context is better -->
        <field name="context">{'search_default_my_pending': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Welcome to your Audit Dashboard!
            </p>
        </field>
    </record>

</odoo>
