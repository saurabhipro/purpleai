<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_word_launcher_wizard_form" model="ir.ui.view">
        <field name="name">word_addin.launcher_wizard.form</field>
        <field name="model">word_addin.launcher_wizard</field>
        <field name="arch" type="xml">
            <form string="Open in Microsoft Word">
                <sheet>
                    <div class="text-center mb-4">
                        <img src="/word_addin/static/src/img/icon-64.png" alt="Word Icon" style="width: 64px; border-radius: 12px;"/>
                        <h3 class="mt-3 fw-bold">Memo AI Word Editor</h3>
                        <p class="text-muted">Synchronize your analysis steps directly with Word.</p>
                    </div>

                    <div class="alert alert-info py-4 px-4 bg-light border" role="status" style="border-radius: 15px;">
                        <ol class="mb-0">
                            <li class="mb-2">Click <strong>Download Manifest</strong> below.</li>
                            <li class="mb-2">Open Microsoft Word on your desktop.</li>
                            <li class="mb-2">Go to <strong>Developer</strong> → <strong>Add-ins</strong> (or Insert → Get Add-ins).</li>
                            <li class="mb-2">Select <strong>Upload My Add-in</strong> and pick the file you just downloaded.</li>
                        </ol>
                    </div>

                    <div class="text-center mb-4">
                        <button name="action_download_manifest" string="Download Manifest File" type="object" class="btn btn-primary btn-lg shadow-sm" icon="fa-download"/>
                    </div>

                    <group string="Add-in Manifest URL (Advanced)">
                        <div class="input-group mb-3">
                            <field name="manifest_url" readonly="1" nolabel="1" class="form-control fw-bold text-primary bg-light"/>
                        </div>
                    </group>
                    <p class="text-center small text-muted">
                        <i class="fa fa-info-circle me-1"/> For internal deployment, your IT team can deploy this for all users.
                    </p>
                </sheet>
                <footer>
                    <button string="Done" class="btn-primary" special="cancel" icon="fa-check"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
