<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_memo_session_form_inherit_word" model="ir.ui.view">
        <field name="name">memo_ai.session.form.inherit.word</field>
        <field name="model">memo_ai.session</field>
        <field name="inherit_id" ref="memoai.view_memo_session_form"/>
        <field name="arch" type="xml">
            <!-- Headers and Buttons -->
            <xpath expr="//header" position="inside">
                <button name="action_open_in_word_all" type="object" 
                        string="📝 Sync All Steps to Word" 
                        class="btn-primary" 
                        invisible="state == 'draft'"/>
                <button name="action_download_manifest_wizard" 
                        string="Setup Word Add-in" type="object" 
                        class="btn-secondary" icon="fa-cog"/>
            </xpath>

            <!-- Step 1 Word Button -->
            <xpath expr="//div[contains(@class, 'bg-primary')]//div[contains(@class, 'ms-auto')]" position="inside">
                <button name="action_open_in_word_step1" type="object" 
                        string="Sync Step 1" icon="fa-file-word-o"
                        class="btn btn-sm btn-light text-primary shadow-none fw-bold ms-2"/>
            </xpath>

            <!-- Step 2 Word Button -->
            <xpath expr="//div[contains(@class, 'bg-warning')]//div[contains(@class, 'ms-auto')]" position="inside">
                <button name="action_open_in_word_step2" type="object" 
                        string="Sync Step 2" icon="fa-file-word-o"
                        class="btn btn-sm btn-light text-warning shadow-none fw-bold ms-2"/>
            </xpath>

            <!-- Step 3 Word Button -->
            <xpath expr="//div[contains(@class, 'bg-info')]//div[contains(@class, 'ms-auto')]" position="inside">
                <button name="action_open_in_word_step3" type="object" 
                        string="Sync Step 3" icon="fa-file-word-o"
                        class="btn btn-sm btn-light text-info shadow-none fw-bold ms-2"/>
            </xpath>

            <!-- Step 4 Word Button -->
            <xpath expr="//div[contains(@class, 'bg-success')]//div[contains(@class, 'ms-auto')]" position="inside">
                <button name="action_open_in_word_step4" type="object" 
                        string="Sync Step 4" icon="fa-file-word-o"
                        class="btn btn-sm btn-light text-success shadow-none fw-bold ms-2"/>
            </xpath>
        </field>
    </record>
</odoo>
