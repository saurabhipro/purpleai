<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="purpleai.AIDashboard" owl="1">
        <div class="o_purpleai_dashboard h-100 bg-100 p-2 overflow-hidden">
            <!-- Header (Compact) -->
            <div class="d-flex justify-content-between align-items-center mb-1">
                <h5 class="fw-bold text-dark m-0">
                    <span class="text-primary">Purple AI</span> Analytics 
                    <span class="text-muted ms-2 x-small fw-normal">| <t t-esc="state.stats.active_info.company"/></span>
                </h5>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-primary shadow-sm rounded-pill px-3" t-on-click="this.loadStats">
                        <i class="fa fa-refresh me-1"/> Refresh
                    </button>
                    <button class="btn btn-sm btn-primary shadow-sm rounded-pill px-3" t-on-click="() => this.openResults()">
                        <i class="fa fa-external-link me-1"/> Results
                    </button>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center h-100">
                    <div class="spinner-grow text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                </div>
            </t>

            <t t-else="">
                <!-- Raw Vibrancy 5-Card Row (High Contrast Black Text) -->
                <div class="d-flex g-2 mb-2" style="height: 105px; gap: 8px;">
                    <!-- Spend Card -->
                    <div style="flex: 1; border-radius: 12px; position: relative; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); background: #7b1fa2 url('/purpleai/static/img/purple_pattern.jpg') center/cover no-repeat !important;">
                        <div style="position: relative; z-index: 2; padding: 12px; color: #000000 !important;">
                            <div style="font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; color: #000000 !important;">Monthly AI Spend</div>
                            <div style="font-size: 1.5rem; font-weight: 900; margin-top: 4px; color: #000000 !important;"><t t-esc="this.formatINR(state.stats.total_cost_inr)"/></div>
                        </div>
                    </div>
                    <!-- Clients Card -->
                    <div style="flex: 1; border-radius: 12px; position: relative; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); background: #c2185b url('/purpleai/static/img/pink_pattern.jpg') center/cover no-repeat !important;">
                        <div style="position: relative; z-index: 2; padding: 12px; color: #000000 !important;">
                            <div style="font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; color: #000000 !important;">Active Clients</div>
                            <div style="font-size: 1.5rem; font-weight: 900; margin-top: 4px; color: #000000 !important;"><t t-esc="state.stats.total_clients"/> <span style="font-size: 0.8rem; opacity: 0.8;">Folders</span></div>
                        </div>
                    </div>
                    <!-- Success Card -->
                    <div style="flex: 1; border-radius: 12px; position: relative; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); background: #2e7d32 url('/purpleai/static/img/green_pattern.jpg') center/cover no-repeat !important;">
                        <div style="position: relative; z-index: 2; padding: 12px; color: #000000 !important;">
                            <div style="font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; color: #000000 !important;">Success Rate</div>
                            <div style="font-size: 1.5rem; font-weight: 900; margin-top: 4px; color: #000000 !important;"><t t-esc="Math.floor((state.stats.status_breakdown.success / (state.stats.total_requests || 1)) * 100)"/>%</div>
                            <div style="font-size: 0.8rem; font-weight: 800; color: #000000 !important;"><i class="fa fa-check-circle"/> <t t-esc="state.stats.status_breakdown.success"/> Accurate</div>
                        </div>
                    </div>
                    <!-- Latency Card -->
                    <div style="flex: 1; border-radius: 12px; position: relative; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); background: #ef6c00 url('/purpleai/static/img/orange_pattern.jpg') center/cover no-repeat !important;">
                        <div style="position: relative; z-index: 2; padding: 12px; color: #000000 !important;">
                            <div style="font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; color: #000000 !important;">Response Latency</div>
                            <div style="font-size: 1.5rem; font-weight: 900; margin-top: 4px; color: #000000 !important;"><t t-esc="state.stats.avg_time"/><span style="font-size: 0.8rem; opacity: 0.8; margin-left: 4px;">ms</span></div>
                        </div>
                    </div>
                    <!-- Provider Card -->
                    <div style="flex: 1; border-radius: 12px; position: relative; overflow: hidden; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); background: #0277bd url('/purpleai/static/img/blue_pattern.jpg') center/cover no-repeat !important;">
                        <div style="position: relative; z-index: 2; padding: 12px; color: #000000 !important;">
                            <div style="font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; color: #000000 !important;">Active Engine</div>
                            <div style="font-size: 1.2rem; font-weight: 900; margin-top: 4px; color: #000000 !important; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><t t-esc="state.stats.active_info.provider"/></div>
                            <div style="font-size: 0.8rem; font-weight: 800; color: #000000 !important; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><t t-esc="state.stats.active_info.model"/></div>
                        </div>
                    </div>
                </div>

                <!-- Row 2: Matrix & Health (Primary Content) -->
                <div class="row g-2" style="height: calc(100% - 130px);">
                    <div class="col-lg-9 h-100 d-flex flex-column gap-2">
                        <!-- Performance Analysis Header -->
                        <div class="card shadow-sm border-0 flex-grow-0" style="max-height: 48%;">
                            <div class="card-header bg-primary py-2 d-flex justify-content-between align-items-center rounded-top" style="background-color: var(--primary) !important;">
                                <h6 class="m-0 fw-bold x-small text-uppercase" style="letter-spacing: 0.5px; color: #ffffff !important;">
                                    <i class="fa fa-filter me-2"/> PERFORMANCE ANALYSIS (UNIFIED)
                                </h6>
                            </div>
                            <div class="table-responsive p-0">
                                <table class="table o_matrix_table align-middle m-0 border-0">
                                    <thead><tr class="bg-primary text-white text-uppercase" style="background-color: var(--primary) !important;">
                                        <th style="color: #ffffff !important;">Provider</th>
                                        <th class="text-center" style="color: #ffffff !important;">Count</th>
                                        <th class="text-center" style="color: #ffffff !important;">Spend</th>
                                        <th style="color: #ffffff !important;">Latency</th>
                                        <th style="color: #ffffff !important;">Uptime</th>
                                    </tr></thead>
                                    <tbody>
                                        <t t-foreach="Object.keys(state.stats.providers)" t-as="p_key" t-key="p_key">
                                            <t t-set="p" t-value="state.stats.providers[p_key]"/>
                                            <tr>
                                                <td class="fw-bold x-small"><div class="dot me-1" t-att-class="p_key"/><t t-esc="p_key"/></td>
                                                <td class="text-center x-small"><t t-esc="p.count"/></td>
                                                <td class="text-center x-small text-primary fw-bold"><t t-esc="formatINR(p.cost_inr)"/></td>
                                                <td class="x-small"><t t-esc="p.avg_time"/>ms</td>
                                                <td class="x-small"><div class="progress" style="height: 4px; width: 40px;"><div class="progress-bar bg-success" role="progressbar" t-att-style="'width: ' + p.success_rate + '%;'"/></div></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <t t-if="Object.keys(state.stats.providers).length > 1">
                                        <tfoot class="bg-light border-top border-2">
                                            <tr class="fw-bold">
                                                <td class="x-small text-muted">CONSOLIDATED TOTAL</td>
                                                <td class="text-center x-small"><t t-esc="state.stats.total_requests"/></td>
                                                <td class="text-center x-small text-dark"><t t-esc="formatINR(state.stats.total_cost_inr)"/></td>
                                                <td class="x-small"><t t-esc="state.stats.avg_time"/>ms</td>
                                                <td class="x-small"><t t-esc="Math.floor((state.stats.status_breakdown.success / (state.stats.total_requests || 1)) * 100)"/>%</td>
                                            </tr>
                                        </tfoot>
                                    </t>
                                </table>
                            </div>
                        </div>

                        <!-- Latest Activity Feed Header -->
                        <div class="card shadow-sm border-0 flex-grow-1 overflow-hidden" style="max-height: 48%;">
                            <div class="card-header bg-primary py-2 d-flex justify-content-between align-items-center rounded-top" style="background-color: var(--primary) !important;">
                                <h6 class="m-0 fw-bold x-small text-uppercase" style="letter-spacing: 0.5px; color: #ffffff !important;">
                                    <i class="fa fa-history me-2"/> LATEST ACTIVITY FEED
                                </h6>
                                <t t-if="state.stats.latest and state.stats.latest.length > 0">
                                    <span class="badge rounded-pill bg-white text-primary x-small">Last Run: <t t-esc="state.stats.latest[0].time"/></span>
                                </t>
                            </div>
                            <div class="table-responsive h-100 overflow-auto">
                                <table class="table table-sm table-hover o_activity_table m-0">
                                    <thead class="sticky-top bg-light"><tr>
                                        <th style="color: #ffffff !important;">Filename</th>
                                        <th style="color: #ffffff !important;">Client</th>
                                        <th class="text-center" style="color: #ffffff !important;">Pages</th>
                                        <th style="color: #ffffff !important;">Provider</th>
                                        <th style="color: #ffffff !important;">Model</th>
                                        <th style="color: #ffffff !important;">Date &amp; Time</th>
                                        <th class="text-center" style="color: #ffffff !important;">Status</th>
                                        <th class="text-end pe-3" style="color: #ffffff !important;">Cost (INR)</th>
                                    </tr></thead>
                                    <tbody>
                                        <t t-foreach="state.stats.latest" t-as="req" t-key="req.id">
                                            <tr class="cursor-pointer" t-on-click="() => this.openResults([], req.id)">
                                                <td class="fw-bold text-primary x-small pe-3"><t t-esc="req.name"/></td>
                                                <td class="text-muted x-small"><t t-esc="req.client_name"/></td>
                                                <td class="text-center fw-bold text-muted x-small"><t t-esc="req.page_count"/></td>
                                                <td class="text-capitalize x-small"><t t-esc="req.provider"/></td>
                                                <td class="text-muted x-small" style="font-size:0.7rem; max-width:120px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><t t-esc="req.model"/></td>
                                                <td class="text-muted x-small"><t t-esc="req.time"/></td>
                                                <td class="text-center"><span t-att-class="'badge rounded-pill px-2 ' + (req.status == 'done' ? 'text-bg-success' : (req.status == 'processing' ? 'text-bg-warning' : 'text-bg-danger'))" style="font-size: 0.65rem;"><t t-esc="req.status"/></span></td>
                                                <td class="text-end text-dark fw-bold x-small pe-3"><t t-esc="this.formatINR(req.cost_inr)"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- System Health Card (Professional Mix) -->
                    <div class="col-lg-3 h-100">
                        <div class="card shadow-sm border-0 h-100 bg-white">
                            <div class="card-header bg-primary py-2 d-flex justify-content-between align-items-center rounded-top" style="background-color: var(--primary) !important;">
                                <h6 class="m-0 fw-bold x-small text-uppercase" style="letter-spacing: 0.5px; color: #ffffff !important;">
                                    <i class="fa fa-shield me-2"/> SYSTEM INTEGRITY
                                </h6>
                            </div>
                            <div class="card-body text-center d-flex flex-column p-3">
                                <!-- Prominent Health Circle -->
                                <div class="my-auto">
                                    <div class="position-relative mx-auto mb-3" style="width: 120px; height: 120px;">
                                        <svg viewBox="0 0 36 36" class="circular-chart">
                                            <path class="circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                                            <path class="circle success" t-att-stroke-dasharray="((state.stats.status_breakdown.success / (state.stats.total_requests || 1)) * 100) + ', 100'" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                                        </svg>
                                        <div class="position-absolute top-50 start-50 translate-middle">
                                            <div class="h4 fw-black m-0 text-dark"><t t-esc="Math.floor((state.stats.status_breakdown.success / (state.stats.total_requests || 1)) * 100)"/>%</div>
                                            <div class="x-small text-muted fw-bold">HEALTH</div>
                                        </div>
                                    </div>
                                    
                                    <div class="badge rounded-pill bg-success-subtle text-success px-3 py-1 mb-2">
                                        <i class="fa fa-check-circle me-1"/> All Systems Operational
                                    </div>
                                    <div class="text-muted small px-2">
                                        No critical outages detected in the last <span class="fw-bold text-dark">24 hours</span>.
                                    </div>
                                </div>

                                <!-- Bottom Status Stats -->
                                <div class="mt-auto pt-3 border-top">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="x-small text-muted">Reliability Index</span>
                                        <span class="x-small fw-bold text-primary">High</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span class="x-small text-muted">Recent Errors</span>
                                        <span class="x-small fw-bold text-danger"><t t-esc="state.stats.status_breakdown.error"/></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
