<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_extraction_master_tree" model="ir.ui.view">
        <field name="name">purple_ai.extraction_master.tree</field>
        <field name="model">purple_ai.extraction_master</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_extraction_master_form" model="ir.ui.view">
        <field name="name">purple_ai.extraction_master.form</field>
        <field name="model">purple_ai.extraction_master</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Invoice Extraction"/></h1>
                    </div>
                    <group>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Fields to Extract">
                            <field name="field_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="field_key"/>
                                    <field name="instruction"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Validation Rules">
                            <field name="rule_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="rule_code"/>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="eval_type"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_extraction_master" model="ir.actions.act_window">
        <field name="name">Extraction Templates</field>
        <field name="res_model">purple_ai.extraction_master</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
