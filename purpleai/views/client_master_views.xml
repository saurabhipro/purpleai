<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purple_ai_client_tree" model="ir.ui.view">
        <field name="name">purple_ai.client.tree</field>
        <field name="model">purple_ai.client</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="folder_path"/>
                <field name="extraction_master_id"/>
                <field name="last_scan"/>
                <field name="processed_count" string="Files Processed"/>
            </list>
        </field>
    </record>

    <record id="view_purple_ai_client_form" model="ir.ui.view">
        <field name="name">purple_ai.client.form</field>
        <field name="model">purple_ai.client</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_scan_folder" string="Scan Now" type="object" class="btn-primary" icon="fa-refresh" invisible="scan_status == 'scanning'"/>
                    <button name="action_force_rescan_folder" string="Force Re-Scan All" type="object" class="btn-secondary" icon="fa-repeat" invisible="scan_status == 'scanning'"
                            confirm="This will re-process ALL files in the folder, including already-scanned ones. Continue?"/>
                    <button string="Scanning..." class="btn-secondary" disabled="1" icon="fa-spinner fa-spin" invisible="scan_status != 'scanning'"/>
                    <button name="action_view_results" string="View Results" type="object" icon="fa-list"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Client Name"/></h1>
                    </div>
                    <group>
                        <group string="Basic Information">
                            <field name="name" placeholder="e.g. GT"/>
                            <field name="extraction_master_id" placeholder="e.g. Invoice Template"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="System Configuration">
                            <field name="folder_path" readonly="1" force_save="1"/>
                            <field name="company_id" readonly="1" groups="base.group_multi_company"/>
                            <field name="last_scan"/>
                        </group>
                    </group>
                    
                    <!-- <group string="Scan Progress" invisible="scan_status == 'idle' and scan_progress == 0">
                        <label for="scan_progress" string="Processing Status"/>
                        <div class="o_row">
                            <field name="scan_progress" widget="progressbar" class="oe_inline"/>
                            <span invisible="scan_status == 'idle'">
                                <i class="fa fa-spinner fa-spin"/> <field name="scan_current_file" class="oe_inline"/>
                            </span>
                            <span invisible="scan_status == 'scanning'">
                                <field name="scan_current_file" class="oe_inline"/>
                            </span>
                        </div>
                        <field name="scan_status" invisible="1"/>
                    </group> -->

                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle"/> PDFs placed in the <b>Watch Folder</b> will be automatically processed using the selected template.
                    </div>

                    <!-- ── Tabs ───────────────────────────────────────────────── -->
                    <notebook>
                        <!-- Tab 1: Files in the watch folder -->
                        <page string="📁 Folder Files" name="folder_files">
                            <div class="p-2">
                                <field name="folder_files_html" widget="html" readonly="1" nolabel="1"/>
                            </div>
                        </page>

                        <!-- Tab 2: Processed extraction results -->
                        <page string="📄 Extraction Results" name="extraction_results">
                            <field name="extraction_result_ids" nolabel="1" readonly="1">
                                <list create="0" delete="0">
                                    <field name="create_date" string="Processed On"/>
                                    <field name="filename" string="File Name"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'done'"
                                           decoration-danger="state == 'error'"/>
                                    <field name="provider" string="AI Provider"/>
                                    <field name="model_used" string="Model"/>
                                    <field name="total_tokens" string="Tokens"/>
                                    <field name="duration_ms" string="Time (ms)"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>

        </field>
    </record>

    <record id="action_purple_ai_client" model="ir.actions.act_window">
        <field name="name">Clients &amp; Folders</field>
        <field name="res_model">purple_ai.client</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
