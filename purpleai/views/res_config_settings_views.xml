<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purpleai_config_settings_form" model="ir.ui.view">
        <field name="name">res.config.settings.purpleai.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="99"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Purple AI" string="Purple AI" name="purpleai">
                    <!-- ══ AI Provider Selection ══════════════════════════════════════ -->
                    <block title="AI Provider" name="ai_provider_config">
                        <setting help="Choose the AI service provider for all AI operations">
                            <div class="content-group">
                                <field name="ai_provider" widget="radio" class="o_field_radio_vertical"/>
                                <div class="text-muted mt-2">
                                    <i class="fa fa-info-circle"/> Select a provider, then configure its credentials below.
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- ══ Google Gemini Configuration ══════════════════════════════ -->
                    <block title="Google Gemini Configuration" name="gemini_config"
                           invisible="ai_provider != 'gemini'">
                        <setting title="API Key" help="Set your Google Gemini API key">
                            <div class="content-group">
                                <label for="tender_ai_api_key"/>
                                <field name="tender_ai_api_key" password="True"/>
                                <div class="text-muted">
                                    Get your API key at <a href="https://aistudio.google.com/app/apikey" target="_blank">Google AI Studio</a>
                                </div>
                            </div>
                        </setting>
                        <setting title="Model Selection" help="Choose which Gemini model to use">
                            <div class="content-group">
                                <label for="tender_ai_default_model"/>
                                <field name="tender_ai_default_model"/>
                                <div class="mt-2">
                                    <button name="action_fetch_available_models" string="Fetch Available Models" type="object" class="btn-secondary btn-sm" icon="fa-refresh"/>
                                    <button name="action_test_model" string="Test Connection" type="object" class="btn-link btn-sm" icon="fa-check-circle"/>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- ══ Mistral AI Configuration ══════════════════════════════════ -->
                    <block title="Mistral AI Configuration" name="mistral_config"
                           invisible="ai_provider != 'mistral'">
                        <setting title="Mistral API Key" help="Your Mistral AI secret key">
                            <field name="mistral_api_key" password="True" placeholder="Enter your Mistral API key"/>
                            <div class="text-muted">
                                Get your API key at <a href="https://console.mistral.ai/" target="_blank">Mistral AI Console</a>
                            </div>
                        </setting>
                        <setting title="Default AI Model" help="Choose the Mistral model to use">
                            <field name="mistral_default_model"/>
                            <div class="mt-2">
                                <button name="action_test_mistral_connection" string="Test Connection" type="object" class="btn-link btn-sm" icon="fa-check-circle"/>
                            </div>
                        </setting>
                        <setting title="Mistral OCR URL" help="The URL for the Mistral OCR API">
                            <field name="mistral_ocr_url" placeholder="https://api.mistral.ai/v1/ocr"/>
                        </setting>
                    </block>

                    <!-- ══ Microsoft Azure Cloud Foundry Configuration ═══════════════ -->
                    <block title="Microsoft Azure Cloud Foundry Configuration" name="azure_config"
                           invisible="ai_provider != 'azure'">
                        <setting title="Azure Endpoint URL" help="Your Azure resource endpoint URL">
                            <field name="azure_endpoint" placeholder="https://&lt;resource&gt;.openai.azure.com/"/>
                            <div class="text-muted">
                                Find this in <a href="https://portal.azure.com/" target="_blank">Azure Portal</a> → Your AI resource → Keys and Endpoint
                            </div>
                        </setting>
                        <setting title="Azure API Key" help="Your Azure Cloud Foundry secret key">
                            <field name="azure_api_key" password="True" placeholder="Enter your Azure API key"/>
                        </setting>
                        <setting title="Default AI Model" help="The name of your Azure model deployment (e.g. gpt-4o)">
                            <field name="azure_deployment_name" placeholder="e.g. gpt-4o, phi-3-mini"/>
                            <div class="text-muted">
                                This is the <b>Deployment Name</b> you configured in Azure AI Studio.
                            </div>
                        </setting>
                        <setting title="API Version" help="Azure OpenAI REST API version">
                            <field name="azure_api_version"/>
                            <div class="mt-2">
                                <button name="action_test_azure_connection" string="Test Connection" type="object" class="btn-link btn-sm" icon="fa-check-circle"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Folder &amp; File Explorer" name="folder_config">
                        <setting title="Root Access" help="Specify the starting path for the file explorer">
                            <div class="content-group">
                                <label for="purple_ai_root_path"/>
                                <field name="purple_ai_root_path"/>
                                <div class="text-muted">
                                    This folder will be the 'Home' for the DMS explorer.
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Pricing &amp; Tokens" name="pricing_config">
                        <setting title="Input Cost" help="Cost per 1M input tokens (INR)">
                            <field name="tender_ai_input_cost"/>
                        </setting>
                        <setting title="Output Cost" help="Cost per 1M output tokens (INR)">
                            <field name="tender_ai_output_cost"/>
                        </setting>
                    </block>
                    <block title="Tally ERP / Prime Integration" name="tally_config">
                        <setting title="Tally Connectivity" help="Configure connection to Tally ERP/Prime">
                            <div class="content-group">
                                <group>
                                    <field name="tally_url" placeholder="e.g. 192.168.1.10 or localhost"/>
                                    <field name="tally_port" placeholder="9000"/>
                                    <field name="tally_company" placeholder="Exact Company Name in Tally"/>
                                </group>
                                <div class="mt-2">
                                    <button name="action_test_tally_connection" string="Test Tally Connection" type="object" class="btn-primary btn-sm" icon="fa-exchange"/>
                                    <button name="action_sync_tally_ledgers" string="Sync Tally Ledgers" type="object" class="btn-secondary btn-sm ms-2" icon="fa-refresh" help="Pull all ledger names from Tally into Odoo Chart of Accounts."/>
                                </div>
                                <div class="text-info mt-2">
                                    <i class="fa fa-info-circle"/> Ensure <b>HTTP Server</b> is enabled in Tally (F1 -> Settings -> Connectivity).
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_purpleai_config_settings" model="ir.actions.act_window">
        <field name="name">Purple AI Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'purpleai'}</field>
    </record>
</odoo>
