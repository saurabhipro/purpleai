<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_property_ai_query_tree" model="ir.ui.view">
        <field name="name">purple_ai.property_query.tree</field>
        <field name="model">purple_ai.property_query</field>
        <field name="arch" type="xml">
            <list string="AI Property Queries">
                <field name="create_date" string="Date"/>
                <field name="question"/>
                <field name="result_count" string="Count"/>
            </list>
        </field>
    </record>

    <record id="view_property_ai_query_form" model="ir.ui.view">
        <field name="name">purple_ai.property_query.form</field>
        <field name="model">purple_ai.property_query</field>
        <field name="arch" type="xml">
            <form string="AI Semantic Query">
                <header>
                    <button name="action_run_query" string="Analyze Data" type="object" class="btn-primary" icon="fa-magic"/>
                    <button name="action_check_models" string="Check Available Models" type="object" class="btn-secondary" icon="fa-search"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Expert AI Property Analysis</h1>
                    </div>
                    <group>
                        <field name="question" placeholder="e.g. List top 10 wards with most solar installations or Give me count of total properties..."/>
                    </group>
                    
                    <notebook>
                        <page string="Result Data" name="results">
                            <div class="alert alert-secondary d-flex justify-content-between" invisible="not execution_time">
                                <span>Query executed in <field name="execution_time" readonly="1"/> seconds.</span>
                                <b><field name="result_count" readonly="1"/> records found.</b>
                            </div>
                            <field name="results_html" readonly="1"/>
                        </page>
                        <page string="Technical Details (SQL)" name="technical">
                            <group>
                                <field name="generated_sql" widget="text" font="monospace"/>
                            </group>
                            <label for="raw_results"/>
                            <field name="raw_results" readonly="1" font="monospace"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_property_ai_query" model="ir.actions.act_window">
        <field name="name">Property AI Analytics</field>
        <field name="res_model">purple_ai.property_query</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Ask a question like "How many properties in Delhi?" 
                and let AI query your 100,000+ records instantly.
            </p>
        </field>
    </record>
</odoo>
