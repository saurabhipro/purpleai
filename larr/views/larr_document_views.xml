<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Document List View -->
    <record id="view_larr_document_tree" model="ir.ui.view">
        <field name="name">larr.document.tree</field>
        <field name="model">larr.document</field>
        <field name="arch" type="xml">
            <list string="Documents">
                <field name="name"/>
                <field name="document_type"/>
                <field name="project_id"/>
                <field name="document_number"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="state" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'approved'" decoration-danger="state == 'expired'"/>
            </list>
        </field>
    </record>

    <!-- Document Form View -->
    <record id="view_larr_document_form" model="ir.ui.view">
        <field name="name">larr.document.form</field>
        <field name="model">larr.document</field>
        <field name="arch" type="xml">
            <form string="Document">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_verify" string="Verify" type="object" class="oe_highlight" invisible="state != 'submitted'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'verified'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft','submitted','verified')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,verified,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Document Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="document_type"/>
                            <field name="project_id"/>
                            <field name="acquisition_id"/>
                            <field name="rehabilitation_id"/>
                            <field name="compensation_id"/>
                            <field name="stakeholder_id"/>
                        </group>
                        <group>
                            <field name="document_number"/>
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <field name="verified_by"/>
                            <field name="verified_date"/>
                            <field name="approved_by"/>
                            <field name="approved_date"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Enter document description..."/>
                    <notebook>
                        <page string="Verification Notes">
                            <field name="verification_notes"/>
                        </page>
                        <page string="Approval Notes">
                            <field name="approval_notes"/>
                        </page>
                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Document Search View -->
    <record id="view_larr_document_search" model="ir.ui.view">
        <field name="name">larr.document.search</field>
        <field name="model">larr.document</field>
        <field name="arch" type="xml">
            <search string="Search Documents">
                <field name="name"/>
                <field name="document_type"/>
                <field name="project_id"/>
                <field name="document_number"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state','=','submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Expired" name="expired" domain="[('state','=','expired')]"/>
                <group expand="0" string="Group By">
                    <filter string="Document Type" name="document_type" context="{'group_by':'document_type'}"/>
                    <filter string="Project" name="project" context="{'group_by':'project_id'}"/>
                    <filter string="State" name="state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Document Action -->
    <record id="action_larr_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">larr.document</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first document
            </p>
            <p>
                Manage project documents with version control and approval workflows.
            </p>
        </field>
    </record>

</odoo>