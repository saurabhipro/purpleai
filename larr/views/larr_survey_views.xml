<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Survey List View -->
    <record id="view_larr_survey_list" model="ir.ui.view">
        <field name="name">larr.survey.list</field>
        <field name="model">larr.survey</field>
        <field name="arch" type="xml">
            <list string="Surveys">
                <field name="name"/>
                <field name="surveyor_id"/>
                <field name="village_id"/>
                <field name="khasra_no"/>
                <field name="khatauni_no"/>
                <field name="land_area"/>
                <field name="land_type"/>
                <field name="land_class"/>
                <field name="owner_name"/>
            </list>
        </field>
    </record>

    <!-- Survey Form View -->
    <record id="view_larr_survey_form" model="ir.ui.view">
        <field name="name">larr.survey.form</field>
        <field name="model">larr.survey</field>
        <field name="arch" type="xml">
            <form string="Survey Details">
                <header>
                    <field name="survey_status" widget="statusbar" statusbar_visible="draft,in_progress,completed"/>
                </header>
                <sheet>
                    <!-- Survey Section -->
                    <group string="Survey Details" name="survey_section">
                        <group>
                            <field name="survey_no"/>
                            <field name="survey_date" widget="date"/>
                            <field name="project_id"/>
                            <field name="package_id"/>
                            <field name="sub_package_id"/>
                        </group>
                        <group>
                            <field name="village_id"/>
                            <field name="district_id"/>
                            <field name="survey_type"/>
                            <field name="survey_status"/>
                            <field name="survey_officer"/>
                            <field name="surveyor_id"/>
                        </group>
                    </group>

                    <!-- Khasra Section -->
                    <group string="Khasra Details" name="khasra_section">
                        <group>
                            <field name="khasra_no"/>
                            <field name="khatauni_no"/>
                            <field name="land_area"/>
                            <field name="land_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="land_class" widget="radio" options="{'horizontal': true}"/>
                        </group>
                    </group>

                    <!-- Owner Section -->
                    <group string="Owners" name="owner_section">
                        <field name="owner_ids"/>
                    </group>

                    <!-- Land Details Section -->
                    <group string="Land Details" name="land_section">
                        <group string="Land Extent">
                            <group>
                                <field name="total_extent_k"/>
                                <field name="total_extent_m"/>
                            </group>
                            <group>
                                <field name="khasra_k"/>
                                <field name="khasra_m"/>
                            </group>
                            <group>
                                <field name="remaining_k"/>
                                <field name="remaining_m"/>
                            </group>
                        </group>
                        <group string="Assessment">
                            <group>
                                <field name="assessment_rs"/>
                                <field name="assessment_paisa"/>
                            </group>
                        </group>
                    </group>

                    <!-- Land Information Section -->
                    <group string="Land Information" name="land_info_section">
                        <group>
                            <field name="current_land_use"/>
                            <field name="land_grade"/>
                            <field name="irrigation_source"/>
                            <field name="crop_type"/>
                            <field name="average_crop_yield"/>
                        </group>
                        <group>
                            <field name="market_value"/>
                            <field name="year_of_acquisition"/>
                            <field name="land_value"/>
                            <field name="ownership_documents"/>
                        </group>
                    </group>

                    <!-- Asset Management Section -->
                    <group string="Asset Management" name="asset_section">
                        <field name="asset_ids"/>
                    </group>

                    <field name="remarks"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Survey Search View -->
    <record id="view_larr_survey_search" model="ir.ui.view">
        <field name="name">larr.survey.search</field>
        <field name="model">larr.survey</field>
        <field name="arch" type="xml">
            <search string="Search Surveys">
                <field name="name"/>
                <field name="survey_no"/>
                <field name="surveyor_id"/>
                <field name="village_id"/>
                <field name="khasra_no"/>
                <field name="owner_name"/>
                <field name="survey_status"/>
                <field name="current_stage"/>
                <filter string="Draft" name="draft" domain="[('survey_status', '=', 'draft')]"/>
                <filter string="In Progress" name="in_progress" domain="[('survey_status', '=', 'in_progress')]"/>
                <filter string="Completed" name="completed" domain="[('survey_status', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Survey Status" name="group_by_status" context="{'group_by': 'survey_status'}"/>
                    <filter string="Current Stage" name="group_by_stage" context="{'group_by': 'current_stage'}"/>
                    <filter string="Village" name="group_by_village" context="{'group_by': 'village_id'}"/>
                    <filter string="Surveyor" name="group_by_surveyor" context="{'group_by': 'surveyor_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Survey Action -->
    <record id="action_larr_survey" model="ir.actions.act_window">
        <field name="name">Surveys</field>
        <field name="res_model">larr.survey</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_larr_survey_list"/>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first survey
            </p>
            <p>
                Manage SIA surveys and land data collection.
            </p>
        </field>
    </record>

    <!-- Package List View -->
    <record id="view_larr_package_list" model="ir.ui.view">
        <field name="name">larr.package.list</field>
        <field name="model">larr.package</field>
        <field name="arch" type="xml">
            <list string="Packages">
                <field name="name"/>
                <field name="code"/>
                <field name="project_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Package Form View -->
    <record id="view_larr_package_form" model="ir.ui.view">
        <field name="name">larr.package.form</field>
        <field name="model">larr.package</field>
        <field name="arch" type="xml">
            <form string="Package">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="project_id"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Package Action -->
    <record id="action_larr_package" model="ir.actions.act_window">
        <field name="name">Packages</field>
        <field name="res_model">larr.package</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first package
            </p>
        </field>
    </record>

    <!-- Sub Package List View -->
    <record id="view_larr_sub_package_list" model="ir.ui.view">
        <field name="name">larr.sub.package.list</field>
        <field name="model">larr.sub.package</field>
        <field name="arch" type="xml">
            <list string="Sub Packages">
                <field name="name"/>
                <field name="code"/>
                <field name="package_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Sub Package Form View -->
    <record id="view_larr_sub_package_form" model="ir.ui.view">
        <field name="name">larr.sub.package.form</field>
        <field name="model">larr.sub.package</field>
        <field name="arch" type="xml">
            <form string="Sub Package">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="package_id"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sub Package Action -->
    <record id="action_larr_sub_package" model="ir.actions.act_window">
        <field name="name">Sub Packages</field>
        <field name="res_model">larr.sub.package</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sub package
            </p>
        </field>
    </record>

</odoo>
