<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>        
        <!-- Compensation List View -->
        <record id="view_larr_compensation_tree" model="ir.ui.view">
            <field name="name">larr.compensation.tree</field>
            <field name="model">larr.compensation</field>
            <field name="arch" type="xml">
                <list string="Compensations">
                    <field name="name"/>
                    <field name="acquisition_id"/>
                    <field name="beneficiary_id"/>
                    <field name="compensation_type"/>
                    <field name="amount"/>
                    <field name="payment_date"/>
                    <field name="state" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'paid'"/>
                </list>
            </field>
        </record>

        <!-- Compensation Form View -->
        <record id="view_larr_compensation_form" model="ir.ui.view">
            <field name="name">larr.compensation.form</field>
            <field name="model">larr.compensation</field>
            <field name="arch" type="xml">
                <form string="Compensation">
                    <header>
                        <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'"/>
                        <button name="action_pay" string="Mark as Paid" type="object" class="oe_highlight" invisible="state != 'approved'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft','submitted','approved')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Compensation Reference"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="acquisition_id"/>
                                <field name="beneficiary_id"/>
                                <field name="compensation_type"/>
                                <field name="currency_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="amount"/>
                                <field name="payment_date"/>
                                <field name="payment_method"/>
                                <field name="payment_reference"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Documents">
                                <field name="document_ids" widget="many2many_binary"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Compensation Search View -->
        <record id="view_larr_compensation_search" model="ir.ui.view">
            <field name="name">larr.compensation.search</field>
            <field name="model">larr.compensation</field>
            <field name="arch" type="xml">
                <search string="Search Compensations">
                    <field name="name"/>
                    <field name="acquisition_id"/>
                    <field name="beneficiary_id"/>
                    <field name="compensation_type"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Submitted" name="submitted" domain="[('state','=','submitted')]"/>
                    <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                    <filter string="Paid" name="paid" domain="[('state','=','paid')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Acquisition" name="acquisition" context="{'group_by':'acquisition_id'}"/>
                        <filter string="Compensation Type" name="compensation_type" context="{'group_by':'compensation_type'}"/>
                        <filter string="State" name="state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Compensation Action -->
        <record id="action_larr_compensation" model="ir.actions.act_window">
            <field name="name">Compensations</field>
            <field name="res_model">larr.compensation</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_draft': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first compensation
                </p>
                <p>
                    Manage compensation payments and track disbursements.
                </p>
            </field>
        </record>

    </data>
</odoo> 