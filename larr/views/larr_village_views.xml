<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Village List View -->
    <record id="view_larr_village_list" model="ir.ui.view">
        <field name="name">larr.village.list</field>
        <field name="model">larr.village</field>
        <field name="arch" type="xml">
            <list string="Villages">
                <field name="name"/>
                <field name="tehsil"/>
                <field name="district_id"/>
                <field name="sarpanch_name"/>
                <field name="contact"/>
                <field name="state" decoration-success="state == 'active'" decoration-danger="state == 'inactive'"/>
            </list>
        </field>
    </record>

    <!-- Village Form View -->
    <record id="view_larr_village_form" model="ir.ui.view">
        <field name="name">larr.village.form</field>
        <field name="model">larr.village</field>
        <field name="arch" type="xml">
            <form string="Village">
                <header>
                    <button name="action_activate" string="Activate" type="object" class="oe_highlight" invisible="state == 'active'"/>
                    <button name="action_deactivate" string="Deactivate" type="object" invisible="state == 'inactive'"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,inactive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Village Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="tehsil"/>
                            <field name="district_id"/>
                            <field name="sarpanch_name"/>
                            <field name="contact"/>
                        </group>
                        <group>
                            <field name="population"/>
                            <field name="area_hectares"/>
                            <field name="gram_panchayat_code"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Documents">
                            <field name="document_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Village Search View -->
    <record id="view_larr_village_search" model="ir.ui.view">
        <field name="name">larr.village.search</field>
        <field name="model">larr.village</field>
        <field name="arch" type="xml">
            <search string="Search Villages">
                <field name="name"/>
                <field name="tehsil"/>
                <field name="district_id"/>
                <field name="sarpanch_name"/>
                <field name="contact"/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Inactive" name="inactive" domain="[('state','=','inactive')]"/>
                <group expand="0" string="Group By">
                    <filter string="Tehsil" name="tehsil" context="{'group_by':'tehsil'}"/>
                    <filter string="District" name="district" context="{'group_by':'district_id'}"/>
                    <filter string="State" name="state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Village Action -->
    <record id="action_larr_village" model="ir.actions.act_window">
        <field name="name">Villages</field>
        <field name="res_model">larr.village</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first village
            </p>
            <p>
                Manage village master data and track village information.
            </p>
        </field>
    </record>

</odoo> 