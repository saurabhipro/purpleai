<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Rehabilitation List View -->
        <record id="view_larr_rehabilitation_list" model="ir.ui.view">
            <field name="name">larr.rehabilitation.list</field>
            <field name="model">larr.rehabilitation</field>
            <field name="arch" type="xml">
                <list string="Rehabilitations">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="affected_person_id"/>
                    <field name="rehabilitation_type"/>
                    <field name="family_members"/>
                    <field name="state" decoration-info="state == 'draft'" decoration-warning="state == 'survey'" decoration-success="state == 'completed'"/>
                </list>
            </field>
        </record>

        <!-- Rehabilitation Form View -->
        <record id="view_larr_rehabilitation_form" model="ir.ui.view">
            <field name="name">larr.rehabilitation.form</field>
            <field name="model">larr.rehabilitation</field>
            <field name="arch" type="xml">
                <form string="Rehabilitation">
                    <header>
                        <button name="action_survey" string="Start Survey" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_planning" string="Start Planning" type="object" class="oe_highlight" invisible="state != 'survey'"/>
                        <button name="action_implementation" string="Start Implementation" type="object" class="oe_highlight" invisible="state != 'planning'"/>
                        <button name="action_complete" string="Complete" type="object" class="oe_highlight" invisible="state != 'implementation'"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft','survey','planning')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,survey,planning,implementation,completed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Rehabilitation Reference"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="project_id"/>
                                <field name="acquisition_id"/>
                                <field name="affected_person_id"/>
                                <field name="rehabilitation_type"/>
                            </group>
                            <group>
                                <field name="family_members"/>
                                <field name="survey_date"/>
                                <field name="planning_date"/>
                                <field name="implementation_date"/>
                                <field name="completion_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Current Residence">
                                <group>
                                    <field name="current_address"/>
                                    <field name="current_land_area"/>
                                    <field name="current_house_type"/>
                                </group>
                            </page>
                            <page string="New Residence">
                                <group>
                                    <field name="new_address"/>
                                    <field name="new_land_area"/>
                                    <field name="new_house_type"/>
                                </group>
                            </page>
                            <page string="Documents">
                                <field name="document_ids" widget="many2many_binary"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Rehabilitation Search View -->
        <record id="view_larr_rehabilitation_search" model="ir.ui.view">
            <field name="name">larr.rehabilitation.search</field>
            <field name="model">larr.rehabilitation</field>
            <field name="arch" type="xml">
                <search string="Search Rehabilitations">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="affected_person_id"/>
                    <field name="rehabilitation_type"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Survey" name="survey" domain="[('state','=','survey')]"/>
                    <filter string="Planning" name="planning" domain="[('state','=','planning')]"/>
                    <filter string="Completed" name="completed" domain="[('state','=','completed')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Project" name="project" context="{'group_by':'project_id'}"/>
                        <filter string="Rehabilitation Type" name="rehabilitation_type" context="{'group_by':'rehabilitation_type'}"/>
                        <filter string="State" name="state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Rehabilitation Action -->
        <record id="action_larr_rehabilitation" model="ir.actions.act_window">
            <field name="name">Rehabilitations</field>
            <field name="res_model">larr.rehabilitation</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_draft': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first rehabilitation plan
                </p>
                <p>
                    Manage rehabilitation and resettlement plans for affected persons.
                </p>
            </field>
        </record>

    </data>
</odoo>