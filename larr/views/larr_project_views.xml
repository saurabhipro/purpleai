<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Project List View -->
    <record id="view_larr_project_tree" model="ir.ui.view">
        <field name="name">larr.project.tree</field>
        <field name="model">larr.project</field>
        <field name="arch" type="xml">
            <list string="Projects">
                <field name="name"/>
                <field name="code"/>
                <field name="project_type"/>
                <field name="project_manager_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Project Form View -->
    <record id="view_larr_project_form" model="ir.ui.view">
        <field name="name">larr.project.form</field>
        <field name="model">larr.project</field>
        <field name="arch" type="xml">
            <form string="Project">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="project_type"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="project_manager_id"/>
                            <field name="total_area_required"/>
                            <field name="estimated_cost"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <field name="description"/>
                    <field name="team_member_ids" widget="many2many_tags"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Project Search View -->
    <record id="view_larr_project_search" model="ir.ui.view">
        <field name="name">larr.project.search</field>
        <field name="model">larr.project</field>
        <field name="arch" type="xml">
            <search string="Search Projects">
                <field name="name"/>
                <field name="code"/>
                <field name="project_type"/>
                <field name="project_manager_id"/>
            </search>
        </field>
    </record>

    <!-- Project Action -->
    <record id="action_larr_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">larr.project</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first project
            </p>
            <p>
                Manage LARR projects and track overall progress.
            </p>
        </field>
    </record>

</odoo> 