<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard Form View -->
    <record id="view_larr_dashboard_form" model="ir.ui.view">
        <field name="name">larr.dashboard.form</field>
        <field name="model">larr.dashboard</field>
        <field name="arch" type="xml">
            <form string="LARR Dashboard">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <!-- Dashboard Content -->
                    <notebook>
                        <page string="Projects Overview">
                            <group>
                                <group>
                                    <field name="project_count" widget="statinfo" string="Total Projects"/>
                                    <field name="active_project_count" widget="statinfo" string="Active Projects"/>
                                </group>
                                <group>
                                    <field name="completed_project_count" widget="statinfo" string="Completed Projects"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Land Acquisition">
                            <group>
                                <group>
                                    <field name="acquisition_count" widget="statinfo" string="Total Acquisitions"/>
                                    <field name="pending_acquisition_count" widget="statinfo" string="Pending Acquisitions"/>
                                </group>
                                <group>
                                    <field name="completed_acquisition_count" widget="statinfo" string="Completed Acquisitions"/>
                                    <field name="total_area_acquired" widget="statinfo" string="Total Area Acquired (Acres)"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Compensation">
                            <group>
                                <group>
                                    <field name="compensation_count" widget="statinfo" string="Total Compensations"/>
                                    <field name="pending_compensation_count" widget="statinfo" string="Pending Compensations"/>
                                </group>
                                <group>
                                    <field name="paid_compensation_count" widget="statinfo" string="Paid Compensations"/>
                                    <field name="total_compensation_amount" widget="monetary" string="Total Amount"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Rehabilitation">
                            <group>
                                <group>
                                    <field name="rehabilitation_count" widget="statinfo" string="Total Rehabilitations"/>
                                    <field name="pending_rehabilitation_count" widget="statinfo" string="Pending Rehabilitations"/>
                                </group>
                                <group>
                                    <field name="completed_rehabilitation_count" widget="statinfo" string="Completed Rehabilitations"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Stakeholders">
                            <group>
                                <group>
                                    <field name="stakeholder_count" widget="statinfo" string="Total Stakeholders"/>
                                    <field name="active_stakeholder_count" widget="statinfo" string="Active Stakeholders"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Dashboard Action -->
    <record id="action_larr_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">larr.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Welcome to LARR Dashboard
            </p>
            <p>
                View comprehensive statistics and insights about your land acquisition and rehabilitation projects.
            </p>
        </field>
    </record>

</odoo> 