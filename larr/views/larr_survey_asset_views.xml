<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Survey Asset List View -->
    <record id="view_larr_survey_asset_list" model="ir.ui.view">
        <field name="name">larr.survey.asset.list</field>
        <field name="model">larr.survey.asset</field>
        <field name="arch" type="xml">
            <list string="Survey Assets">
                <field name="asset_type"/>
                <field name="category_type"/>
                <field name="quantity"/>
                <field name="unit"/>
                <field name="cost_per_unit"/>
                <field name="condition"/>
            </list>
        </field>
    </record>

    <!-- Survey Asset Form View -->
    <record id="view_larr_survey_asset_form" model="ir.ui.view">
        <field name="name">larr.survey.asset.form</field>
        <field name="model">larr.survey.asset</field>
        <field name="arch" type="xml">
            <form string="Survey Asset">
                <sheet>
                    <group>
                        <group>
                            <field name="asset_type"/>
                            <field name="category_type"/>
                            <field name="quantity"/>
                            <field name="unit"/>
                        </group>
                        <group>
                            <field name="cost_per_unit"/>
                            <field name="condition"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

</odoo> 