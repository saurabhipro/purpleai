<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- District List View -->
    <record id="view_larr_district_list" model="ir.ui.view">
        <field name="name">larr.district.list</field>
        <field name="model">larr.district</field>
        <field name="arch" type="xml">
            <list string="Districts">
                <field name="name"/>
                <field name="code"/>
                <field name="state_id"/>
                <field name="village_count"/>
                <field name="survey_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- District Form View -->
    <record id="view_larr_district_form" model="ir.ui.view">
        <field name="name">larr.district.form</field>
        <field name="model">larr.district</field>
        <field name="arch" type="xml">
            <form string="District">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="state_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="description"/>
                    
                    <!-- Statistics -->
                    <group string="Statistics">
                        <group>
                            <field name="village_count" widget="statinfo" string="Villages"/>
                        </group>
                        <group>
                            <field name="survey_count" widget="statinfo" string="Surveys"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- District Search View -->
    <record id="view_larr_district_search" model="ir.ui.view">
        <field name="name">larr.district.search</field>
        <field name="model">larr.district</field>
        <field name="arch" type="xml">
            <search string="Search Districts">
                <field name="name"/>
                <field name="code"/>
                <field name="state_id"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="group_by_state" context="{'group_by': 'state_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- District Action -->
    <record id="action_larr_district" model="ir.actions.act_window">
        <field name="name">Districts</field>
        <field name="res_model">larr.district</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first district
            </p>
        </field>
    </record>

</odoo> 