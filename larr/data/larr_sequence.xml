        </record>
        
        <!-- LARR Survey Sequence -->
        <record id="seq_larr_survey" model="ir.sequence">
            <field name="name">LARR Survey</field>
            <field name="code">larr.survey</field>
            <field name="prefix">LARR/SURV/%(y)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
        </record>
        
    </data>
</odoo> 