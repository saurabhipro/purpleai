<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- LARR Project Sequence -->
        <record id="seq_larr_project" model="ir.sequence">
            <field name="name">LARR Project</field>
            <field name="code">larr.project</field>
            <field name="prefix">LARR/PROJ/%(y)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
        </record>
        
        <!-- LARR Land Acquisition Sequence -->
        <record id="seq_larr_land_acquisition" model="ir.sequence">
            <field name="name">LARR Land Acquisition</field>
            <field name="code">larr.land.acquisition</field>
            <field name="prefix">LARR/ACQ/%(y)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
        </record>
        
        <!-- LARR Rehabilitation Sequence -->
        <record id="seq_larr_rehabilitation" model="ir.sequence">
