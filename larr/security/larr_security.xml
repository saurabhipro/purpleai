<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <!-- LARR User Group -->
        <record id="group_larr_user" model="res.groups">
            <field name="name">LARR User</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
        <!-- LARR Manager Group -->
        <record id="group_larr_manager" model="res.groups">
            <field name="name">LARR Manager</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('group_larr_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
        
        <!-- LARR Administrator Group -->
        <record id="group_larr_administrator" model="res.groups">
            <field name="name">LARR Administrator</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('group_larr_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
        
        <!-- Multi-company rules -->
        <!-- Note: Multi-company rules removed as company_id field is not implemented in the models -->
        
    </data>
</odoo> 