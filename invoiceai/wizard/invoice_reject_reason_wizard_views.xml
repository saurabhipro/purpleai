<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_reject_reason_wizard_form" model="ir.ui.view">
        <field name="name">purple_ai.invoice_reject_reason_wizard.form</field>
        <field name="model">purple_ai.invoice_reject_reason_wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Invoice">
                <group>
                    <field name="invoice_processor_id" readonly="1"/>
                    <field name="rejection_reason" placeholder="Please enter reason for rejection..." required="1"/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object" string="Reject" class="btn-danger"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
