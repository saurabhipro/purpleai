<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_invoice_processor_tree" model="ir.ui.view">
        <field name="name">purple_ai.invoice_processor.tree</field>
        <field name="model">purple_ai.invoice_processor</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'failed'" decoration-info="state == 'posted'">
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="process_id"/>
                <field name="invoice_date"/>
                <field name="invoice_number" decoration-bf="1"/>
                <field name="vendor_name"/>
                <field name="status_with_icon" string="Status"/>
                <field name="untaxed_amount"/>
                <field name="gst_amount" string="GST"/>
                <field name="tds_amount" string="TDS (10%)"/>
                <field name="net_payable"/>
            </list>
        </field>
    </record>

    <record id="view_invoice_processor_form" model="ir.ui.view">
        <field name="name">purple_ai.invoice_processor.form</field>
        <field name="model">purple_ai.invoice_processor</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="overall_status" widget="statusbar" statusbar_visible="draft_extracted,pending_vrf_field_mapping,gl_decision_in_progress,waiting_fa_schedule_update,waiting_prepaid_review,pending_manager_approval,ready_for_tally,manager_rejected,validation_failed,posted,cancelled"/>
                </header>
                <sheet>
                    <div class="row g-0 o_audit_container">
                        <!-- Left column: Data Tabs (40% Width) -->
                        <div class="col-lg-5 border-end bg-light p-2 o_audit_left_panel" style="height: calc(100vh - 160px); overflow-y: auto;">
                            <notebook>
                                <page string="🧠 AI Extracted Data" name="ai_extracted_data">
                                    <field name="extracted_data" widget="ai_evidence_viewer" nolabel="1"/>
                                </page>
                                <page string="✅ Validation Results" name="validation_results">
                                    <div class="o_horizontal_separator text-primary fw-bold mb-3" style="font-size: 1.1rem; border-bottom: 2px solid #007bff;">
                                        Rule-Based Compliance Report
                                    </div>
                                    <field name="validation_log" nolabel="1"/>
                                    <div class="alert alert-warning mt-3" role="alert" invisible="state != 'failed'">
                                        <i class="fa fa-warning me-2"/> Some rules have failed. Please review the <b>RED</b> sections on the PDF document to understand the issues.
                                    </div>
                                </page>
                            </notebook>
                        </div>

                        <!-- Draggable Resizer Handle -->
                        <div class="o_audit_resizer d-none d-lg-block"/>

                        <!-- Right column: PDF Preview (60% Width) -->
                        <div class="col-lg-7 bg-dark-subtle p-0 o_audit_right_panel">
                            <div class="d-flex justify-content-between align-items-center bg-white border-bottom px-3 py-1">
                                <h6 class="m-0 text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05rem;">
                                    <i class="fa fa-eye me-2"/> AUDITOR VIEWPORT
                                </h6>
                                <div class="badge rounded-pill text-bg-light border text-muted" style="font-size: 0.7rem;">
                                    <field name="filename" readonly="1"/>
                                </div>
                            </div>
                            <div style="height: calc(100vh - 160px); overflow: hidden; position: relative;" class="shadow-sm border o_audit_viewport_container bg-white">
                                <field name="pdf_file" widget="pdf_viewer" nolabel="1" readonly="1" class="h-100 w-100 p-0 m-0"/>
                            </div>
                        </div>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_invoice_processor" model="ir.actions.act_window">
        <field name="name">All Invoices</field>
        <field name="res_model">purple_ai.invoice_processor</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Review and validate extracted invoices in the queue.
          </p>
          <p>
            This list is your full invoice workflow from extraction to manager approval and Tally posting.
            New rows are created automatically when an extraction finishes successfully; you can also open any extraction and use
            <b>Open Invoice Workflow</b>.
          </p>
        </field>
    </record>

    <record id="action_invoice_processor_hold" model="ir.actions.act_window">
        <field name="name">Hold Invoices</field>
        <field name="res_model">purple_ai.invoice_processor</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('workflow_status', 'in', ['hold_vrf_vendor_missing', 'hold_last_provision', 'hold_foreign_invoice', 'hold_advance_proforma'])]</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Invoices currently on hold in workflow branches.
          </p>
        </field>
    </record>

    <record id="action_invoice_processor_validated" model="ir.actions.act_window">
        <field name="name">Validated Invoices</field>
        <field name="res_model">purple_ai.invoice_processor</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('workflow_status', 'in', ['validation_passed', 'pending_manager_approval', 'manager_approved', 'ready_for_tally'])]</field>
    </record>

    <record id="action_invoice_processor_passed_tally" model="ir.actions.act_window">
        <field name="name">Passed to Tally</field>
        <field name="res_model">purple_ai.invoice_processor</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'posted')]</field>
    </record>

    <record id="action_invoice_processor_rejected" model="ir.actions.act_window">
        <field name="name">Rejected Invoices</field>
        <field name="res_model">purple_ai.invoice_processor</field>
        <field name="view_mode">list,form</field>
        <field name="domain">['|', ('workflow_status', '=', 'manager_rejected'), ('approval_state', '=', 'rejected')]</field>
    </record>
    
    <!-- Bulk Export Action for List View -->
    <record id="action_bulk_export_tally_excel" model="ir.actions.server">
        <field name="name">Export Tally Excel (Bulk)</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                action = records.action_export_tally_excel()
        </field>
    </record>

    <record id="action_bulk_reprocess_pending_invoices" model="ir.actions.server">
        <field name="name">Reprocess Pending (Bulk)</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_bulk_reprocess_pending()
        </field>
    </record>

    <record id="action_create_demo_invoices" model="ir.actions.server">
        <field name="name">Create Demo Invoices</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = env['purple_ai.invoice_processor'].action_create_demo_invoices()
        </field>
    </record>

    <!-- Form Action menu entries (below Delete) -->
    <record id="action_form_push_to_tally" model="ir.actions.server">
        <field name="name">Push to Tally</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_push_to_tally()
        </field>
    </record>

    <record id="action_form_rerun_validations" model="ir.actions.server">
        <field name="name">Re-Run Validations</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_validate()
        </field>
    </record>

    <record id="action_form_send_manager_approval" model="ir.actions.server">
        <field name="name">Send for Manager Approval</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_send_for_manager_approval()
        </field>
    </record>

    <record id="action_form_manager_approve" model="ir.actions.server">
        <field name="name">Manager Approve</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_manager_approve()
        </field>
    </record>

    <record id="action_form_manager_reject" model="ir.actions.server">
        <field name="name">Manager Reject</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    records.action_manager_reject()
        </field>
    </record>

    <record id="action_form_export_validation_report" model="ir.actions.server">
        <field name="name">Export Validation Report</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_export_validation_excel()
        </field>
    </record>

    <record id="action_form_export_tally_excel" model="ir.actions.server">
        <field name="name">Export Tally Excel</field>
        <field name="model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_model_id" ref="model_purple_ai_invoice_processor"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records.action_export_tally_excel()
        </field>
    </record>

</odoo>
