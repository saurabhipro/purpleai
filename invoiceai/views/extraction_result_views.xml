<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_extraction_result_tree" model="ir.ui.view">
        <field name="name">purple_ai.extraction_result.tree</field>
        <field name="model">purple_ai.extraction_result</field>
        <field name="arch" type="xml">
            <list create="0" edit="0 shadow-none">
                <header>
                    <button name="%(invoiceai.action_upload_invoice_wizard)d" string="Manual AI Upload" type="action" class="btn-primary"/>
                    <button name="action_retry_extraction" string="Retry Selection" type="object" class="btn-secondary"/>
                    <button name="action_sync_invoice_queue_row" string="Start Invoice Workflow" type="object" class="btn-secondary"
                            title="Creates or updates rows in Extraction → All Invoices for selected successful extractions."/>
                </header>
                <field name="create_date" string="Processed Date"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="client_id"/>
                <field name="filename"/>
                <field name="page_count" string="Pages"/>
                <field name="pdf_dpi" string="DPI"/>
                <field name="pdf_quality" string="Quality" widget="badge" 
                       decoration-success="pdf_quality == 'high'" 
                       decoration-info="pdf_quality == 'good'" 
                       decoration-warning="pdf_quality == 'medium'" 
                       decoration-danger="pdf_quality == 'low'"/>
                <field name="fields_extracted_percent" string="% Extracted" 
                       widget="progressbar" 
                       decoration-success="fields_extracted_percent >= 80"
                       decoration-warning="fields_extracted_percent >= 50 and fields_extracted_percent &lt; 80"
                       decoration-danger="fields_extracted_percent &lt; 50"/>
                <field name="extracted_fields_count" string="Fields" optional="hide"/>
                <field name="total_fields_count" optional="hide"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-danger="state == 'error'" decoration-warning="state == 'processing'"/>
                <field name="provider" string="AI Provider"/>
                <field name="model_used" string="Model"/>
                <field name="ocr_method" string="OCR Method" optional="show"/>
                <field name="total_tokens" string="Tokens Used" optional="show"/>
                <field name="processing_time_seconds" string="Processing Time (s)" widget="float_time" optional="show"/>
                <field name="cost_inr" string="Cost (₹)" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_extraction_result_form" model="ir.ui.view">
        <field name="name">purple_ai.extraction_result.form</field>
        <field name="model">purple_ai.extraction_result</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <header>
                    <button name="action_retry_extraction" string="Retry Extraction" type="object" class="btn-primary" invisible="state != 'error'"/>
                    <button name="action_retry_extraction" string="Re-Scan (Overwrite)" type="object" class="btn-secondary" invisible="state == 'error'"/>
                    <field name="state" widget="statusbar"/>
                    <field name="review_workflow_status" widget="badge" string="Workflow"/>
                    <field name="review_approval_state" widget="badge" string="Approval"/>
                </header>
                <sheet>
                    <div class="row g-0 o_audit_container">
                        <!-- Left Panel: Extracted Data (40%) -->
                        <div class="col-lg-5 border-end bg-light p-3 o_audit_left_panel" style="min-height: 1000px;">
                            <h5 class="text-primary mb-3">
                                <i class="fa fa-list-alt me-2"/>AI Evidence List
                            </h5>
                            <field name="extracted_data" widget="ai_evidence_viewer" nolabel="1" readonly="1"/>
                            
                            <div class="mt-4">
                                <group string="Processing Details" class="mb-3">
                                    <group>
                                        <field name="provider" string="AI Provider"/>
                                        <field name="model_used" string="AI Model"/>
                                        <field name="ocr_method" widget="badge" 
                                               decoration-info="ocr_method == 'tesseract'" 
                                               decoration-success="ocr_method == 'paddle'" 
                                               decoration-warning="ocr_method == 'mistral'"/>
                                        <field name="fields_extracted_percent" widget="percentpie"/>
                                    </group>
                                    <group>
                                        <field name="page_count"/>
                                        <field name="pdf_dpi" string="Source PDF DPI"/>
                                        <field name="pdf_quality" widget="badge" 
                                               decoration-success="pdf_quality == 'high'" 
                                               decoration-info="pdf_quality == 'good'" 
                                               decoration-warning="pdf_quality == 'medium'" 
                                               decoration-danger="pdf_quality == 'low'"/>
                                        <field name="quality_enhancements" invisible="not quality_enhancements"/>
                                        <field name="extracted_fields_count" string="Extracted"/>
                                        <field name="total_fields_count" string="Total Fields"/>
                                        <field name="processing_time_seconds" string="Total Time (s)" widget="float"/>
                                        <field name="duration_ms" string="AI Call Time (ms)" optional="hide"/>
                                        <field name="total_tokens" invisible="not total_tokens"/>
                                        <field name="cost_inr" string="Estimated Cost (₹)" invisible="not cost_inr"/>
                                    </group>
                                </group>
                                <notebook invisible="state != 'error'">
                                    <page string="Errors" name="errors">
                                        <field name="error_log" readonly="1" class="text-danger font-monospace"/>
                                    </page>
                                </notebook>
                            </div>
                        </div>

                        <!-- Draggable Resizer Handle -->
                        <div class="o_audit_resizer d-none d-lg-block"/>

                        <!-- Right Panel: PDF Preview (60%) -->
                        <div class="col-lg-7 bg-dark-subtle p-0 o_audit_right_panel">
                            <div class="d-flex justify-content-between align-items-center bg-white border-bottom px-3 py-1">
                                <h6 class="m-0 text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05rem;">
                                    <i class="fa fa-eye me-2"/> DOCUMENT PREVIEW
                                </h6>
                            </div>
                            <div style="height: calc(100vh - 120px); min-height: 800px; overflow: hidden; position: relative;" class="shadow-sm border o_audit_viewport_container bg-secondary">
                                <field name="is_pdf" invisible="1"/>
                                <field name="is_image" invisible="1"/>
                                <!-- PDF Viewer -->
                                <field name="pdf_file" widget="pdf_viewer" nolabel="1" filename="pdf_filename" class="h-100 w-100 p-0 m-0" invisible="not is_pdf"/>
                                <!-- Image Viewer -->
                                <field name="pdf_file" widget="image" nolabel="1" class="h-100 w-100 p-0 m-0" style="object-fit: contain; background: #333;" invisible="not is_image"/>
                                <!-- Fallback -->
                                <div invisible="is_pdf or is_image" class="d-flex align-items-center justify-content-center h-100 text-white p-5 text-center">
                                    <div>
                                        <i class="fa fa-file-o fa-5x mb-3 opacity-50" title="Document"/>
                                        <h5>Preview unavailable for this format</h5>
                                        <p class="opacity-75">Filename: <field name="filename"/></p>
                                    </div>
                                </div>
                            </div>
                            <field name="pdf_filename" invisible="1"/>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_extraction_result" model="ir.actions.act_window">
        <field name="name">Extraction Results</field>
        <field name="res_model">purple_ai.extraction_result</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
