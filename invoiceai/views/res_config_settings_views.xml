<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_purpleai_config_settings" model="ir.actions.act_window">
        <field name="name">Invoice AI Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'invoiceai'}</field>
    </record>

    <record id="view_purpleai_config_settings_form" model="ir.ui.view">
        <field name="name">res.config.settings.purpleai.invoices.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="99"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Invoice AI" string="Invoice AI" name="invoiceai">
                    <!-- Folder & File Explorer Settings -->
                    <block title="Folder &amp; File Explorer" name="folder_config">
                        <setting title="Root Access" help="Specify the starting path for the file explorer">
                            <div class="content-sgroup">
                                <label for="purple_ai_root_path"/>
                                <field name="purple_ai_root_path"/>
                                <div class="text-muted">This folder will be the 'Home' for the DMS explorer.</div>
                            </div>
                        </setting>
                    </block>

                    <!-- Parallel Processing Configuration -->
                    <block title="Batch Processing &amp; Performance" name="parallel_processing_config">
                        <setting title="Parallel Workers" help="Configure parallel document processing for batch imports">
                            <div class="content-group">
                                <group>
                                    <field name="ai_core_max_parallel_workers"/>
                                </group>
                                <div class="text-muted mt-2">
                                    <p><strong>Performance Guide:</strong></p>
                                    <ul class="mb-0">
                                        <li><strong>1 Worker:</strong> ~2 files/min (Sequential - debugging only)</li>
                                        <li><strong>2 Workers:</strong> ~4 files/min (✅ Recommended - safe)</li>
                                        <li><strong>3 Workers:</strong> ~6 files/min (Aggressive - good internet)</li>
                                        <li><strong>4 Workers:</strong> ~8 files/min (⚠️ Maximum - monitor rate limits)</li>
                                    </ul>
                                    <p class="mt-2 mb-0"><strong>API:</strong> Use <code>process_documents_parallel(env, client, file_list, max_workers)</code> to batch process multiple invoices in parallel.</p>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- API Pricing Configuration -->
                    <block title="AI API Pricing Configuration" name="pricing_config">
                        <setting title="Set API Costs (per 1 Million tokens - USD)" help="These rates are used to calculate invoice processing costs. Update when API provider pricing changes.">
                            <div class="content-group">
                                <!-- Gemini Flash Section -->
                                <div class="border-top pt-3 mb-3">
                                    <div style="font-size: 1.1rem; font-weight: bold; color: #1f77b4; margin-bottom: 12px;">
                                        💎 Gemini Flash 2.0 (Recommended - Cheapest)
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div style="margin-bottom: 8px; font-weight: 600; font-size: 0.95rem;">Input Cost ($ per 1M tokens)</div>
                                            <field name="gemini_input_cost_per_m_tokens" widget="monetary" style="width: 100%;"/>
                                            <small class="text-muted">Default: 0.075</small>
                                        </div>
                                        <div class="col-md-6">
                                            <div style="margin-bottom: 8px; font-weight: 600; font-size: 0.95rem;">Output Cost ($ per 1M tokens)</div>
                                            <field name="gemini_output_cost_per_m_tokens" widget="monetary" style="width: 100%;"/>
                                            <small class="text-muted">Default: 0.30</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- OpenAI Section -->
                                <div class="border-top pt-3 mb-3">
                                    <div style="font-size: 1.1rem; font-weight: bold; color: #ff7f0e; margin-bottom: 12px;">
                                        🤖 OpenAI GPT-4o (Direct - Most Expensive)
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div style="margin-bottom: 8px; font-weight: 600; font-size: 0.95rem;">Input Cost ($ per 1M tokens)</div>
                                            <field name="openai_input_cost_per_m_tokens" widget="monetary" style="width: 100%;"/>
                                            <small class="text-muted">Default: 2.50</small>
                                        </div>
                                        <div class="col-md-6">
                                            <div style="margin-bottom: 8px; font-weight: 600; font-size: 0.95rem;">Output Cost ($ per 1M tokens)</div>
                                            <field name="openai_output_cost_per_m_tokens" widget="monetary" style="width: 100%;"/>
                                            <small class="text-muted">Default: 10.00</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Azure Section -->
                                <div class="border-top pt-3 mb-3">
                                    <div style="font-size: 1.1rem; font-weight: bold; color: #0078d4; margin-bottom: 12px;">
                                        ☁️ Azure OpenAI (40-60% Cheaper)
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div style="margin-bottom: 8px; font-weight: 600; font-size: 0.95rem;">Input Cost ($ per 1M tokens)</div>
                                            <field name="azure_input_cost_per_m_tokens" widget="monetary" style="width: 100%;"/>
                                            <small class="text-muted">Default: 0.50 (region-dependent)</small>
                                        </div>
                                        <div class="col-md-6">
                                            <div style="margin-bottom: 8px; font-weight: 600; font-size: 0.95rem;">Output Cost ($ per 1M tokens)</div>
                                            <field name="azure_output_cost_per_m_tokens" widget="monetary" style="width: 100%;"/>
                                            <small class="text-muted">Default: 1.50 (region-dependent)</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Exchange Rate Section -->
                                <div class="border-top pt-3 mb-3">
                                    <div style="font-size: 1.1rem; font-weight: bold; color: #2ca02c; margin-bottom: 12px;">
                                        💱 Currency Exchange Rate
                                    </div>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div style="margin-bottom: 8px; font-weight: 600; font-size: 0.95rem;">USD to INR Conversion Rate</div>
                                            <field name="usd_to_inr_rate" widget="float" style="width: 100%;"/>
                                            <small class="text-muted">Current: 85.0 (Update as per market rate)</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Cost Calculation Example -->
                                <div class="alert alert-info mt-4" role="alert">
                                    <h6 class="mb-3" style="font-size: 1rem; font-weight: bold;">📊 Cost Comparison (3,000 input + 1,000 output tokens):</h6>
                                    <div style="background-color: #f0f7ff; padding: 12px; border-radius: 4px; margin-bottom: 10px;">
                                        <strong>💎 Gemini Flash (CHEAPEST):</strong>
                                        <ul class="mb-2" style="font-size: 0.95rem; line-height: 1.5;">
                                            <li>Input: (3,000 × $0.075 / 1M) = $0.000225</li>
                                            <li>Output: (1,000 × $0.30 / 1M) = $0.0003</li>
                                            <li><strong>→ Total: ₹0.045</strong> ✅</li>
                                        </ul>
                                    </div>
                                    <div style="background-color: #e3f2fd; padding: 12px; border-radius: 4px; margin-bottom: 10px;">
                                        <strong>☁️ Azure OpenAI (40-60% cheaper than OpenAI Direct):</strong>
                                        <ul class="mb-2" style="font-size: 0.95rem; line-height: 1.5;">
                                            <li>Input: (3,000 × $0.50 / 1M) = $0.0015</li>
                                            <li>Output: (1,000 × $1.50 / 1M) = $0.0015</li>
                                            <li><strong>→ Total: ₹0.25</strong> 💰</li>
                                        </ul>
                                    </div>
                                    <div style="background-color: #fff5f0; padding: 12px; border-radius: 4px;">
                                        <strong>🤖 OpenAI Direct (Most Expensive):</strong>
                                        <ul class="mb-0" style="font-size: 0.95rem; line-height: 1.5;">
                                            <li>Input: (3,000 × $2.50 / 1M) = $0.0075</li>
                                            <li>Output: (1,000 × $10.00 / 1M) = $0.01</li>
                                            <li><strong>→ Total: ₹1.28</strong> ❌</li>
                                        </ul>
                                    </div>
                                    <p class="mb-0 mt-3 small"><i class="fa fa-check-circle text-success"/> All costs are displayed in <strong>INR (₹)</strong> in the invoice extraction view. <strong>Gemini is 28x cheaper than OpenAI!</strong></p>
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- AI Provider Connection Testing -->
                    <block title="AI Provider Configuration" name="ai_provider_config">
                        <setting title="Test AI Connection" help="Verify the configured AI provider is working correctly">
                            <div class="content-group">
                                <div class="text-muted mb-3">
                                    Test connectivity and functionality of your configured AI provider:
                                </div>
                                <ul class="text-muted mb-3" style="font-size: 0.95rem;">
                                    <li><strong>🚀 Mistral:</strong> Pixtral vision model (recommended)</li>
                                    <li><strong>☁️ Azure:</strong> Azure OpenAI endpoint</li>
                                    <li><strong>🤖 OpenAI:</strong> Direct OpenAI API</li>
                                    <li><strong>💎 Gemini:</strong> Google Gemini API</li>
                                </ul>
                            </div>
                            <div class="mt-2">
                                <button name="action_test_ai_connection" string="Test AI Connection" type="object" class="btn-primary btn-sm" icon="fa-plug"/>
                            </div>
                        </setting>
                    </block>

                    <!-- OCR Engine Configuration & Testing -->
                    <block title="OCR Engine Configuration" name="ocr_config">
                        <setting title="OCR Engine Testing" help="Test connectivity and functionality of OCR engines">
                            <div class="content-group">
                                <div class="text-muted mb-3">
                                    Test the OCR engines configured for document processing. This will verify:
                                </div>
                                <ul class="text-muted mb-3" style="font-size: 0.95rem;">
                                    <li><strong>🔧 Tesseract:</strong> Local OCR engine (installed on server)</li>
                                    <li><strong>🐉 Paddle OCR:</strong> Alternative local OCR (if installed)</li>
                                    <li><strong>🚀 Mistral:</strong> Cloud-based vision API connectivity</li>
                                </ul>
                            </div>
                            <div class="mt-2">
                                <button name="action_test_ocr" string="Test OCR Engines" type="object" class="btn-primary btn-sm" icon="fa-flask"/>
                            </div>
                            <div class="alert alert-info mt-3" role="alert">
                                <i class="fa fa-info-circle"/> <strong>Installation Requirements:</strong>
                                <ul class="mb-0" style="margin-top: 8px; font-size: 0.95rem;">
                                    <li>Tesseract: <code>apt-get install tesseract-ocr</code></li>
                                    <li>Paddle OCR (optional): <code>pip install paddleocr</code></li>
                                    <li>Mistral: API key in AI Core settings</li>
                                </ul>
                            </div>
                        </setting>
                    </block>

                    <!-- Tally ERP / Prime Integration -->
                    <block title="Tally ERP / Prime Integration" name="tally_config">
                        <setting title="Tally Connectivity" help="Configure connection to Tally ERP/Prime">
                            <div class="content-group">
                                <group>
                                    <field name="tally_url" placeholder="e.g. 192.168.1.10 or localhost"/>
                                    <field name="tally_port" placeholder="9000"/>
                                    <field name="tally_company" placeholder="Exact Company Name in Tally"/>
                                </group>
                                <div class="mt-2">
                                    <button name="action_test_tally_connection" string="Test Tally Connection" type="object" class="btn-primary btn-sm" icon="fa-exchange"/>
                                    <button name="action_sync_tally_ledgers" string="Sync Tally Ledgers" type="object" class="btn-secondary btn-sm ms-2" icon="fa-refresh" help="Fetches ledger names from Tally. Creates Odoo chart-of-accounts lines only when the Accounting app is installed."/>
                                </div>
                                <div class="text-info mt-2">
                                    <i class="fa fa-info-circle"/> Ensure <b>HTTP Server</b> is enabled in Tally (F1 → Settings → Connectivity).
                                </div>
                            </div>
                        </setting>
                    </block>

                </app>

                <!-- General Settings App for Mistral Configuration -->
                <app data-string="General Settings" string="General Settings" name="general_settings">
                    <!-- Mistral API Configuration -->
                    <block title="Mistral AI Configuration" name="mistral_config">
                        <setting title="Mistral API Settings" help="Configure Mistral API endpoint and SSL verification">
                            <div class="content-group">
                                <div class="border-bottom pb-3 mb-3">
                                    <label for="mistral_endpoint_url" style="display: block; margin-bottom: 6px; font-weight: 600;">🌐 Mistral Custom Endpoint URL (Optional)</label>
                                    <field name="mistral_endpoint_url" placeholder="e.g. https://aif-cosec-dev.services.ai.azure.com/providers/mistral/azure/ocr" style="width: 100%;"/>
                                    <small class="text-muted" style="display: block; margin-top: 4px;">
                                        <strong>Leave empty</strong> to use default: <code>https://api.mistral.ai/v1/chat/completions</code><br/>
                                        <strong>Azure OCR Endpoint (Document Extraction):</strong><br/>
                                        • Base path: <code>https://aif-cosec-dev.services.ai.azure.com/providers/mistral/azure/ocr</code><br/>
                                        • Full path: <code>https://aif-cosec-dev.services.ai.azure.com/providers/mistral/azure/ocr/v1/chat/completions</code><br/>
                                        <strong>Standard Chat Endpoint:</strong><br/>
                                        • Path: <code>https://api.mistral.ai/v1/chat/completions</code><br/>
                                        <strong>ℹ️ Azure OCR:</strong> Designed for document extraction and OCR tasks with JSON schema support. The system will auto-complete the endpoint path if needed.
                                    </small>
                                </div>

                                <div>
                                    <label for="mistral_verify_ssl" style="display: block; margin-bottom: 6px; font-weight: 600;">🔐 SSL Certificate Verification</label>
                                    <field name="mistral_verify_ssl" style="width: 100%;"/>
                                    <small class="text-muted" style="display: block; margin-top: 4px;">
                                        <strong>✅ Verify SSL (Default):</strong> Secure option - validates SSL certificates<br/>
                                        <strong>⚠️ Skip SSL:</strong> For self-signed certificates or custom gateways<br/><br/>
                                        <strong>If you get certificate errors:</strong><br/>
                                        1. First try: <code>apt-get install ca-certificates</code><br/>
                                        2. If using Azure: Select "Skip SSL" and verify your endpoint URL
                                    </small>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
