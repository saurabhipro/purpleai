<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Action to open the wizard -->
    <record id="action_pdf_converter_wizard" model="ir.actions.act_window">
        <field name="name">Image → PDF Converter</field>
        <field name="res_model">purple_ai.pdf_converter</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Wizard Form View -->
    <record id="view_pdf_converter_form" model="ir.ui.view">
        <field name="name">purple_ai.pdf_converter.form</field>
        <field name="model">purple_ai.pdf_converter</field>
        <field name="arch" type="xml">
            <form string="Image → Searchable PDF Converter">
                <sheet>

                    <!-- Header Banner -->
                    <div style="
                        background: linear-gradient(135deg, #6b21a8 0%, #a21caf 60%, #db2777 100%);
                        border-radius: 12px;
                        padding: 20px 24px;
                        margin-bottom: 20px;
                        display: flex;
                        align-items: center;
                        gap: 16px;
                    ">
                        <div style="font-size: 2.5rem; line-height: 1;">📄</div>
                        <div>
                            <div style="color: #fff; font-size: 1.25rem; font-weight: 800; letter-spacing: -0.5px;">
                                Image → Searchable PDF Converter
                            </div>
                            <div style="color: rgba(255,255,255,0.75); font-size: 0.82rem; margin-top: 2px;">
                                Upload JPEG / PNG / TIFF images · OCR in your language · Download a merged searchable PDF
                            </div>
                        </div>
                    </div>

                    <!-- STEP 1: Upload (visible in draft state) -->
                    <div invisible="state != 'draft'">
                        <div style="display: flex; gap: 16px; margin-bottom: 16px; align-items: flex-end;">
                            <div style="flex: 1;">
                                <div class="o_form_label" style="font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: #6b21a8; margin-bottom: 6px;">
                                    🌐 OCR Language
                                </div>
                                <field name="lang" nolabel="1"
                                    style="font-size: 0.95rem; border-radius: 8px;"/>
                            </div>
                            <div style="flex: 1;">
                                <field name="rotate_pages" widget="boolean_toggle"/>
                                <span style="font-size: 0.85rem; color: #555; margin-left: 8px;">Auto-rotate pages</span>
                            </div>
                        </div>

                        <div style="
                            border: 2px dashed #c084fc;
                            border-radius: 12px;
                            padding: 20px;
                            background: #faf5ff;
                            margin-bottom: 8px;
                        ">
                            <div style="text-align: center; color: #7c3aed; font-size: 0.88rem; font-weight: 600; margin-bottom: 12px;">
                                ⬆ Drag &amp; drop images here or click the button below
                            </div>
                            <field name="attachment_ids"
                                widget="many2many_binary"
                                string="Images (JPEG / PNG / TIFF / BMP)"
                                nolabel="1"/>
                        </div>

                        <div style="font-size: 0.77rem; color: #888; margin-top: 6px;">
                            <i class="fa fa-info-circle"/> Images will be processed <b>in the order listed above</b>.
                            Each image = one page in the final PDF.
                        </div>
                    </div>

                    <!-- STEP 2: Result (visible when done) -->
                    <div invisible="state != 'done'"
                        style="
                            background: #f0fdf4;
                            border: 1.5px solid #86efac;
                            border-radius: 12px;
                            padding: 20px 24px;
                            margin-bottom: 16px;
                        ">
                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 14px;">
                            <span style="font-size: 2rem;">✅</span>
                            <div>
                                <div style="font-weight: 700; color: #166534; font-size: 1rem;">Conversion Complete!</div>
                                <div style="color: #15803d; font-size: 0.82rem;">
                                    <field name="page_count" nolabel="1" readonly="1"/> pages processed and merged into one searchable PDF.
                                </div>
                            </div>
                        </div>

                        <!-- Download Button -->
                        <div style="display: flex; justify-content: center; margin-top: 8px;">
                            <field name="output_pdf"
                                widget="binary"
                                filename="output_filename"
                                string="⬇ Download Searchable PDF"
                                nolabel="1"
                                style="font-size: 1rem;"/>
                            <field name="output_filename" invisible="1"/>
                        </div>
                    </div>

                    <!-- Error log (if any partial errors) -->
                    <div invisible="not error_log"
                        style="
                            background: #fff7ed;
                            border: 1px solid #fdba74;
                            border-radius: 8px;
                            padding: 12px 16px;
                            margin-top: 8px;
                            font-size: 0.8rem;
                        ">
                        <div style="font-weight: 700; color: #c2410c; margin-bottom: 4px;">⚠ Some images had errors:</div>
                        <field name="error_log" nolabel="1" readonly="1"
                            style="color: #7c2d12; font-family: monospace; font-size: 0.78rem; white-space: pre;"/>
                    </div>

                </sheet>
                <footer>
                    <button name="action_convert"
                        string="🔄 Convert &amp; Merge to PDF"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"
                        data-hotkey="v"/>
                    <button name="action_reset"
                        string="🔁 Convert Another"
                        type="object"
                        class="btn-secondary"
                        invisible="state != 'done'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
