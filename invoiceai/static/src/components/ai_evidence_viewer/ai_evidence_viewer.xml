<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="invoiceai.AIEvidenceViewer">
        <div class="ai-evidence-container d-flex flex-column h-100">
            <div t-if="!state.data" class="alert alert-warning py-2 small">
                <i class="fa fa-exclamation-triangle me-1"/> No AI evidence data available for this document.
            </div>
            <t t-else="">
                <!-- Tabs for Marks -->
                <ul t-if="this.hasMarksTab" class="nav nav-tabs nav-tabs-custom bg-white px-3 pt-2" style="border-bottom: 1px solid #dee2e6;">
                    <li class="nav-item">
                        <a href="#" t-attf-class="nav-link fw-bold px-4 py-2 #{state.activeTab === 'main' ? 'active text-primary' : 'text-muted border-0'}" 
                           t-on-click.prevent="() => this.setActiveTab('main')">
                           <i class="fa fa-list-alt me-1"/> Document Info
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" t-attf-class="nav-link fw-bold px-4 py-2 #{state.activeTab === 'marks' ? 'active text-primary' : 'text-muted border-0'}" 
                           t-on-click.prevent="() => this.setActiveTab('marks')">
                           <i class="fa fa-table me-1"/> Marks Breakdown
                        </a>
                    </li>
                </ul>

                <div class="evidence-list shadow-sm flex-grow-1 overflow-auto">
                    <table class="table table-sm table-hover mb-0" t-if="state.activeTab === 'main'">
                        <thead class="bg-light sticky-top">
                            <tr>
                                <th class="ps-3 py-2 text-uppercase text-muted text-center" style="font-size: 0.65rem; width: 40px;">#</th>
                                <th class="ps-3 py-2 text-uppercase text-muted" style="font-size: 0.7rem; letter-spacing: 0.05rem; width: 30%;">Field Name</th>
                                <th class="ps-3 py-2 text-uppercase text-muted" style="font-size: 0.7rem; letter-spacing: 0.05rem;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>Extracted Evidence &amp; Corrections</span>
                                    </div>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="count" t-value="1"/>
                            <t t-foreach="this.getGroupedTabEntries()" t-as="section" t-key="section.id">
                                <tr class="table-primary">
                                    <td colspan="3" class="px-3 py-2 fw-bold text-uppercase" style="font-size: 0.72rem; letter-spacing: 0.06rem;">
                                        <i class="fa fa-folder-open-o me-1"/> <t t-esc="section.title"/>
                                    </td>
                                </tr>
                                <t t-foreach="section.entries" t-as="item" t-key="item[0]">
                                    <t t-set="key" t-value="item[0]"/>
                                    <t t-set="val_data" t-value="item[1]"/>
                                    <t t-set="val_raw" t-value="(val_data and typeof val_data === 'object' and !Array.isArray(val_data)) ? val_data.value : val_data"/>
                                    <t t-set="val" t-value="this.formatValue(val_raw)"/>
                                    <t t-set="boolState" t-value="this.getBooleanState(val_raw)"/>
                                    <t t-set="isArray" t-value="Array.isArray(val_raw)"/>
                                    <t t-set="page" t-value="(val_data and typeof val_data === 'object' and !Array.isArray(val_data)) ? val_data.page_number : null"/>

                                    <tr t-att-class="{'evidence-row': true, 'border-bottom': true, 'active-audit-row': state.selectedKey === key}"
                                        t-on-click="(ev) => this.selectRow(key, ev)"
                                        t-on-mouseenter="() => this.onMouseEnterRow(key)"
                                        t-on-mouseleave="() => this.onMouseLeaveRow()"
                                        style="cursor: pointer; transition: all 0.2s;">
                                        <td class="text-center align-middle text-muted small ps-3">
                                            <t t-esc="count"/>
                                        </td>
                                        <th class="ps-3 align-middle text-muted text-nowrap" style="font-weight: 600; font-size: 0.75rem; border-left: 2px solid transparent;">
                                            <div class="d-flex align-items-center">
                                                <span class="field-icon me-2">
                                                    <i t-attf-class="fa #{this.getFieldIcon(key)}"/>
                                                </span>
                                                <t t-esc="this.formatFieldLabel(key)"/>
                                            </div>
                                        </th>
                                        <t t-set="count" t-value="count + 1"/>
                                        <td class="ps-3 align-middle">
                                            <div class="d-flex align-items-center justify-content-between w-100 py-1">
                                                <!-- Edit Mode -->
                                                <div t-if="state.editingKey === key" class="input-group input-group-sm" t-on-click="(ev) => ev.stopPropagation()">
                                                    <input type="text" class="form-control form-control-sm border-primary"
                                                           t-model="state.editValue"
                                                           t-on-keydown="(ev) => ev.key === 'Enter' ? this.saveEdit() : (ev.key === 'Escape' ? this.cancelEdit() : null)"
                                                           autoFocus="true"/>
                                                    <button class="btn btn-success" t-on-click="() => this.saveEdit()"><i class="fa fa-check"/></button>
                                                    <button class="btn btn-danger" t-on-click="() => this.cancelEdit()"><i class="fa fa-times"/></button>
                                                </div>

                                                <!-- Comment Mode -->
                                                <div t-if="state.commentingKey === key" class="input-group input-group-sm mt-1" t-on-click="(ev) => ev.stopPropagation()">
                                                    <input type="text" class="form-control form-control-sm border-info"
                                                           placeholder="Add a note..."
                                                           t-model="state.commentValue"
                                                           t-on-keydown="(ev) => ev.key === 'Enter' ? this.saveComment() : (ev.key === 'Escape' ? this.cancelComment() : null)"
                                                           autoFocus="true"/>
                                                    <button class="btn btn-info text-white" t-on-click="() => this.saveComment()"><i class="fa fa-pencil"/></button>
                                                    <button class="btn btn-outline-secondary btn-sm" t-on-click="() => this.cancelComment()"><i class="fa fa-times"/></button>
                                                </div>

                                                <!-- View Mode -->
                                                <t t-else="">
                                                    <div class="d-flex flex-column overflow-hidden me-2">
                                                        <!-- Array/JSON display (e.g. marks_table) -->
                                                        <div t-if="isArray" style="font-size: 0.78rem; max-height: 80px; overflow-y: auto;">
                                                            <t t-foreach="val_raw" t-as="item" t-key="item_index">
                                                                <span class="badge bg-secondary text-white me-1 mb-1" style="font-size: 0.70rem;">
                                                                    <t t-esc="this.formatArrayItem(item)"/>
                                                                </span>
                                                            </t>
                                                        </div>
                                                        <!-- Plain value display -->
                                                        <t t-if="boolState === 'true'">
                                                            <span class="badge rounded-pill text-bg-success" style="font-size: 0.78rem;">
                                                                <i class="fa fa-check me-1"/> True
                                                            </span>
                                                        </t>
                                                        <t t-elif="boolState === 'false'">
                                                            <span class="badge rounded-pill text-bg-danger" style="font-size: 0.78rem;">
                                                                <i class="fa fa-times me-1"/> False
                                                            </span>
                                                        </t>
                                                        <span t-else=""
                                                              t-attf-class="evidence-value fw-bold #{state.selectedKey === key ? 'text-danger' : 'text-primary'}"
                                                              style="font-size: 0.9rem;" t-esc="val || '---'"/>
                                                        <div t-if="val_data and typeof val_data === 'object' and !Array.isArray(val_data) and val_data.comment"
                                                             class="text-muted small italic opacity-75 mt-1"
                                                             style="font-size: 0.75rem; border-left: 2px solid #2563eb; padding-left: 6px;">
                                                            <i class="fa fa-commenting-o me-1"/> <t t-esc="val_data.comment"/>
                                                        </div>
                                                    </div>

                                                    <div class="d-flex align-items-center audit-actions">
                                                        <span t-if="page" class="badge rounded-pill text-bg-info me-2 shadow-sm" style="font-size: 0.65rem; padding: 0.35em 0.65em;">
                                                            <i class="fa fa-file-text-o me-1"/>PG <t t-esc="page"/>
                                                        </span>
                                                        <button class="btn btn-link btn-sm p-0 text-info opacity-50 hover-opacity-100 me-2"
                                                                title="Add Note"
                                                                t-on-click="(ev) => this.startComment(key, (val_data and typeof val_data === 'object') ? val_data.comment : '', ev)">
                                                            <i class="fa fa-commenting-o"/>
                                                        </button>
                                                        <button class="btn btn-link btn-sm p-0 text-muted opacity-50 hover-opacity-100"
                                                                title="Edit Value"
                                                                t-on-click="(ev) => this.startEdit(key, val, ev)">
                                                            <i class="fa fa-pencil"/>
                                                        </button>
                                                    </div>
                                                </t>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                    </tbody>
                </table>

                <!-- MARKS TAB -->
                <div t-if="state.activeTab === 'marks'" class="p-3 bg-white">
                    <t t-set="marksInfo" t-value="this.getMarksTableData()"/>
                    <div t-if="!marksInfo.rows.length" class="alert alert-secondary text-center small mt-3">
                        <i class="fa fa-info-circle me-1"/> No marks breakdown available.
                    </div>
                    <t t-else="">
                        <div class="table-responsive px-2 pb-3">
                            <table class="table table-borderless table-hover text-center align-middle mb-0" style="border-collapse: separate; border-spacing: 0 4px;">
                                <thead>
                                    <tr style="background-color: #e2e8f0; border-radius: 6px;">
                                        <th class="text-uppercase text-dark py-3" style="font-size: 0.70rem; letter-spacing: 1px; font-weight: 700; width: 25%; border-top-left-radius: 6px; border-bottom-left-radius: 6px;">Question No</th>
                                        <th class="text-uppercase text-dark py-3" style="font-size: 0.70rem; letter-spacing: 1px; font-weight: 700; width: 20%;">Page</th>
                                        <th class="text-uppercase text-dark py-3" style="font-size: 0.70rem; letter-spacing: 1px; font-weight: 700; width: 30%;">Marks Given</th>
                                        <th class="text-uppercase text-dark py-3" style="font-size: 0.70rem; letter-spacing: 1px; font-weight: 700; width: 25%; border-top-right-radius: 6px; border-bottom-right-radius: 6px;">Confidence</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="marksInfo.rows" t-as="m" t-key="m.qStr"
                                        t-on-mouseenter="(ev) => this.onMouseEnterMarksRow(m)"
                                        t-on-mouseleave="() => this.onMouseLeaveMarksRow()"
                                        t-on-click="(ev) => this.selectRow(marksInfo.key, ev)"
                                        class="bg-white shadow-sm evidence-row" 
                                        style="cursor: pointer; transition: transform 0.1s, box-shadow 0.1s;">
                                        <td class="fw-bold py-2" style="color: #4b5563; font-size: 0.85rem; border-top-left-radius: 6px; border-bottom-left-radius: 6px;">Q<t t-esc="m.q"/></td>
                                        <td class="py-2">
                                            <span t-if="m.page !== '-'" class="badge rounded-pill" style="background-color: #f0fdf4; color: #166534; font-size: 0.7rem; border: 1px solid #bbf7d0; padding: 0.35em 0.8em;">
                                                <i class="fa fa-file-text-o me-1 opacity-75"/> <t t-esc="m.page"/>
                                            </span>
                                            <span t-else="" class="text-muted opacity-50 small">—</span>
                                        </td>
                                        <td class="fw-bold" style="color: #2563eb; font-size: 1rem;">
                                            <t t-esc="m.marks"/>
                                        </td>
                                        <td style="border-top-right-radius: 6px; border-bottom-right-radius: 6px;">
                                            <t t-if="m.confidence !== null">
                                                <span class="badge rounded-pill" t-attf-style="background-color: #{m.confidence >= 90 ? '#e0e7ff' : '#fef9c3'}; color: #{m.confidence >= 90 ? '#3730a3' : '#854d0e'}; font-size: 0.7rem; border: 1px solid #{m.confidence >= 90 ? '#c7d2fe' : '#fef08a'};">
                                                    <i class="fa fa-crosshairs opacity-50 me-1"/> <t t-esc="m.confidence"/>%
                                                </span>
                                            </t>
                                            <span t-else="" class="text-muted opacity-25">—</span>
                                        </td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr class="mt-3">
                                        <td colspan="2" class="text-end pe-4 pt-3 text-uppercase text-muted" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;">Total Marks</td>
                                        <td class="pt-3 fw-bold text-success" style="font-size: 1.25rem;"><t t-esc="marksInfo.total"/></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </t>
                </div>
                </div>
            </t>
            <div t-if="state.data" class="text-center mt-2 text-muted small">
                <i class="fa fa-info-circle me-1"/> Click any row to highlight evidence in the PDF viewer
            </div>
        </div>
    </t>
</templates>
