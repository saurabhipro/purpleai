<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Default Extraction Template for Invoices -->
        <record id="extraction_master_invoice" model="purple_ai.extraction_master">
            <field name="name">Invoice Extraction</field>
        </record>

        <!-- Fields for Invoice Extraction -->
        <record id="field_vendor_name" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">10</field>
            <field name="name">Vendor Name</field>
            <field name="field_key">vendor_name</field>
            <field name="instruction">Extract the legal name of the supplier or vendor who issued the invoice.</field>
        </record>

        <record id="field_invoice_number" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">20</field>
            <field name="name">Invoice Number</field>
            <field name="field_key">invoice_number</field>
            <field name="instruction">Extract the unique invoice reference number or bill number.</field>
        </record>

        <record id="field_invoice_date" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">30</field>
            <field name="name">Invoice Date</field>
            <field name="field_key">invoice_date</field>
            <field name="instruction">Extract the date the invoice was issued. Preferred format: YYYY-MM-DD.</field>
        </record>

        <record id="field_untaxed_amount" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">40</field>
            <field name="name">Untaxed Amount</field>
            <field name="field_key">untaxed_amount</field>
            <field name="instruction">Extract the subtotal or base amount before ANY taxes (GST/VAT) are applied. Return a naked number.</field>
        </record>

        <record id="field_gst_amount" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">50</field>
            <field name="name">GST Amount</field>
            <field name="field_key">gst_amount</field>
            <field name="instruction">Extract the total GST (SGST+CGST or IGST) amount shown on the invoice.</field>
        </record>

        <record id="field_total_amount" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">60</field>
            <field name="name">Total Amount</field>
            <field name="field_key">total_amount</field>
            <field name="instruction">Extract the final grand total amount including all taxes.</field>
        </record>

        <record id="field_supplier_gstin" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">70</field>
            <field name="name">Supplier GSTIN</field>
            <field name="field_key">supplier_gstin</field>
            <field name="instruction">Extract the GST identification number of the supplier.</field>
        </record>

        <record id="field_vendor_bank_account" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">80</field>
            <field name="name">Vendor Bank Account</field>
            <field name="field_key">vendor_bank_account</field>
            <field name="instruction">Extract the bank account number or IBAN of the vendor mentioned on the invoice.</field>
        </record>

        <record id="field_po_number" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">90</field>
            <field name="name">PO Number</field>
            <field name="field_key">po_number</field>
            <field name="instruction">Extract the Purchase Order (PO) number reference mentioned on the invoice.</field>
        </record>

        <record id="field_service_type" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">100</field>
            <field name="name">Service Type</field>
            <field name="field_key">service_type</field>
            <field name="instruction">Extract the nature of service or goods provided (e.g. Professional Services, Rent, Technical Services).</field>
        </record>

        <record id="field_line_items" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">110</field>
            <field name="name">Line Items</field>
            <field name="field_key">line_items</field>
            <field name="instruction">Extract ALL line items from the invoice as a JSON array. Each item MUST have: "name" (item description), "qty" (quantity as a number), "rate" (unit price/rate as a number). Example: [{"name": "Item 1", "qty": 5, "rate": 100.00}, {"name": "Item 2", "qty": 2, "rate": 250.00}]. Return empty array [] if no items found.</field>
        </record>

        <!-- Rules for Invoice Extraction -->
        <record id="rule_unique_invoice" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">10</field>
            <field name="rule_code">RULE_1</field>
            <field name="name">Unique Invoice Check</field>
            <field name="description">Verify if this invoice number already exists for this vendor in Odoo.</field>
            <field name="eval_type">python</field>
        </record>

        <record id="rule_gst_format" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">20</field>
            <field name="rule_code">RULE_2</field>
            <field name="name">Valid GSTIN Format</field>
            <field name="description">Check if the extracted GSTIN followed the standard 15-character format.</field>
            <field name="eval_type">python</field>
        </record>

        <record id="rule_tax_match" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">30</field>
            <field name="rule_code">RULE_3</field>
            <field name="name">Tax Calculation Math</field>
            <field name="description">Taxable Value * GST Rate must equal the GST Amount shown on invoice.</field>
            <field name="eval_type">ai</field>
        </record>

        <record id="rule_po_amount" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">40</field>
            <field name="rule_code">RULE_4</field>
            <field name="name">Invoice Amount vs PO</field>
            <field name="description">Ensure the total invoice amount does not exceed the Purchase Order (PO) limit.</field>
            <field name="eval_type">python</field>
        </record>

        <record id="rule_bank_match" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">50</field>
            <field name="rule_code">RULE_5</field>
            <field name="name">Bank Account Master Match</field>
            <field name="description">Extracted bank account must belong to the selected vendor in Master data.</field>
            <field name="eval_type">python</field>
        </record>

        <record id="rule_po_date" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">60</field>
            <field name="rule_code">RULE_6</field>
            <field name="name">PO Date Check</field>
            <field name="description">Invoice date cannot be earlier than the PO issuance date.</field>
            <field name="eval_type">python</field>
        </record>

        <record id="rule_tds_accuracy" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">70</field>
            <field name="rule_code">RULE_7</field>
            <field name="name">TDS Rate Compliance</field>
            <field name="description">Ensure the TDS rate applied is correct for the extracted Service Type (e.g. 10% for Prof. Services).</field>
            <field name="eval_type">ai</field>
        </record>

        <!-- Decision-flow fields for AP automation -->
        <record id="field_vendor_gstin_decision" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">110</field>
            <field name="name">Vendor GSTIN (Decision)</field>
            <field name="field_key">vendor_gstin</field>
            <field name="instruction">Extract supplier GSTIN exactly as printed. Return uppercase alphanumeric text.</field>
        </record>
        <record id="field_vendor_pan" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">120</field>
            <field name="name">Vendor PAN</field>
            <field name="field_key">vendor_pan</field>
            <field name="instruction">Extract supplier PAN if available. Return uppercase text without spaces.</field>
        </record>
        <record id="field_invoice_currency" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">130</field>
            <field name="name">Invoice Currency</field>
            <field name="field_key">invoice_currency</field>
            <field name="instruction">Extract invoice currency code like INR, USD, EUR. Return 3-letter ISO code when possible.</field>
        </record>
        <record id="field_exchange_rate" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">140</field>
            <field name="name">Exchange Rate</field>
            <field name="field_key">exchange_rate</field>
            <field name="instruction">Extract FX conversion rate if mentioned. Return only numeric value.</field>
        </record>
        <record id="field_cgst_amount" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">150</field>
            <field name="name">CGST Amount</field>
            <field name="field_key">cgst_amount</field>
            <field name="instruction">Extract CGST amount. Return numeric value only; return 0 if not applicable.</field>
        </record>
        <record id="field_sgst_amount" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">160</field>
            <field name="name">SGST Amount</field>
            <field name="field_key">sgst_amount</field>
            <field name="instruction">Extract SGST amount. Return numeric value only; return 0 if not applicable.</field>
        </record>
        <record id="field_igst_amount" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">170</field>
            <field name="name">IGST Amount</field>
            <field name="field_key">igst_amount</field>
            <field name="instruction">Extract IGST amount. Return numeric value only; return 0 if not applicable.</field>
        </record>
        <record id="field_tds_amount" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">180</field>
            <field name="name">TDS Amount</field>
            <field name="field_key">tds_amount</field>
            <field name="instruction">Extract TDS deduction amount if printed or computable from invoice details. Return numeric value.</field>
        </record>
        <record id="field_rcm_amount" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">190</field>
            <field name="name">RCM Amount</field>
            <field name="field_key">rcm_amount</field>
            <field name="instruction">Extract reverse charge tax amount if present. Return numeric value, else 0.</field>
        </record>
        <record id="field_service_period_from" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">200</field>
            <field name="name">Service Period From</field>
            <field name="field_key">service_period_from</field>
            <field name="instruction">Extract service period start date in YYYY-MM-DD when available.</field>
        </record>
        <record id="field_service_period_to" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">210</field>
            <field name="name">Service Period To</field>
            <field name="field_key">service_period_to</field>
            <field name="instruction">Extract service period end date in YYYY-MM-DD when available.</field>
        </record>
        <record id="field_is_foreign_invoice" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">220</field>
            <field name="name">Is Foreign Invoice</field>
            <field name="field_key">is_foreign_invoice</field>
            <field name="instruction">Return boolean true/false whether this is a foreign invoice (non-India vendor/tax context/currency).</field>
        </record>
        <record id="field_is_proforma_invoice" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">230</field>
            <field name="name">Is Proforma Invoice</field>
            <field name="field_key">is_proforma_invoice</field>
            <field name="instruction">Return boolean true/false if document is proforma/performa invoice.</field>
        </record>
        <record id="field_is_services_invoice" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">240</field>
            <field name="name">Is Services Invoice</field>
            <field name="field_key">is_services_invoice</field>
            <field name="instruction">Return boolean true/false whether this invoice is for services (not goods).</field>
        </record>
        <record id="field_is_capex" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">250</field>
            <field name="name">Is CapEx</field>
            <field name="field_key">is_capex</field>
            <field name="instruction">Return boolean true/false if invoice nature indicates capital expenditure asset creation.</field>
        </record>
        <record id="field_is_gst_applicable" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">260</field>
            <field name="name">Is GST Applicable</field>
            <field name="field_key">is_gst_applicable</field>
            <field name="instruction">Return boolean true/false if GST applies for this invoice.</field>
        </record>
        <record id="field_is_tds_applicable" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">270</field>
            <field name="name">Is TDS Applicable</field>
            <field name="field_key">is_tds_applicable</field>
            <field name="instruction">Return boolean true/false if TDS should be applied.</field>
        </record>
        <record id="field_is_rcm_applicable" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">280</field>
            <field name="name">Is RCM Applicable</field>
            <field name="field_key">is_rcm_applicable</field>
            <field name="instruction">Return boolean true/false if reverse charge mechanism applies.</field>
        </record>
        <record id="field_is_prepaid" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">290</field>
            <field name="name">Is Prepaid</field>
            <field name="field_key">is_prepaid</field>
            <field name="instruction">Return boolean true/false if expense pertains to prepaid nature.</field>
        </record>
        <record id="field_is_next_period" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">300</field>
            <field name="name">Belongs To Next Period</field>
            <field name="field_key">belongs_to_next_period</field>
            <field name="instruction">Return boolean true/false if service period/invoice should be recognized in next accounting period.</field>
        </record>
        <record id="field_selected_hold_bucket" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">310</field>
            <field name="name">Selected Hold Bucket</field>
            <field name="field_key">selected_hold_bucket</field>
            <field name="instruction">If hold is needed, return one value only: vrf_hold, last_provision_hold, foreign_invoice_hold, advance_hold; else empty.</field>
        </record>
        <record id="field_selected_expense_gl" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">320</field>
            <field name="name">Selected Expense GL</field>
            <field name="field_key">selected_expense_gl</field>
            <field name="instruction">Return best matched expense GL code/name from context, if identifiable.</field>
        </record>
        <record id="field_selected_gst_gl" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">330</field>
            <field name="name">Selected GST GL</field>
            <field name="field_key">selected_gst_gl</field>
            <field name="instruction">Return GST GL bucket suggestion (eligible_gst_gl, ineligible_gst_gl, no_gst_gl) based on invoice evidence.</field>
        </record>
        <record id="field_selected_rcm_gl" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">340</field>
            <field name="name">Selected RCM GL</field>
            <field name="field_key">selected_rcm_gl</field>
            <field name="instruction">Return RCM GL suggestion when applicable, else no_gl.</field>
        </record>
        <record id="field_selected_tds_gl" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">350</field>
            <field name="name">Selected TDS GL</field>
            <field name="field_key">selected_tds_gl</field>
            <field name="instruction">Return TDS GL suggestion (or no_tds_gl) based on TDS applicability and section.</field>
        </record>
        <record id="field_selected_prepaid_gl" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">360</field>
            <field name="name">Selected Prepaid GL</field>
            <field name="field_key">selected_prepaid_gl</field>
            <field name="instruction">Return prepaid GL if prepaid treatment is required, else no_prepaid.</field>
        </record>
        <record id="field_fa_schedule_update_required" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">370</field>
            <field name="name">FA Schedule Update Required</field>
            <field name="field_key">fa_schedule_update_required</field>
            <field name="instruction">Return boolean true/false whether fixed asset schedule update is required for this invoice.</field>
        </record>
        <record id="field_final_action" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">380</field>
            <field name="name">Final Action</field>
            <field name="field_key">final_action</field>
            <field name="instruction">Return one final workflow decision: pass_entry, hold, update_fa_schedule, move_to_prepaid, move_to_last_provision.</field>
        </record>

        <!-- Decision-flow validation rules -->
        <record id="rule_vendor_exists_vrf" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">80</field>
            <field name="rule_code">RULE_8</field>
            <field name="name">Vendor Exists in VRF</field>
            <field name="description">Verify if vendor exists in VRF/master mapping; else route to hold bucket.</field>
            <field name="eval_type">ai</field>
        </record>
        <record id="rule_current_fy_check" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">90</field>
            <field name="rule_code">RULE_9</field>
            <field name="name">Current FY Date Check</field>
            <field name="description">Check whether invoice date belongs to current FY; otherwise suggest last provision hold.</field>
            <field name="eval_type">ai</field>
        </record>
        <record id="rule_foreign_invoice_check" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">100</field>
            <field name="rule_code">RULE_10</field>
            <field name="name">Foreign Invoice Check</field>
            <field name="description">Detect foreign invoice and route per policy.</field>
            <field name="eval_type">ai</field>
        </record>
        <record id="rule_proforma_check" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">110</field>
            <field name="rule_code">RULE_11</field>
            <field name="name">Proforma Invoice Check</field>
            <field name="description">Detect proforma/performa documents and route to advance/hold logic.</field>
            <field name="eval_type">ai</field>
        </record>
        <record id="rule_services_vs_goods" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">120</field>
            <field name="rule_code">RULE_12</field>
            <field name="name">Services vs Goods</field>
            <field name="description">Classify line nature as services or goods to drive GST/CapEx/prepaid branch.</field>
            <field name="eval_type">ai</field>
        </record>
        <record id="rule_capex_check" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">130</field>
            <field name="rule_code">RULE_13</field>
            <field name="name">CapEx Decision Check</field>
            <field name="description">Determine if invoice is CapEx and whether FA schedule update is required.</field>
            <field name="eval_type">ai</field>
        </record>
        <record id="rule_prepaid_period_check" model="purple_ai.validation_rule">
            <field name="master_id" ref="extraction_master_invoice"/>
            <field name="sequence">140</field>
            <field name="rule_code">RULE_14</field>
            <field name="name">Prepaid and Period Cutoff</field>
            <field name="description">Identify prepaid and next-period scenarios to route posting correctly.</field>
            <field name="eval_type">ai</field>
        </record>

        <!-- OMR Ranchi Template -->
        <record id="extraction_master_omr_ranchi" model="purple_ai.extraction_master">
            <field name="name">OMR Ranchi</field>
        </record>

        <record id="field_omr_registration" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_omr_ranchi"/>
            <field name="sequence">10</field>
            <field name="name">Registration Number</field>
            <field name="field_key">registration_number</field>
            <field name="instruction">Look for the 'REGISTRATION NUMBER' block. This is a multi-digit bubbled value (OMR). Extract and return the sequence of filled/bubbled digits as a string.</field>
        </record>

        <record id="field_omr_exam_code" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_omr_ranchi"/>
            <field name="sequence">20</field>
            <field name="name">Examination Code</field>
            <field name="field_key">examination_code</field>
            <field name="instruction">Look for the 'Examination Code' block. Extract the sequence of bubbled digits on the OMR sheet.</field>
        </record>

        <record id="field_omr_centre_code" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_omr_ranchi"/>
            <field name="sequence">30</field>
            <field name="name">Centre Code</field>
            <field name="field_key">centre_code</field>
            <field name="instruction">Look for the 'Centre Code' block. Extract the sequence of bubbled digits.</field>
        </record>

        <record id="field_omr_subject_code" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_omr_ranchi"/>
            <field name="sequence">40</field>
            <field name="name">Subject Code</field>
            <field name="field_key">subject_code</field>
            <field name="instruction">Look for the 'Subject Code' block at the top and bottom. Extract the bubbled value.</field>
        </record>

        <record id="field_omr_total_marks" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_omr_ranchi"/>
            <field name="sequence">50</field>
            <field name="name">Total Marks</field>
            <field name="field_key">total_marks</field>
            <field name="instruction">From PART-II (Examiner Sheet), locate the 'Total Marks' bubbles. Extract the resulting number.</field>
        </record>

        <record id="field_omr_answers" model="purple_ai.extraction_field">
            <field name="master_id" ref="extraction_master_omr_ranchi"/>
            <field name="sequence">60</field>
            <field name="name">Evaluation Answers</field>
            <field name="field_key">answers</field>
