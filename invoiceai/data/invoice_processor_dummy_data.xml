            <field name="invoice_date">2026-04-01</field>
            <field name="untaxed_amount">10000</field>
            <field name="state">draft</field>
            <field name="workflow_status">pending_manager_approval</field>
            <field name="approval_state">pending</field>
        </record>

        <record id="proc_demo_ready_tally" model="purple_ai.invoice_processor">
            <field name="extraction_result_id" ref="invoiceai.extract_demo_ready_tally"/>
