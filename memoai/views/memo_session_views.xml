<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Session List View -->
    <record id="view_memo_session_list" model="ir.ui.view">
        <field name="name">memo_ai.session.list</field>
        <field name="model">memo_ai.session</field>
        <field name="arch" type="xml">
            <list string="Analysis Sessions" decoration-success="state == 'done'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="subject_id"/>
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <field name="create_date" string="Started"/>
                <field name="total_time_seconds" sum="Total Time"/>
                <field name="total_cost" sum="Total Cost" widget="monetary"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state not in ('draft', 'done')"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- Session Form View — the main 5-step workflow UI -->
    <record id="view_memo_session_form" model="ir.ui.view">
        <field name="name">memo_ai.session.form</field>
        <field name="model">memo_ai.session</field>
        <field name="arch" type="xml">
            <form string="Analysis Session">
                <header>
                    <button name="action_run_step1" type="object"
                            string="▶ Run Step 1 — Summarize"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_run_step2" type="object"
                            string="▶ Run Step 2 — Issues"
                            class="btn-primary"
                            invisible="state != 'step1_done'"/>

                    <button name="action_run_step3" type="object"
                            string="▶ Run Step 3 — Regulations"
                            class="btn-primary"
                            invisible="state != 'step2_done'"/>

                    <button name="action_run_step4" type="object"
                            string="▶ Run Step 4 — Analysis"
                            class="btn-primary"
                            invisible="state != 'step3_done'"/>

                    <button name="action_open_export_wizard" type="object"
                            string="📤 Export Report"
                            class="btn-primary"
                            invisible="state not in ('step4_done', 'done')"/>

                    <button name="action_reset_to_draft" type="object"
                            string="↺ Reset"
                            class="btn-secondary"
                            invisible="state == 'draft'"
                            confirm="This will clear all step outputs. Are you sure?"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,step1_done,step2_done,step3_done,step4_done,done"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="subject_id" readonly="state != 'draft'"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <label for="total_time_seconds" string="Performance Metrics"/>
                            <div class="o_row">
                                <field name="total_time_seconds" widget="float_time" class="oe_inline"/> <span class="text-muted pe-2">secs</span>
                                <i class="fa fa-usd ms-3 text-success me-1"/>
                                <field name="total_cost" widget="monetary" class="oe_inline fw-bold text-success"/>
                            </div>
                            <field name="word_attachment_id" invisible="not word_attachment_id"/>
                        </group>
                    </group>

                    <!-- Documents Upload (draft only) -->
                    <group string="Source Documents" invisible="state != 'draft'">
                        <div class="alert alert-info" role="alert">
                            Upload PDFs or scanned documents to analyze. Then click <strong>Run Step 1</strong>.
                        </div>
                        <field name="document_ids" nolabel="1" widget="many2many_binary"/>
                    </group>

                    <!-- Uploaded files shown after step 1 starts -->
                    <group string="Source Documents" invisible="state == 'draft'">
                        <field name="document_ids" nolabel="1" readonly="1" widget="many2many_binary"/>
                    </group>

                    <separator/>

                    <!-- ── STEP 1 OUTPUT ──────────────────────────────────────────── -->
                    <div invisible="state == 'draft' and not step1_output" class="mt-4 card shadow-sm border-0 overflow-hidden">
                        <div class="card-header d-flex align-items-center justify-content-between bg-primary text-white py-3 px-3 clickable" 
                             data-bs-toggle="collapse" data-bs-target="#collapse_step1" style="border-bottom: 3px solid #0056b3;">
                            <div class="d-flex align-items-center">
                                <span class="badge rounded-pill bg-white text-primary fs-6 me-3 shadow-sm"><i class="fa fa-file-text-o"/> Step 1</span>
                                <span class="fs-5 fw-bold">Summary — AI-Generated (Editable)</span>
                            </div>
                            <div class="d-flex align-items-center ms-auto me-3 text-white">
                                <div class="badge rounded-pill bg-white text-primary border-0 px-3 py-2 shadow-sm d-flex align-items-center" 
                                     style="font-weight: 600; font-size: 0.75rem;" invisible="not step1_last_run">
                                    <i class="fa fa-clock-o me-2 opacity-75"/>
                                    <field name="step1_last_run" widget="datetime" readonly="1"/>
                                    <span class="mx-3 border-start border-primary opacity-25" style="height: 12px;"/>
                                    <i class="fa fa-refresh me-2 opacity-75"/>
                                    <span class="text-uppercase x-small me-1 opacity-50" style="font-size: 0.6rem;">Iter:</span>
                                    <field name="step1_iteration" readonly="1" class="fw-bold"/>
                                </div>
                            </div>
                             <button name="action_run_step1" string="Summarizing Documents..." 
                                     icon="fa-spinner fa-spin" invisible="not step1_processing" 
                                     class="btn btn-sm btn-light text-primary shadow-none fw-bold" disabled="1"/>
                             <button name="action_rerun_step1" type="object" string="Rerun AI" 
                                     icon="fa-refresh" class="btn btn-sm btn-light text-primary shadow-none fw-bold"
                                     invisible="step1_processing"
                                     confirm="Are you sure you want to rerun Step 1 using the current source documents?"/>
                        </div>
                        <div id="collapse_step1" class="collapse show">
                            <div class="card-body p-0">
                                <field name="step1_output" nolabel="1" widget="html" class="w-100"
                                       placeholder="AI summary will appear here after Step 1 runs..."
                                       options="{'collaborative': false, 'resizable': true, 'min-height': 250}"/>
                            </div>
                        </div>
                        <div class="card-footer bg-light py-2 px-3 border-top d-flex align-items-center" invisible="not step1_sources">
                            <i class="fa fa-info-circle text-primary me-2" style="font-size: 0.9rem;"/>
                            <span class="text-muted small"><strong>Based on:</strong> <field name="step1_sources" readonly="1"/></span>
                        </div>
                    </div>

                    <!-- ── STEP 2 OUTPUT ──────────────────────────────────────────── -->
                    <div invisible="state not in ('step2_done','step3_done','step4_done','done') and not step2_output" class="mt-4 card shadow-sm border-0 overflow-hidden">
                        <div class="card-header d-flex align-items-center justify-content-between bg-warning text-dark py-3 px-3 clickable"
                             data-bs-toggle="collapse" data-bs-target="#collapse_step2" style="border-bottom: 3px solid #d39e00;">
                            <div class="d-flex align-items-center">
                                <span class="badge rounded-pill bg-white text-warning fs-6 me-3 shadow-sm"><i class="fa fa-exclamation-triangle"/> Step 2</span>
                                <span class="fs-5 fw-bold">Applicable Issues — AI-Generated (Editable)</span>
                            </div>
                            <div class="d-flex align-items-center ms-auto me-3">
                                <div class="badge rounded-pill bg-white text-warning border-0 px-3 py-2 shadow-sm d-flex align-items-center" 
                                     style="font-weight: 600; font-size: 0.75rem;" invisible="not step2_last_run">
                                    <i class="fa fa-clock-o me-2 opacity-75"/>
                                    <field name="step2_last_run" widget="datetime" readonly="1"/>
                                    <span class="mx-3 border-start border-warning opacity-25" style="height: 12px;"/>
                                    <i class="fa fa-refresh me-2 opacity-75"/>
                                    <span class="text-uppercase x-small me-1 opacity-50" style="font-size: 0.6rem;">Iter:</span>
                                    <field name="step2_iteration" readonly="1" class="fw-bold"/>
                                </div>
                            </div>
                             <button name="action_run_step2" string="Finding Issues..." 
                                     icon="fa-spinner fa-spin" invisible="not step2_processing" 
                                     class="btn btn-sm btn-light text-warning shadow-none fw-bold" disabled="1"/>
                             <button name="action_rerun_step2" type="object" string="Rerun AI" 
                                     icon="fa-refresh" class="btn btn-sm btn-light text-warning shadow-none fw-bold"
                                     invisible="step1_processing or step2_processing"
                                     confirm="Are you sure you want to rerun Step 2 using the current Summary and RAG matches?"/>
                        </div>
                        <div id="collapse_step2" class="collapse show">
                            <div class="card-body p-0">
                                <field name="step2_output" nolabel="1" widget="html" class="w-100"
                                       placeholder="Identified issues will appear here after Step 2 runs..."
                                       options="{'collaborative': false, 'resizable': true, 'min-height': 250}"/>
                            </div>
                        </div>
                        <div class="card-footer bg-light py-2 px-3 border-top d-flex align-items-center" invisible="not step2_sources">
                            <i class="fa fa-info-circle text-warning me-2" style="font-size: 0.9rem;"/>
                            <span class="text-muted small"><strong>Matches:</strong> <field name="step2_sources" readonly="1"/></span>
                        </div>
                    </div>

                    <!-- ── STEP 3 OUTPUT ──────────────────────────────────────────── -->
                    <div invisible="state not in ('step3_done','step4_done','done') and not step3_output" class="mt-4 card shadow-sm border-0 overflow-hidden">
                        <div class="card-header d-flex align-items-center justify-content-between bg-info text-white py-3 px-3 clickable"
                             data-bs-toggle="collapse" data-bs-target="#collapse_step3" style="border-bottom: 3px solid #0aa2c0;">
                            <div class="d-flex align-items-center">
                                <span class="badge rounded-pill bg-white text-info fs-6 me-3 shadow-sm"><i class="fa fa-balance-scale"/> Step 3</span>
                                <span class="fs-5 fw-bold">Regulatory Guidelines — AI-Generated (Editable)</span>
                            </div>
                            <div class="d-flex align-items-center ms-auto me-3">
                                <div class="badge rounded-pill bg-white text-info border-0 px-3 py-2 shadow-sm d-flex align-items-center" 
                                     style="font-weight: 600; font-size: 0.75rem;" invisible="not step3_last_run">
                                    <i class="fa fa-clock-o me-2 opacity-75"/>
                                    <field name="step3_last_run" widget="datetime" readonly="1"/>
                                    <span class="mx-3 border-start border-info opacity-25" style="height: 12px;"/>
                                    <i class="fa fa-refresh me-2 opacity-75"/>
                                    <span class="text-uppercase x-small me-1 opacity-50" style="font-size: 0.6rem;">Iter:</span>
                                    <field name="step3_iteration" readonly="1" class="fw-bold"/>
                                </div>
                            </div>
                             <button name="action_run_step3" string="Mapping Compliance..." 
                                     icon="fa-spinner fa-spin" invisible="not step3_processing" 
                                     class="btn btn-sm btn-light text-info shadow-none fw-bold" disabled="1"/>
                             <button name="action_rerun_step3" type="object" string="Rerun AI" 
                                     icon="fa-refresh" class="btn btn-sm btn-light text-info shadow-none fw-bold"
                                     invisible="step2_processing or step3_processing"
                                     confirm="Are you sure you want to rerun Step 3 using the current Issues and Guidelines?"/>
                        </div>
                        <div id="collapse_step3" class="collapse show">
                            <div class="card-body p-0">
                                <field name="step3_output" nolabel="1" widget="html" class="w-100"
                                       placeholder="Applicable regulations will appear here after Step 3 runs..."
                                       options="{'collaborative': false, 'resizable': true, 'min-height': 250}"/>
                            </div>
                        </div>
                        <div class="card-footer bg-light py-2 px-3 border-top d-flex align-items-center" invisible="not step3_sources">
                            <i class="fa fa-balance-scale text-info me-2" style="font-size: 0.8rem;"/>
                            <span class="text-muted small"><strong>Library Refs:</strong> <field name="step3_sources" readonly="1"/></span>
                        </div>
                    </div>

                    <!-- ── STEP 4 OUTPUT ──────────────────────────────────────────── -->
                    <div invisible="state not in ('step4_done','done') and not step4_output" class="mt-4 card shadow-sm border-0 overflow-hidden">
                        <div class="card-header d-flex align-items-center justify-content-between bg-success text-white py-3 px-3 clickable"
                             data-bs-toggle="collapse" data-bs-target="#collapse_step4" style="border-bottom: 3px solid #198754;">
                            <div class="d-flex align-items-center">
                                <span class="badge rounded-pill bg-white text-success fs-6 me-3 shadow-sm"><i class="fa fa-diamond"/> Step 4</span>
                                <span class="fs-5 fw-bold">Analysis — AI-Generated (Editable)</span>
                            </div>
                            <div class="d-flex align-items-center ms-auto me-3">
                                <div class="badge rounded-pill bg-white text-success border-0 px-3 py-2 shadow-sm d-flex align-items-center" 
                                     style="font-weight: 600; font-size: 0.75rem;" invisible="not step4_last_run">
                                    <i class="fa fa-clock-o me-2 opacity-75"/>
                                    <field name="step4_last_run" widget="datetime" readonly="1"/>
                                    <span class="mx-3 border-start border-success opacity-25" style="height: 12px;"/>
                                    <i class="fa fa-refresh me-2 opacity-75"/>
                                    <span class="text-uppercase x-small me-1 opacity-50" style="font-size: 0.6rem;">Iter:</span>
                                    <field name="step4_iteration" readonly="1" class="fw-bold"/>
                                </div>
                            </div>
                             <button name="action_run_step4" string="Generating Memo..." 
                                     icon="fa-spinner fa-spin" invisible="not step4_processing" 
                                     class="btn btn-sm btn-light text-success shadow-none fw-bold" disabled="1"/>
                             <button name="action_rerun_step4" type="object" string="Rerun AI" 
                                     icon="fa-refresh" class="btn btn-sm btn-light text-success shadow-none fw-bold"
                                     invisible="step3_processing or step4_processing"
                                     confirm="Are you sure you want to rerun the final Analysis?"/>
                        </div>
                        <div id="collapse_step4" class="collapse show">
                            <div class="card-body p-0">
                                <field name="step4_output" nolabel="1" widget="html" class="w-100"
                                       placeholder="Full analysis memo will appear here after Step 4 runs..."
                                       options="{'collaborative': false, 'resizable': true, 'min-height': 350}"/>
                            </div>
                        </div>
                        <div class="card-footer bg-light py-2 px-3 border-top d-flex align-items-center" invisible="not step4_sources">
                            <i class="fa fa-diamond text-success me-2" style="font-size: 0.8rem;"/>
                            <span class="text-muted small"><strong>Synthesized from:</strong> <field name="step4_sources" readonly="1"/></span>
                        </div>
                    </div>

                </sheet>
                <chatter>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_memo_session_kanban" model="ir.ui.view">
        <field name="name">memo_ai.session.kanban</field>
        <field name="model">memo_ai.session</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="subject_id"/>
                <field name="user_id"/>
                <field name="state"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="subject_id"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left text-muted">
                                    <field name="create_date" widget="date"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Export Wizard Form -->
    <record id="view_memo_export_wizard_form" model="ir.ui.view">
        <field name="name">memo_ai.export_wizard.form</field>
        <field name="model">memo_ai.export_wizard</field>
        <field name="arch" type="xml">
            <form string="Export Report">
                <sheet>
                    <div class="alert alert-primary mb-3" role="alert">
                        <i class="fa fa-info-circle me-2"/> Choose your preferred format for the final analysis memo.
                    </div>
                    <group>
                        <field name="session_id" invisible="1"/>
                        <field name="format" widget="radio" class="fw-bold"/>
                    </group>
                    <div class="alert alert-warning mt-3" role="alert" invisible="format != 'pdf'">
                        <i class="fa fa-clock-o me-2"/> PDF generation is being optimized for large tables. Using Word as fallback for now.
                    </div>
                </sheet>
                <footer>
                    <button name="action_export" string="Generate Download" type="object" class="btn-primary" icon="fa-download"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_memo_session" model="ir.actions.act_window">
        <field name="name">Analysis Sessions</field>
        <field name="res_model">memo_ai.session</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Start a new analysis session!</p>
            <p>Select a subject, upload your documents, and let AI guide you through the
            5-step analysis workflow.</p>
        </field>
    </record>

</odoo>
