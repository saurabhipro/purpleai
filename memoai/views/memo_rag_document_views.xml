<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- RAG Document standalone List -->
    <record id="view_memo_rag_document_list" model="ir.ui.view">
        <field name="name">memo_ai.rag_document.list</field>
        <field name="model">memo_ai.rag_document</field>
        <field name="arch" type="xml">
            <list string="RAG Documents"
                  decoration-success="state == 'processed'"
                  decoration-danger="state == 'error'">
                <field name="name"/>
                <field name="subject_id"/>
                <field name="rag_type"/>
                <field name="chunk_count" string="Chunks"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'processed'"
                       decoration-danger="state == 'error'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="view_memo_rag_document_form" model="ir.ui.view">
        <field name="name">memo_ai.rag_document.form</field>
        <field name="model">memo_ai.rag_document</field>
        <field name="arch" type="xml">
            <form string="RAG Document">
                <header>
                    <button name="action_extract_text" type="object"
                            string="Extract Text from PDF"
                            class="btn-primary"
                            invisible="state == 'processed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,processed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="subject_id"/>
                            <field name="rag_type"/>
                        </group>
                        <group>
                            <field name="upload_file" widget="binary" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                            <field name="chunk_count" readonly="1" string="Vector Chunks"/>
                            <field name="process_time" widget="float_time" invisible="not process_time"/>
                            <field name="process_cost" invisible="not process_time"/>
                            <field name="processed_date" invisible="not process_time"/>
                        </group>
                    </group>
                    <group string="Extracted Text Preview" invisible="not extracted_text">
                        <field name="extracted_text" readonly="1" nolabel="1" widget="text"/>
                    </group>
                    <group string="Error" invisible="not error_message">
                        <field name="error_message" readonly="1" nolabel="1" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_memo_rag_document" model="ir.actions.act_window">
        <field name="name">RAG Library</field>
        <field name="res_model">memo_ai.rag_document</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Upload your first RAG document!</p>
            <p>RAG documents are indexed PDF files used by AI to find relevant context during analysis steps.</p>
        </field>
    </record>

</odoo>
