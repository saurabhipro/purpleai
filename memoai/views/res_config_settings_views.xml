<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_memo_ai_res_config_settings" model="ir.ui.view">
        <field name="name">res.config.settings.memoai.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="99"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Memo AI" string="Memo AI" name="memoai">

                    <!-- AI Provider Selection -->
                    <block title="AI Provider" name="memo_ai_provider_block">
                        <setting help="Choose the AI service for Memo AI analysis steps">
                            <div class="content-group">
                                <field name="memo_ai_provider" widget="radio" class="o_field_radio_vertical"/>
                                <div class="text-muted mt-2">
                                    <i class="fa fa-info-circle"/> Select a provider, then configure its credentials below.
                                </div>
                            </div>
                        </setting>
                    </block>

                    <!-- OpenAI GPT -->
                    <block title="OpenAI GPT Configuration" name="memo_openai_block"
                           invisible="memo_ai_provider != 'openai'">
                        <setting title="API Key" help="Your OpenAI secret API key">
                            <field name="memo_ai_openai_api_key" password="True" placeholder="sk-..."/>
                            <div class="text-muted">
                                Get your key at <a href="https://platform.openai.com/api-keys" target="_blank">platform.openai.com</a>
                            </div>
                        </setting>
                        <setting title="Model" help="The GPT model to use for analysis">
                            <field name="memo_ai_openai_model"/>
                            <div class="mt-2">
                                <button name="action_test_memo_openai" string="Test Connection"
                                        type="object" class="btn-secondary btn-sm" icon="fa-plug"/>
                            </div>
                        </setting>
                    </block>

                    <!-- Google Gemini -->
                    <block title="Google Gemini Configuration" name="memo_gemini_block"
                           invisible="memo_ai_provider != 'gemini'">
                        <setting title="API Key" help="Your Google Gemini API key">
                            <field name="memo_ai_gemini_api_key" password="True" placeholder="AIzaSy..."/>
                            <div class="text-muted">
                                Get your key at <a href="https://aistudio.google.com/app/apikey" target="_blank">Google AI Studio</a>
                            </div>
                        </setting>
                        <setting title="Model" help="The Gemini model to use for analysis">
                            <field name="memo_ai_gemini_model"/>
                            <div class="mt-2">
                                <button name="action_test_memo_gemini" string="Test Connection"
                                        type="object" class="btn-secondary btn-sm" icon="fa-plug"/>
                            </div>
                        </setting>
                    </block>

                    <!-- Azure OpenAI -->
                    <block title="Microsoft Azure OpenAI Configuration" name="memo_azure_block"
                           invisible="memo_ai_provider != 'azure'">
                        <setting title="Endpoint URL" help="Your Azure resource endpoint URL">
                            <field name="memo_ai_azure_endpoint"
                                   placeholder="https://&lt;resource&gt;.openai.azure.com/"/>
                            <div class="text-muted">
                                Find this in <a href="https://portal.azure.com/" target="_blank">Azure Portal</a>
                                → Your AI resource → Keys and Endpoint
                            </div>
                        </setting>
                        <setting title="API Key" help="Your Azure OpenAI secret key">
                            <field name="memo_ai_azure_api_key" password="True"
                                   placeholder="Enter your Azure API key"/>
                        </setting>
                        <setting title="Deployment Name" help="The name of your Azure model deployment">
                            <field name="memo_ai_azure_deployment" placeholder="e.g. gpt-4o"/>
                        </setting>
                        <setting title="API Version" help="Azure OpenAI REST API version">
                            <field name="memo_ai_azure_api_version"/>
                            <div class="mt-2">
                                <button name="action_test_memo_azure" string="Test Connection"
                                        type="object" class="btn-secondary btn-sm" icon="fa-plug"/>
                            </div>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>

    <!-- Action for Memo AI Settings menu -->
    <record id="action_memo_ai_settings" model="ir.actions.act_window">
        <field name="name">Memo AI Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'memoai'}</field>
    </record>

</odoo>
