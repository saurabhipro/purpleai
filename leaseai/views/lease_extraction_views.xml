<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lease_ai_extraction_tree" model="ir.ui.view">
        <field name="name">lease.ai.extraction.tree</field>
        <field name="model">lease_ai.extraction</field>
        <field name="arch" type="xml">
            <list string="Lease Extractions" decoration-success="state == 'done'" decoration-danger="state == 'error'" decoration-warning="state == 'processing'">
                <field name="create_date" string="Date"/>
                <field name="name"/>
                <field name="document_filename"/>
                <field name="state" widget="badge"/>
                <field name="page_count" string="Pages" optional="show"/>
                <field name="tenant_name" optional="show"/>
                <field name="lease_start_date" optional="show"/>
                <field name="lease_end_date" optional="show"/>
                <field name="property_address" optional="hide"/>
                <field name="rent_amount" optional="show"/>
                <field name="execution_time" string="Time (s)" optional="show"/>
                <field name="tokens_used" optional="hide"/>
                <field name="estimated_cost_inr" string="Cost (₹)" optional="show"/>
                <field name="ai_provider" optional="hide"/>
                <field name="create_uid" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_lease_ai_extraction_form" model="ir.ui.view">
        <field name="name">lease.ai.extraction.form</field>
        <field name="model">lease_ai.extraction</field>
        <field name="arch" type="xml">
            <form string="Lease Extraction" create="0" edit="0">
                <header>
                    <button name="action_extract" string="Run Extraction" type="object" class="btn-primary" invisible="state == 'processing'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,processing,done,error"/>
                </header>
                <sheet>
                    <div class="row g-0 o_audit_container">
                        <!-- Left Panel: Extracted Data (40%) -->
                        <div class="col-lg-5 border-end bg-light p-3 o_audit_left_panel" style="min-height: 1000px;">
                            <h5 class="text-primary mb-3">
                                <i class="fa fa-list-alt me-2"/>Lease Data Extraction
                            </h5>
                            <field name="extracted_data" widget="ai_evidence_viewer" nolabel="1" readonly="1" invisible="not extracted_data"/>
                            
                            <!-- Extracted Lease Data Summary (shown after extraction) -->
                            <div invisible="not extracted_data" class="p-3 rounded bg-white border mt-3">
                                <h6 class="fw-bold mb-2"><i class="fa fa-info-circle me-2"/>Extracted Lease Data</h6>
                                <group>
                                    <field name="tenant_name" readonly="1"/>
                                    <field name="property_address" readonly="1"/>
                                </group>
                                <group>
                                    <field name="lease_start_date" readonly="1"/>
                                    <field name="lease_end_date" readonly="1"/>
                                </group>
                                <group>
                                    <field name="rent_amount" readonly="1"/>
                                    <field name="page_count" readonly="1"/>
                                </group>
                            </div>
                            
                            <!-- Execution Metrics -->
                            <div invisible="not extracted_data" class="p-3 rounded bg-info-light border mt-3">
                                <h6 class="fw-bold mb-2"><i class="fa fa-tachometer me-2"/>Execution Metrics</h6>
                                <group>
                                    <field name="execution_time" readonly="1" string="Time (seconds)"/>
                                    <field name="tokens_used" readonly="1"/>
                                </group>
                                <group>
                                    <field name="estimated_cost_inr" readonly="1" string="Cost (₹)"/>
                                    <field name="ai_provider" readonly="1"/>
                                    <field name="ai_model" readonly="1"/>
                                </group>
                            </div>
                            
                            
                            <!-- Metadata & Config (shown before extraction) -->
                            <div invisible="extracted_data" class="p-3 rounded bg-white border">
                                <group>
                                    <field name="name"/>
                                    <field name="template_id"/>
                                    <field name="document_file" filename="document_filename"/>
                                    <field name="document_filename" invisible="1"/>
                                </group>
                                <group string="Custom Rules" class="mt-2">
                                    <field name="custom_prompt" nolabel="1" placeholder="Edit extraction rules here..." style="height: 150px;"/>
                                </group>
                            </div>

                            <!-- Errors Section -->
                            <div class="mt-4" invisible="not error_log">
                                <div class="alert alert-danger" role="alert">
                                    <h6 class="alert-heading" role="status"><i class="fa fa-exclamation-triangle me-2"/>Extraction Errors</h6>
                                    <field name="error_log" readonly="1" class="text-danger font-monospace" style="font-size: 0.85rem;"/>
               s                 </div>
                            </div>
                        </div>

                        <!-- Draggable Resizer Handle -->
                        <div class="o_audit_resizer d-none d-lg-block"/>

                        <!-- Right Panel: PDF Preview (60%) -->
                        <div class="col-lg-7 bg-dark-subtle p-0 o_audit_right_panel">
                            <div class="d-flex justify-content-between align-items-center bg-white border-bottom px-3 py-1">
                                <h6 class="m-0 text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05rem;">
                                    <i class="fa fa-eye me-2"/> DOCUMENT PREVIEW
                                </h6>
                            </div>
                            <div style="height: calc(100vh - 120px); min-height: 800px; overflow: hidden; position: relative;" class="shadow-sm border o_audit_viewport_container bg-secondary">
                                <field name="is_pdf" invisible="1"/>
                                <field name="is_image" invisible="1"/>
                                <!-- PDF Viewer -->
                                <field name="pdf_file" widget="pdf_viewer" nolabel="1" filename="pdf_filename" class="h-100 w-100 p-0 m-0" invisible="not is_pdf"/>
                                <!-- Image Viewer -->
                                <field name="pdf_file" widget="image" nolabel="1" class="h-100 w-100 p-0 m-0" style="object-fit: contain; background: #333;" invisible="not is_image"/>
                                <!-- Fallback: Prompt to upload document -->
                                <div invisible="is_pdf or is_image" class="d-flex align-items-center justify-content-center h-100 text-white p-5 text-center">
                                    <div>
                                        <i class="fa fa-file-pdf-o fa-5x mb-3 opacity-50" title="Document"/>
                                        <h5>Upload a document to view</h5>
                                        <p class="opacity-75">Supported: PDF, Images (JPG, PNG, TIFF)</p>
                                    </div>
                                </div>
                            </div>
                            <field name="pdf_filename" invisible="1"/>
                        </div>
                    </div>
                </sheet>
                <chatter>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="action_lease_ai_extraction" model="ir.actions.act_window">
        <field name="name">Lease Extractions</field>
        <field name="res_model">lease_ai.extraction</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lease_ai_extractions"
              name="Lease Extractions"
              parent="leaseai.menu_lease_ai_root"
              action="action_lease_ai_extraction"
              sequence="10"/>
</odoo>
