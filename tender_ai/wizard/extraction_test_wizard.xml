<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_extraction_test_wizard_form" model="ir.ui.view">
        <field name="name">tende_ai.extraction_test_wizard.form</field>
        <field name="model">tende_ai.extraction_test_wizard</field>
        <field name="arch" type="xml">
            <form string="Test Custom Extraction">
                <sheet>
                    <group invisible="state == 'done'">
                        <field name="field_id" readonly="1"/>
                        <field name="pdf_file" filename="pdf_filename"/>
                        <field name="pdf_filename" invisible="1"/>
                    </group>
                    <group invisible="state == 'draft'" string="Results">
                        <field name="result_value"/>
                        <field name="result_page"/>
                        <field name="result_para"/>
                    </group>
                    <footer>
                        <button name="action_test" string="Test Extraction" type="object" class="btn-primary" invisible="state == 'done'" data-hotkey="q"/>
                        <button string="Close" class="btn-secondary" special="cancel" data-hotkey="x"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_extraction_test_wizard" model="ir.actions.act_window">
        <field name="name">Test Extraction</field>
        <field name="res_model">tende_ai.extraction_test_wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_field_id': active_id}</field>
    </record>
</odoo>
