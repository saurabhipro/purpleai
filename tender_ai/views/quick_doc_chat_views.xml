<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_quick_doc_chat_tree" model="ir.ui.view">
        <field name="name">tende_ai.quick_doc_chat.tree</field>
        <field name="model">tende_ai.quick_doc_chat</field>
        <field name="arch" type="xml">
            <list string="Quick Document Chats">
                <field name="create_date" string="Date"/>
                <field name="name"/>
                <field name="filename" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_quick_doc_chat_form" model="ir.ui.view">
        <field name="name">tende_ai.quick_doc_chat.form</field>
        <field name="model">tende_ai.quick_doc_chat</field>
        <field name="arch" type="xml">
            <form string="Quick Chat" class="o_quick_chat_form">
                <header>
                    <button name="action_process_document" string="Re-Process Document" type="object" invisible="not file"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Chat Name"/>
                        <h1><field name="name" placeholder="e.g. Invoice Query"/></h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="file" filename="filename" widget="binary" string="Upload PDF"/>
                            <field name="filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="kb_state" widget="badge" 
                                   decoration-success="kb_state == 'processed'"
                                   decoration-muted="kb_state == 'empty'"
                                   readonly="1" string="Indexing Status"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Chat" name="chat_tab">
                            <div class="o_quick_chat_container border rounded bg-white mt-2" 
                                 style="max-height: 65vh; overflow-y: auto; display: flex; flex-direction: column;">
                                
                                <div class="p-5 text-center text-muted" invisible="chat_message_ids or not file">
                                    <i class="fa fa-comments-o fa-4x mb-3" style="opacity: 0.3;" title="Chat Icon"/>
                                    <h3>Ready to Chat!</h3>
                                    <p>The document is indexed. Ask anything below.</p>
                                </div>

                                <div class="p-5 text-center text-muted" invisible="file">
                                    <i class="fa fa-cloud-upload fa-4x mb-3" style="opacity: 0.3;" title="Upload File"/>
                                    <h3>Upload a Document to Start</h3>
                                </div>

                                <field name="chat_message_ids" readonly="1" nolabel="1">
                                    <kanban create="0" delete="0" edit="0" class="o_kanban_chat d-block w-100 p-0 m-0 shadow-none border-0">
                                        <field name="role"/>
                                        <field name="content"/>
                                        <templates>
                                            <t t-name="card">
                                                <div t-attf-class="w-100 d-flex flex-row p-3 mb-2" 
                                                     t-attf-style="justify-content: #{record.role.raw_value == 'user' ? 'flex-end' : 'flex-start'};">
                                                    <div t-attf-class="d-flex gap-3 align-items-start" 
                                                         t-attf-style="max-width: 85%; flex-direction: #{record.role.raw_value == 'user' ? 'row-reverse' : 'row'};">
                                                        
                                                        <!-- Avatar -->
                                                        <div t-attf-class="rounded-circle shadow-sm d-flex align-items-center justify-content: center;"
                                                             t-attf-style="width: 42px; height: 42px; flex-shrink: 0; background-color: #{record.role.raw_value == 'user' ? '#388e3c' : '#0288d1'}; color: white; border: 2px solid white;">
                                                            <i t-attf-class="fa fa-2x w-100 text-center #{record.role.raw_value == 'user' ? 'fa-user-circle' : 'fa-bolt'}" title="Avatar"/>
                                                        </div>

                                                        <!-- Bubble -->
                                                        <div t-attf-class="shadow-sm p-3" 
                                                             t-attf-style="background-color: #{record.role.raw_value == 'user' ? '#f1f8e9' : '#e1f5fe'}; border: 1px solid #{record.role.raw_value == 'user' ? '#c8e6c9' : '#b3e5fc'}; border-radius: 15px !important;">
                                                            <div class="small fw-bold mb-1" t-attf-style="color: #{record.role.raw_value == 'user' ? '#2e7d32' : '#0277bd'}; text-align: #{record.role.raw_value == 'user' ? 'right' : 'left'};">
                                                                <t t-if="record.role.raw_value == 'user'">You</t>
                                                                <t t-else="">Assistant</t>
                                                            </div>
                                                            <div style="white-space: pre-wrap; font-size: 1.1rem; color: #333; line-height: 1.6;">
                                                                <field name="content"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </div>

                            <!-- Input Bar Sticky Bottom -->
                            <div class="mt-auto p-4 bg-white border-top shadow-lg rounded-bottom" style="position: sticky; bottom: 0; z-index: 10;">
                                <div class="d-flex align-items-center bg-light rounded-pill px-4 py-2 border">
                                    <field name="chat_question" nolabel="1" 
                                           placeholder="Type your question about the document..."
                                           class="flex-grow-1 border-0 bg-transparent py-2 shadow-none"
                                           style="outline: none !important; font-size: 1.1rem;"/>
                                    <button name="action_send_message" string="" 
                                            type="object" class="btn btn-primary rounded-circle p-0 ms-2" 
                                            style="width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;"
                                            icon="fa-paper-plane"
                                            title="Send Message"
                                            invisible="not chat_question or not file"/>
                                </div>
                                <div class="d-flex justify-content-between mt-2 px-3">
                                    <button name="action_clear_chat" string="Clear History" 
                                            type="object" class="btn btn-link btn-sm text-muted p-0" 
                                            icon="fa-trash"
                                            invisible="not chat_message_ids"/>
                                    <div class="small text-muted italic" invisible="not filename">
                                        Source: <field name="filename" class="fw-bold"/>
                                    </div>
                                </div>
                            </div>
                        </page>
                        <page string="Extracted Text" name="text_tab" invisible="not kb_text">
                            <field name="kb_text" readonly="1" placeholder="Text will appear here after indexing..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_quick_doc_chat" model="ir.actions.act_window">
        <field name="name">Odoo Chat AI</field>
        <field name="res_model">tende_ai.quick_doc_chat</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Upload any PDF and start chatting instantly!
            </p>
        </field>
    </record>

    <!-- Menuitem -->
    <menuitem id="menu_quick_doc_chat"
              name="Odoo Chat AI"
              parent="menu_tende_ai_root"
              action="action_quick_doc_chat"
              sequence="5"/>
</odoo>
