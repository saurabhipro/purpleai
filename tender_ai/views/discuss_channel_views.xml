<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="discuss_channel_view_form_inherit_ai" model="ir.ui.view">
        <field name="name">discuss.channel.form.inherit.ai</field>
        <field name="model">discuss.channel</field>
        <field name="inherit_id" ref="mail.discuss_channel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='description']" position="after">
                <field name="is_ai_kb_enabled"/>
                <div class="o_horizontal_separator mt-1" invisible="not is_ai_kb_enabled">AI Knowledge Base Settings</div>
                <group invisible="not is_ai_kb_enabled">
                    <field name="kb_state" widget="badge" 
                           decoration-success="kb_state == 'ready'"
                           decoration-muted="kb_state == 'empty'"/>
                    <button name="action_index_latest_attachment" string="Index Latest PDF" 
                            type="object" class="btn-primary" icon="fa-refresh"
                            help="Index the most recently uploaded PDF in this channel"/>
                    <field name="kb_text" invisible="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
