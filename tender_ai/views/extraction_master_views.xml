<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_extraction_master_tree" model="ir.ui.view">
        <field name="name">tende_ai.extraction_master.tree</field>
        <field name="model">tende_ai.extraction_master</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="document_type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_extraction_master_form" model="ir.ui.view">
        <field name="name">tende_ai.extraction_master.form</field>
        <field name="model">tende_ai.extraction_master</field>
        <field name="arch" type="xml">
            <form string="Extraction Master">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Financial Documents"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="document_type"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Extraction Fields">
                            <field name="field_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="field_key"/>
                                    <field name="instruction"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Test Extraction">
                            <group>
                                <field name="test_pdf_file" filename="test_pdf_filename"/>
                                <field name="test_pdf_filename" invisible="1"/>
                                <button name="action_run_test_extraction" 
                                        string="Run Test Extraction (Bulk)" 
                                        type="object" 
                                        class="btn-primary" 
                                        icon="fa-flask"
                                        invisible="not test_pdf_file"/>
                            </group>
                            <div class="alert alert-info" role="alert" invisible="test_pdf_file">
                                Upload a PDF file here to test all active extraction fields at once.
                            </div>
                        </page>
                        <page string="Test Results" invisible="not test_result_ids">
                            <field name="test_result_ids" readonly="1">
                                <list>
                                    <field name="field_name"/>
                                    <field name="value"/>
                                    <field name="page"/>
                                    <field name="paragraph" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Highlighted PDF Result" invisible="not test_pdf_highlighted">
                            <field name="test_pdf_highlighted" widget="pdf_viewer" nolabel="1" class="w-100"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_extraction_master" model="ir.actions.act_window">
        <field name="name">Extraction Master</field>
        <field name="res_model">tende_ai.extraction_master</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define extraction groups and fields.
            </p>
        </field>
    </record>
</odoo>
