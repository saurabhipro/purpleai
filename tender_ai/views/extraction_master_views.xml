<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_extraction_master_tree" model="ir.ui.view">
        <field name="name">tende_ai.extraction_master.tree</field>
        <field name="model">tende_ai.extraction_master</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="document_type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_extraction_master_form" model="ir.ui.view">
        <field name="name">tende_ai.extraction_master.form</field>
        <field name="model">tende_ai.extraction_master</field>
        <field name="arch" type="xml">
            <form string="Extraction Master">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Financial Documents"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="document_type"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Extraction Fields">
                            <field name="field_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="field_key"/>
                                    <field name="instruction"/>
                                    <field name="active"/>
                                    <button name="%(action_extraction_test_wizard)d" string="Test" type="action" icon="fa-flask" context="{'default_field_id': id}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_extraction_master" model="ir.actions.act_window">
        <field name="name">Extraction Master</field>
        <field name="res_model">tende_ai.extraction_master</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define extraction groups and fields.
            </p>
        </field>
    </record>
</odoo>
