<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_extraction_master_tree" model="ir.ui.view">
        <field name="name">tende_ai.extraction_master.tree</field>
        <field name="model">tende_ai.extraction_master</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="document_type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_extraction_master_form" model="ir.ui.view">
        <field name="name">tende_ai.extraction_master.form</field>
        <field name="model">tende_ai.extraction_master</field>
        <field name="arch" type="xml">
            <form string="Extraction Master">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Financial Documents"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="document_type"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Extraction Fields">
                            <field name="field_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="field_key"/>
                                    <field name="instruction"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Test Extraction">
                            <group>
                                <field name="test_pdf_file" filename="test_pdf_filename"/>
                                <field name="test_pdf_filename" invisible="1"/>
                                <button name="action_run_test_extraction" 
                                        string="Run Test Extraction (Bulk)" 
                                        type="object" 
                                        class="btn-primary" 
                                        icon="fa-flask"
                                        invisible="not test_pdf_file"/>
                            </group>
                            <div class="alert alert-info" role="alert" invisible="test_pdf_file">
                                Upload a PDF file here to test all active extraction fields at once.
                            </div>
                        </page>
                        <page string="Test Results" invisible="not test_result_ids">
                            <field name="test_result_ids" readonly="1">
                                <list>
                                    <field name="field_name"/>
                                    <field name="value"/>
                                    <field name="page"/>
                                    <field name="paragraph" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Highlighted PDF Result" invisible="not test_pdf_highlighted">
                            <field name="test_pdf_highlighted" widget="pdf_viewer" nolabel="1" class="w-100"/>
                        </page>
                        <page string="Knowledge Base" invisible="not test_result_ids">
                            <group>
                                <field name="kb_state" readonly="1" widget="badge" 
                                       decoration-info="kb_state == 'indexed'"
                                       decoration-warning="kb_state == 'empty'"/>
                            </group>
                            <label for="kb_text" string="Indexed Text Content" invisible="kb_state != 'indexed'"/>
                            <field name="kb_text" readonly="1" class="bg-light p-2" invisible="kb_state != 'indexed'"/>
                            
                            <div class="alert alert-warning" role="alert" invisible="kb_state != 'empty'">
                                <i class="fa fa-exclamation-triangle"/> <b>Document not indexed.</b> The system could not extract searchable text from this PDF. Chat will not be available.
                            </div>

                            <button name="action_clear_kb" string="Clear All Data" 
                                    type="object" class="btn-secondary mt-2" 
                                    confirm="This will clear all test results and indexed text. Proceed?"/>
                        </page>
                        <page string="Doc Chat" invisible="not test_result_ids">
                            <div class="alert alert-danger" role="alert" invisible="kb_state != 'empty'">
                                <i class="fa fa-ban"/> Chat is disabled because no text could be extracted from the document.
                            </div>
                            
                            <!-- Chat Bubble Area -->
                            <div class="o_doc_chat_container border rounded bg-white p-0" style="max-height: 700px; overflow-y: auto;">
                                <field name="chat_message_ids" readonly="1" nolabel="1">
                                    <kanban create="0" delete="0" edit="0" class="o_kanban_chat d-block w-100 p-0 m-0">
                                        <field name="role"/>
                                        <field name="content"/>
                                        <templates>
                                            <t t-name="card">
                                                <div t-attf-class="w-100 d-flex flex-column mb-0 p-3" 
                                                     t-attf-style="background-color: #{record.role.raw_value == 'user' ? 'transparent' : '#f7f7f8'}; border-bottom: 1px solid #e5e5e5;">
                                                    <div class="container" style="max-width: 850px; margin: 0 auto;">
                                                        <div class="d-flex align-items-start gap-3">
                                                            <!-- Avatar/Icon Placeholder -->
                                                            <div t-attf-class="rounded p-2 text-white shadow-sm" 
                                                                 t-attf-style="width: 35px; height: 35px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background-color: #{record.role.raw_value == 'user' ? '#5436DA' : '#10a37f'};">
                                                                <i t-attf-class="fa #{record.role.raw_value == 'user' ? 'fa-user' : 'fa-robot'}"/>
                                                            </div>
                                                            <!-- Text Content -->
                                                            <div class="flex-grow-1 pt-1">
                                                                <div class="small text-muted fw-bold mb-1">
                                                                    <t t-if="record.role.raw_value == 'user'">You</t>
                                                                    <t t-else="">Document Assistant</t>
                                                                </div>
                                                                <div style="white-space: pre-wrap; font-size: 1.1rem; color: #374151; line-height: 1.6;">
                                                                    <field name="content"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </div>

                            <!-- Input Area (ChatGPT Style) -->
                            <div class="mt-auto p-4 bg-white border-top rounded-top shadow-lg" style="position: sticky; bottom: 0; z-index: 10;">
                                <div class="d-flex align-items-center bg-light rounded-pill px-3 py-2 border shadow-sm">
                                    <field name="chat_question" nolabel="1" 
                                           placeholder="Write your message here..."
                                           class="flex-grow-1 border-0 bg-transparent py-2 shadow-none"
                                           style="outline: none !important; box-shadow: none !important; font-size: 1.1rem;"/>
                                    <button name="action_doc_chat" string="" 
                                            type="object" class="btn btn-primary rounded-circle p-0" 
                                            style="width: 45px; height: 45px; line-height: 45px; display: flex; align-items: center; justify-content: center;"
                                            icon="fa-paper-plane"
                                            invisible="not chat_question"/>
                                </div>
                                <div class="d-flex justify-content-start mt-2 px-3">
                                    <button name="action_clear_chat" string="Clear Conversation" 
                                            type="object" class="btn btn-link btn-sm text-secondary p-0" 
                                            icon="fa-trash-o"
                                            confirm="Are you sure you want to clear your chat history?"
                                            invisible="not chat_message_ids"/>
                                </div>
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_extraction_master" model="ir.actions.act_window">
        <field name="name">Extraction Master</field>
        <field name="res_model">tende_ai.extraction_master</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define extraction groups and fields.
            </p>
        </field>
    </record>
</odoo>
