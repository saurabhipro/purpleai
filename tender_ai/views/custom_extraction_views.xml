<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_extraction_tree" model="ir.ui.view">
        <field name="name">tende_ai.custom_extraction.tree</field>
        <field name="model">tende_ai.custom_extraction</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="field_name"/>
                <field name="value"/>
                <field name="source_file"/>
                <field name="source_page"/>
                <field name="source_para" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_custom_extraction_form" model="ir.ui.view">
        <field name="name">tende_ai.custom_extraction.form</field>
        <field name="model">tende_ai.custom_extraction</field>
        <field name="arch" type="xml">
            <form string="Custom Extraction">
                <sheet>
                    <group>
                        <group>
                            <field name="field_name"/>
                            <field name="source_file"/>
                        </group>
                        <group>
                            <field name="source_page"/>
                        </group>
                    </group>
                    <group string="Extracted Value">
                        <field name="value" nolabel="1"/>
                    </group>
                    <group string="Source Paragraph / Context">
                        <field name="source_para" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
