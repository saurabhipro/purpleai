<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_tender_ai" model="ir.ui.view">
        <field name="name">res.config.settings.tender_ai</field>
        <field name="model">res.config.settings</field>
        <field name="priority">50</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Purple AI" string="Purple AI" name="tender_ai">
                    
                    <block title="AI Connection" name="tender_ai_connection_block">
                        <setting id="tender_ai_api_key_setting" help="Enter your Google AI Studio API key.">
                            <label for="tender_ai_api_key" string="Gemini API Key"/>
                            <field name="tender_ai_api_key" password="True" placeholder="AIzaSy..."/>
                            <div class="mt8">
                                <a href="https://aistudio.google.com/app/apikey" target="_blank" class="oe_link">
                                    <i class="oi oi-arrow-right"/> Get API Key from Google AI Studio
                                </a>
                            </div>
                        </setting>
                    </block>

                    <block title="AI Model Configuration" name="tender_ai_model_block">
                        <setting id="tender_ai_model_setting" help="The Gemini model used for all extraction and evaluation.">
                            <label for="tender_ai_default_model" string="Default Model"/>
                            <field name="tender_ai_default_model" class="oe_inline"/>
                            
                            <div class="mt16" invisible="not tender_ai_model_choices">
                                <span class="fw-bold">Available models for your key:</span>
                                <div class="mt4 p-2 bg-light border rounded" style="font-family: monospace; font-size: 0.9em; max-height: 120px; overflow-y: auto;">
                                    <field name="tender_ai_model_choices" readonly="1" nolabel="1"/>
                                </div>
                            </div>
                            
                            <div class="mt16 d-flex gap-2">
                                <button name="action_fetch_available_models"
                                        string="Fetch Available Models"
                                        type="object"
                                        class="btn btn-secondary btn-sm"
                                        title="Connect to Gemini API and load all available models for your key"/>
                                <button name="action_test_model"
                                        string="Test Connection"
                                        type="object"
                                        class="btn btn-secondary btn-sm"
                                        title="Send a test prompt to verify the selected model works"/>
                            </div>
                        </setting>
                    </block>

                    <block title="Token Pricing (INR)" name="tender_ai_pricing_block">
                        <setting id="tender_ai_pricing_setting" help="Cost per 1 million tokens in ₹ INR. Used for job cost analysis.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="tender_ai_input_cost" string="Input (₹ / 1M)" class="col-lg-3 o_light_label"/>
                                    <field name="tender_ai_input_cost" class="oe_inline"/>
                                </div>
                                <div class="row mt8">
                                    <label for="tender_ai_output_cost" string="Output (₹ / 1M)" class="col-lg-3 o_light_label"/>
                                    <field name="tender_ai_output_cost" class="oe_inline"/>
                                </div>
                                <div class="text-muted mt16 small">
                                    <b>Ref:</b> flash-2.5 ≈ ₹13/52 | flash-2.0 ≈ ₹9/35 (Input/Output)
                                </div>
                            </div>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
