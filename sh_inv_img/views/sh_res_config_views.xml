<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_account_invoice_print_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.account.invoice.print</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='invoicing_settings']" position="inside">
                <setting id="sh_print_taxes_options" help="Default Print Tax will be enabled in Invoice Form" title="Default Print Tax will be enabled in Invoice Form View">
                    <field name="sh_print_taxes"/>
                </setting>
                <setting id="sh_print_line_no_options" help="Default Print Serial Number will be enabled in Invoice Form" title="Default Print Serial Number will be enabled in Invoice Form View">
                    <field name="sh_print_line_no"/>
                </setting>
                <setting id="sh_print_product_img_options" help="Default Print Product Image will be enabled &amp; Show Print Image Size in Invoice Form">
                    <field name="sh_print_product_img"/>
                    <div class="content-group">
                        <div class="row mt16">
                            <label for="sh_image_size" class="col-lg-4" invisible="not sh_print_product_img"/>
                            <field name="sh_image_size" invisible="not sh_print_product_img" class="col-lg-4"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>