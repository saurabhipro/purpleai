<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sh_account_invoice_custom_form" model="ir.ui.view">
        <field name="name">sh.account.invoice.custom.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <field name="ref" position="after">
                <field name="sh_dummy" invisible="1" />
                <field name="sh_print_taxes" />
                <field name="sh_print_line_no" />
                <field name="sh_print_product_img" />
                <field name="sh_image_size" default="small" invisible="not sh_print_product_img" />
            </field>
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='product_id']" position="before">
                <field name="ml_number" />
                <field name="sh_product_img" widget="image" readonly="1" />
            </xpath>
            <xpath expr="//field[@name='line_ids']//list//field[@name='account_id']" position="before">
                <field name="ml_number" />
                <field name="sh_product_img" widget="image" readonly="1" />
            </xpath>
        </field>
    </record>
</odoo>
