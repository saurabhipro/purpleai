<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sh_account_invoice_template_custom" inherit_id="account.report_invoice_document">
        <xpath expr="//table[@name='invoice_line_table']//thead//tr[1]//th[@name='th_taxes']" position="attributes">
            <attribute name="t-if">o.sh_print_taxes</attribute>
        </xpath>

        <xpath expr="//table[@name='invoice_line_table']//tbody//tr[1]//td[5]" position="attributes">
            <attribute name="t-if">o.sh_print_taxes</attribute>
        </xpath>

        <xpath expr="//table[@name='invoice_line_table']//thead//tr[1]//th[1]" position="before">
            <th t-if="o.sh_print_line_no">##</th>
            <th t-if="o.sh_print_product_img">Image</th>
        </xpath>

        <xpath expr="//table[@name='invoice_line_table']//tbody//tr[1]//td[1]" position="before">
            <td t-if="o.sh_print_line_no" class="text-center">
                <span t-field="line.ml_number" />
            </td>

            <td t-if="o.sh_print_product_img" class="text-center">
                <img t-if="line.sh_product_img and o.sh_image_size == 'small'" t-att-src="image_data_uri(line.sh_product_img)" style="max-height: auto;max-width: 64px;" />
                <img t-if="line.sh_product_img and o.sh_image_size == 'medium'" t-att-src="image_data_uri(line.sh_product_img)" style="max-height: auto;max-width: 128px;" />
                <img t-if="line.sh_product_img and o.sh_image_size == 'large'" t-att-src="image_data_uri(line.sh_product_img)" style="max-height: auto;max-width: 192px;" />
            </td>
        </xpath>
    </template>
</odoo>
