<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <!-- Inherit Account Move -->
        <record id="inherited_view_move_form" model="ir.ui.view">
            <field name="name">account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button class="oe_stat_button" name="action_open_attachments" type="object" icon="fa-file-text-o">
                        <field string="Attachment Files" name="attachment_count" widget="statinfo" />
                    </button>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
