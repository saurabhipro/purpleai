<odoo>
  <data>
        <record id="account_tax_view_tax_form_id" model="ir.ui.view">
            <field name="inherit_id" ref="account.view_tax_form"/>
            <field name="mode">primary</field>
            <field name="model">account.tax</field>
            <field name="name">account.tax</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="state" options="{'no_create_edit': True, 'no_open': True, 'no_create':True}"/>
                    <field name="city" />
                </xpath>
            </field>
        </record>


        <record id="view_account_tax_tree_inherit" model="ir.ui.view">
            <field name="name">account.tax.tree.inherit</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="state"/>
                    <field name="city" />
                </xpath>
            </field>
        </record> 

      </data>
    </odoo>
