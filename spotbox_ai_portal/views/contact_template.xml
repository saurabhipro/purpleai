<odoo>


    <!-- partner form view -->
    <template id="portal_my_contacts_details_fields">
        
        <div class="container">
            <div class="row">
                <div class="col-2">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" value="person" name="company_type" id="flexRadioPerson" 
                            t-att-checked="partner.company_type == 'person'"/>
                        <label class="form-check-label" for="flexRadioPerson">
                            Individual
                        </label>
                    </div>
                </div>
                <div class="col-2">
                    <div class="form-check">
                        <input class="form-check-input" value="company" type="radio" name="company_type" id="flexRadioCompany" 
                            t-att-checked="partner.company_type == 'company'"/>
                        <label class="form-check-label" for="flexRadioCompany">
                            Company
                        </label>
                    </div>
                </div>
            </div>
            <br/>
            <div class="row">
                <div class="col-5">
                    <div class="form-group">
                        <label for="inputName">Name</label>
                        <input id="inputName" type="text" name="name" class="form-control" t-att-value="name or partner.name"/>
                    </div>
                    <br/>
                    <div class="form-group">
                        <label for="inputPhone">Phone</label>
                        <input id="inputPhone" type="number" name="phone" class="form-control" placeholder="9991110009" t-att-value="phone or partner.phone"/>
                    </div>
                    <br/>

                    <div class="form-group">
                        <label for="inputMobile">Mobile</label>
                        <input id="inputMobile" type="tel" name="mobile" class="form-control" placeholder="9991110009" t-att-value="mobile or partner.mobile"/>
                    </div>
                    <br/>                    
                </div>
                <div class="col-7">
                    <br/>
                    <div class="row">
                        <div class="col-3">
                            <select name="country_id" class="form-select">
                                <option value="">Country...</option>
                                <t t-foreach="countries or []" t-as="country">
                                    <option t-att-value="country.id" t-att-selected="country.id == int(country_id) if country_id else country.id == partner.country_id.id">
                                        <t t-esc="country.name" />
                                    </option>
                                </t>
                            </select>
                        </div>
                        <div class="col-3">
                            <select name="state_id" t-attf-class="form-select">
                                <option value="">select...</option>
                                <t t-foreach="states or []" t-as="state">
                                    <option t-att-value="state.id" t-att-data-country_id="state.country_id.id" t-att-selected="state.id == int(state_id) if state_id else state.id == partner.state_id.id">
                                        <t t-esc="state.name" />
                                    </option>
                                </t>
                            </select>
                        </div>
                        
                        <div class="col-3">
                            <input id="inputZip" name="zipcode" class="form-control" placeholder="PIN eg - 121009" t-att-value="zipcode or partner.zip"/>
                        </div>
                        
                        <div class="col-3">
                                <input id="inputCity" type="text" name="city" class="form-control" placeholder="City" t-att-value="city or partner.city"/>
                        </div>
                    </div>
                    <br/>
                    
        
                    <div class="form-group">
                        <label for="inputStreet">Address</label>
                        <input id="inputStreet" type="text" name="street" class="form-control" placeholder="Address Line 1" t-att-value="street or partner.street"/>
                    </div>
                    <br/>

                    <div class="form-group">
                        <label for="inputStreet2">Address Line 2</label>
                        <input id="inputStreet2" type="text" name="street2" class="form-control" placeholder="Address Line 2" t-att-value="street2 or partner.street2"/>
                    </div>
                    <br/>
                   
                    
                    
                </div>

            </div>
            <hr style="color: #dee2e6:padding-top:2px;    margin-bottom: 0px;"/>
            
            <div class="w-100 h-0">Contacts &amp; Address</div>
            <hr style="color: #dee2e6:padding-top:2px; margin-top: 23px;"/>
            <br/>
            <br/>

            <div> <a class="btn btn-secondary" t-att-href="request.httprequest.url_root + 'my/contact-edit/' + str(partner_id) + '/' + str(partner.id) + '/child_id'" style="">Add Contacts</a></div>
            <br/>

            <div class="container">
                <div class="row">
                    <t t-if="partner.child_ids">
                        <t t-foreach="partner.child_ids" t-as="child">
                            <div class="col-4">
                                <a t-att-href="'/my/contact-edit/' + str(partner_id) + '/' + str(partner.id) + '/' + '/child_id/' + str(child.id)" style="text-decoration: none;">
                                    <div class="p-2 h-100" style="border:1px solid #dee2e6;font-size:13px;line-height: 1.2;cursor: pointer; transition: background-color;">
                                        <p> 
                                            <t t-if="child.name"><span t-esc="child.name"/><br/></t>
                                            <t t-if="child.email"><span t-esc="child.email"/><br/></t>
                                            <t t-if="child.phone"><span t-esc="child.phone"/><br/></t>
                                            <t t-if="child.mobile"><span t-esc="child.mobile"/><br/></t>
                                            <t t-if="child.street"><span t-esc="child.street"/><br/></t>
                                            <t t-if="child.street2"><span t-esc="child.street2"/><br/></t>
                                            <t t-if="child.city"><span t-esc="child.city"/>,</t>
                                            <t t-if="child.zip"><span t-esc="child.zip"/><br/></t>
                                            <t t-if="child.state_id"><span t-esc="child.state_id.name"/>,</t>
                                            <t t-if="child.country_id"><span t-esc="child.country_id.name"/></t>
                                        </p>
                                    </div>
                                </a>
                            </div>
                           
                        </t>
                    </t>
                </div>
            </div>
        </div>
    </template>

    <!-- partner child ids form view -->
    <template id="partner_child_ids_form_template">
        <t t-call="portal.portal_layout">
            <t t-call="spotbox_ai_portal.portal_breadcrumbs"/>
            <br/>
            <div class="container">
                <form t-att-actions="'/my/contacts' + str(partner_id) + '/child_id'" method="post">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="row">
                            <div class="col-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" id="flexRadioContact" name="address_type" value="contact" t-att-checked="child_partner.type == 'contact' if child_partner else 'contact'"/>
                                    <label class="form-check-label" for="flexRadioContact">
                                        Contact
                                    </label>
                                </div>
                            </div>

                            <div class="col-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" id="flexRadioInvoice" name="address_type" value="invoice" t-att-checked="child_partner.type == 'invoice' if child_partner else 'invoice'"/>
                                    <label class="form-check-label" for="flexRadioInvoice">
                                        Invoice Address
                                    </label>
                                </div>
                            </div>
                            
                            <div class="col-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" id="flexRadioDelivery" name="address_type" value="delivery" t-att-checked="child_partner.type == 'delivery' if child_partner else 'delivery'"/>
                                    <label class="form-check-label" for="flexRadioDelivery">
                                        Delivery Address
                                    </label>
                                </div>
                            </div>

                            <div class="col-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" id="flexRadioOther" name="address_type" value="other" t-att-checked="child_partner.type == 'other' if child_partner else 'other'"/>
                                    <label class="form-check-label" for="flexRadioOther">
                                        Other Address
                                    </label>
                                </div>
                            </div>
                    


                    </div>
                    <br/>
                    <div class="row">
                        <div class="col-6">
                            <div class="form-group">
                                <label for="inputName">Name</label>
                                <input id="inputName" type="text" name="name" class="form-control" placeholder="Your Company/Name" t-att-value="child_partner.name if child_partner else name"/>
                            </div>
                            <br/>


                            <div class="form-group">
                                <label for="inputPhone">Phone</label>
                                <input id="inputPhone" type="tel" name="phone" class="form-control" placeholder="9991110009" t-att-value="child_partner.phone if child_partner else phone"/>
                            </div>
                            <br/>
                            <div class="form-group">
                                <label for="inputMobile">Mobile</label>
                                <input id="inputMobile" type="tel" name="mobile" class="form-control" placeholder="9991110009" t-att-value="child_partner.mobile if child_partner else mobile"/>
                            </div>
                            <br/>
                            <div class="form-group">
                                <label for="inputEmail">Email address</label>
                                <input id="inputEmail" type="email" name="email" class="form-control" aria-describedby="emailHelp" placeholder="info@example.com" t-att-value="child_partner.email if child_partner else email"/>
                                <small class="form-text text-muted">We'll never share your email with anyone else.</small>
                            </div>
                            
                        </div>
                        <div class="col-6">
                            
                            <br/>
                            <div class="row">
                                <div class="col">
                                    <select name="country_id" class="form-select">
                                            <option value="">Country...</option>
                                            
                                            <t t-foreach="countries or []" t-as="country">
                                                <!-- If child_partner exists (updated record) -->
                                                <t t-if="child_partner">
                                                    <option 
                                                        t-att-value="country.id" 
                                                        t-att-selected="country.id == int(country_id) if country_id else country.id == child_partner.country_id.id">
                                                        <t t-esc="country.name"/>
                                                    </option>
                                                </t>
                                                
                                                <!-- If child_partner doesn't exist (new record) -->
                                                <t t-else="">
                                                    <option 
                                                        t-att-value="country.id" 
                                                        t-att-selected="country.id == int(country_id) if country_id else ''">
                                                        <t t-esc="country.name"/>
                                                    </option>
                                                </t>
                                            </t>
                                        </select>
                                </div>
                                
                                <div class="col">
                                    
                                    <select name="state_id" class="form-select">
                                        <option value="">select...</option>
                                        
                                        <t t-foreach="states or []" t-as="state">
                                            <!-- If child_partner exists (updated record) -->
                                            <t t-if="child_partner">
                                                <option 
                                                    t-att-value="child_partner.state_id.id or state.id" 
                                                    t-att-selected="state.id == child_partner.state_id.id">
                                                    <t t-esc="state.name"/>
                                                </option>
                                            </t>

                                        
                                            
                                            <!-- If child_partner doesn't exist (new record) -->
                                            <t t-else="">
                                                <option 
                                                    t-att-value="state.id" 
                                                    t-att-data-country_id="state.country_id.id"
                                                    t-att-selected="state.id == int(state_id) if state_id else ''">
                                                    <t t-esc="state.name"/>
                                                </option>
                                            </t>
                                        </t>
                                    </select>
                                </div>
                            </div>
                            <br/>
                            <br/>
                            <div class="row">
                                <div class="col">
                                    <input id="inputZip" name="zipcode" class="form-control" placeholder="90067" t-att-value="child_partner.zip if child_partner else zipcode"/>
                                </div>
                                <div class="col">
                                        <input id="inputCity" type="text" name="city" class="form-control" placeholder="City" t-att-value="child_partner.city if child_partner else city"/>
                                </div>
                            </div>
                            <br/>
                            <div class="form-group">
                                <label for="inputStreet">Address</label>
                                <input id="inputStreet" type="text" name="street" class="form-control" placeholder="Address Line 1" t-att-value="child_partner.street if child_partner else street"/>
                            </div>
                            <br/>

                            <div class="form-group">
                                <label for="inputStreet2">Address Line 2</label>
                                <input id="inputStreet2" type="text" name="street2" class="form-control" placeholder="Address Line 2" t-att-value="child_partner.street2 if child_partner else street2"/>
                            </div>
                           
                            
                           
                        </div>

                    </div>
                    <div class="clearfix text-end mb-5">
                        <a href="/my/" class="btn btn-secondary me-2">
                            Discard
                        </a>
                        <button type="submit" class="btn btn-primary float-end">
                             <t t-if="child_partner.id if child_partner else ''">Edit </t><t t-else="">Create </t>Contact
                        </button>
                    </div>
                </form>
            </div>
        </t>
    </template>

    <!-- Main Contacts page template -->
    <template id="portal_my_contacts_and_address" name="my_contacts">
        <t t-call="portal.portal_layout">
            <t t-call="spotbox_ai_portal.portal_breadcrumbs"/>
            <br/>
            <t t-set="additional_title">Contact Details</t>
            <div class="container w-100">
                <form t-att-actions="'/my/contacts/' + str(partner.id) + '/' + str(edit_partner_id)" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <div class="row o_portal_details">
                        <div class="col-lg-12">
                            <div class="row">
                                <t t-call="spotbox_ai_portal.portal_my_contacts_details_fields"/>
                                <input type="hidden" name="redirect" t-att-value="redirect"/>
                            </div>
                            <div class="clearfix text-end mb-5">
                                <a href="/my/" class="btn btn-secondary me-2">
                                    Discard
                                </a>
                                <button type="submit" class="btn btn-primary float-end">
                                    Edit Contacts
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </t>
    </template>


    <!-- Customer List View -->

    <template id="portal_my_contacts_tree_view" name="My Order List">
        <t t-call="portal.portal_layout">
            <t t-call="spotbox_ai_portal.portal_breadcrumbs"/>
            <br/>
            <div>
                <a t-att-href="'/my/contact-create/' + str(partner_id)" class="btn btn-primary me-2">Create Your Company</a>
            </div>
            <br/>
            <style>
                .clickable-row {
                    cursor: pointer; 
                    transition: background-color 0.3s ease;
                }

                .clickable-row:hover {
                    background-color: #f0f0f0;
                }
            </style>
            <div class="container w-100">
                <table class="table">
                    <thead>
                        <tr> 
                            <th scope="col">Name</th>
                            <th scope="col">Phone</th>
                            <th scope="col">Email</th>
                            <th scope="col">City</th>
                            <th scope="col">State</th>
                            <th scope="col">Country</th>                           
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="partners" t-as="partner">
                           <tr t-att-data-url="'/my/contact-edit/' + str(partner_id) + '/' + str(partner.id)" onclick="window.location.href=this.getAttribute('data-url')" class="clickable-row">
                                <td style="width:10%"><t t-esc="partner.name"/></td>
                                <td style="width:10%"><t t-esc="partner.mobile"/></td>
                                <td style="width:10%"><t t-esc="partner.email"/></td>
                                <td style="width:10%"><t t-esc="partner.city"/></td>
                                <td style="width:10%"><t t-esc="partner.state_id.name"/></td>
                                <td style="width:10%"><t t-esc="partner.country_id.name"/></td>
                                <td style="width:11%"><a t-att-href="'/my/order/' + str(partner_id) + '/' + str(partner.id)" class="btn btn-primary me-2">Create Order</a></td>
                                <td style="width:11%"><a t-att-href="'/my/order-list/' + str(partner_id) + '/' + str(partner.id)" class="btn btn-primary me-2">View Orders</a></td>
                            </tr>
                        </t>
                    </tbody>

                </table>
            </div>
        </t>
    </template>


    <!-- Customer Creation -->
