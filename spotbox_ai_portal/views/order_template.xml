<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <!-- Order form view -->
    <template id="portal_my_order_details_fields">
        <div class="container">
            <div class="row">
                <div class="col-sm">
                    <div class="form-group">
                        <label for="inputName">Customer Name</label>
                        <input id="inputName" type="text" name="name" class="form-control" placeholder="Your Company/Name" t-att-value="name or partner.name" readonly="1"/>
                    </div>
                </div>
                
                <div class="col-sm">
                    <t t-if="partner.child_ids">
                        <t t-foreach="partner.child_ids" t-as="child">
                            <div class="form-group">
                                <label for="inputPhone">
                                    <t t-if="child.type == 'contact'">Contact</t>
                                    <t t-elif="child.type == 'invoice'">Invoice Address</t>
                                    <t t-elif="child.type == 'delivery'">Delivery Address</t>
                                    <t t-elif="child.type == 'other'">Other</t>
                                </label>
                                <input id="inputPhone" type="text" name="phone" class="form-control" placeholder="" t-att-value="child.name" readonly="1"/>
                            </div>
                        </t>
                    </t>
                </div>
            </div>
            <br/>
         
            <br/>
            <ul class="nav nav-tabs" id="myTab" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" id="home-tab" data-toggle="tab" href="#home" role="tab" aria-controls="home" aria-selected="true">Order Lines</a>
                </li>
               
                </ul>
                <div class="tab-content" id="myTabContent">
                <div class="tab-pane fade show active" id="home" role="tabpanel" aria-labelledby="home-tab">
                    <div class="container w-100">
                        <table class="table">
                            <thead>
                                <tr> 
                                    <th scope="col">Product</th>
                                    <th scope="col">Image</th>
                                    <th scope="col">Description</th>
                                    <th scope="col">Quantity</th>
                                    <th scope="col">Unit Price</th>
                                    <!-- <th scope="col">Taxes</th>
                                    <th scope="col">Tax Exclude</th>
                                    <th scope="col">Tax Include</th> -->
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="portal_order_lines" t-as="pol">
                                    <tr>
                                        
                                        <td style="width:20%"><t t-esc="pol.product_template_id.name"/></td>
                                        <td style="width:10%">
                                            <t t-if="pol.order_line_image">
                                                <img style="width:25%;" t-att-src="'data:image/png;base64,' + pol.order_line_image.decode('utf-8')"/>
                                            </t>
                                        </td>
                                        <td style="width:10%"><t t-esc="pol.name"/></td>
                                        <td style="width:10%">
                                            <input name="pol_product_qty[]" type="number" t-att-value="pol.product_uom_qty"/>
                                        </td>

                                        <td style="width:10%"><t t-esc="pol.price_unit"/></td>
                                        <!-- <td style="width:10%"><t t-foreach="pol.product_template_id.taxes_id" t-as="tax"><t t-esc="tax.name"/></t></td>
                                        <td style="width:10%"><t t-esc="pol.name"/></td>
                                        <td style="width:10%"><t t-esc="pol.name"/></td> -->
                                        <td style="width:10%" type="hidden">
                                            <!-- Make the name a list by adding [] to the name attribute -->
                                            <input name="pol_product_id[]" type="hidden" t-att-value="pol.product_template_id.id"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>

                        </table>
                    </div>
                </div>
                </div>
            
        </div>
    </template>

    <!-- order main form tempalte  -->
    <template id="portal_my_orders_and_address">
        <t t-call="portal.portal_layout">
            <br/>
            <t t-call="spotbox_ai_portal.portal_breadcrumbs"/>
            <br/>
            <t t-set="additional_title">Order Details</t>
            <form t-att-actions="'/my/orders/' + str(partner.id) + '/' + str(edit_partner_id)" method="post">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <div class="row o_portal_details">
                    <div class="col-lg-12">
                        <div class="row">
                            <t t-call="spotbox_ai_portal.portal_my_order_details_fields"/>
                            <input type="hidden" name="redirect" t-att-value="redirect"/>
                        </div>
                        <div class="clearfix text-end mb-5">
                            <a href="/my/" class="btn btn-secondary me-2">
                                Discard
                            </a>
                            <button type="submit" class="btn btn-primary float-end">
                                Create Order
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </t>
    </template>


    <!-- Order Tree view Template -->
    <template id="portal_my_order_tree_view" name="My Order List">
        <t t-call="portal.portal_layout">
            <t t-call="spotbox_ai_portal.portal_breadcrumbs"/>
            <br/>
            <div>
                <t t-if="edit_partner_id"><a t-att-href="'/my/order/'+str(partner_id) + '/' + str(edit_partner_id)" class="btn btn-primary me-2">Create Order</a></t>
            </div>
            <br/>
            <style>
                .clickable-row {
                    cursor: pointer; /* Changes cursor to hand pointer */
                    transition: background-color 0.3s ease; /* Smooth color transition */
                }

            .clickable-row:hover {
                background-color: #f0f0f0; /* Change this color as needed */
            }
            </style>
            <div class="container w-100">
                <table class="table">
                    <thead>
                        <tr> 
                            <th scope="col">Number</th>
                            <th scope="col">Quotation Ref.</th>
                            <th scope="col">Create Date</th>
                            <th scope="col">Customer</th>
                            <th scope="col">Status</th>
                            <!-- <th scope="col">Action</th> -->

                           
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="sale_orders" t-as="order">
                           <tr t-att-data-url="'/my/order-edit/' + '/' + str(partner_id) + '/' + str(edit_partner_id) + '/' + str(order.id) if edit_partner_id else '/my/order-list-all/order-edit/' + str(partner_id) + '/' + str(order.partner_id.id) + '/' + str(order.id)" onclick="window.location.href=this.getAttribute('data-url')" class="clickable-row">
                                <td style="width:10%"><t t-esc="order.name"/></td>
                                <td style="width:10%"><t t-esc="order.quotation_ref"/></td>
                                <td style="width:10%">
                                    <t t-esc="order.create_date" t-field-options='{"format": "MM/dd/yyyy"}'/>                                </td>                                
                                <td style="width:10%"><t t-esc="order.partner_id.name"/></td>
                                <td style="width:10%"><t t-if="order.state == 'draft'">Quotation</t><t t-elif="order.state == 'sent'">Quotation Sent</t><t t-elif="order.state == 'sale'">Sale Order</t></td>
                                <!-- <td style="width:10%"><a t-att-href="'/my/order/'+str(partner_id)" class="btn btn-primary me-2">Edit</a></td> -->
                            </tr>
                        </t>
                    </tbody>

                </table>
            </div>
        </t>
    </template>


    <!-- order Edit Child Template -->
    <template id="portal_my_order_details_fields_for_edit" name="My Order Edit">
        
        <div class="container">
            
            

            <div class="row">
                <div class="col-6">
                    <div class="form-group">
                        <label for="inputName">Customer Name</label>
                        <input id="inputName" type="text" name="name" class="form-control" t-att-value="name or sale_order.partner_id.name" readonly="1"/>
                    </div>
                </div>

                <div class="col-3">
                    <t t-if="sale_order.partner_invoice_id">
                    <div class="form-group">
                        <label for="inputName">Invoice Address</label>
                        <input id="inputName" type="text" name="name" class="form-control" t-att-value="name or sale_order.partner_invoice_id.name" readonly="1"/>
                    </div>
                    </t>
                </div>

                <div class="col-3">
                    <t t-if="sale_order.partner_shipping_id">
                        <div class="form-group">
                            <label for="inputName">Shipping Address</label>
                            <input id="inputName" type="text" name="name" class="form-control" t-att-value="name or sale_order.partner_shipping_id.name" readonly="1"/>
                        </div>
                    </t>

                </div>

            </div>

            <div class="row">

                <div class="col-6">
                    <t t-if="sale_order.partner_id.street">
                        <div class="form-group">
                            <label for="street">Address</label>
                            <input id="street" type="text" name="street" class="form-control" t-att-value="street or sale_order.partner_id.street if sale_order else ''" readonly="1"/>
                        </div>
                    </t>
                </div>
                

                <div class="col-3">
                    <t t-if="sale_order.date_order">
                    <div class="form-group">
                        <label for="date_order">Order Date</label>
                        <input id="date_order" type="datetime" name="date_order" class="form-control" t-att-value="date_order or sale_order.date_order if sale_order else ''" readonly="1"/>
                    </div>
                    </t>
                </div>

                <div class="col-3">
                    <t t-if="sale_order.date_order">
                    <div class="form-group">
                        <label for="status">Status</label>
                        <t t-if="sale_order.state == 'draft'">
                            <input id="status" type="datetime" name="status" class="form-control" t-att-value="status or 'Quotation'" readonly="1"/>
                        </t>
                        <t t-elif="sale_order.state == 'sent'">
                            <input id="status" type="datetime" name="status" class="form-control" t-att-value="status or 'Quotation Sent'" readonly="1"/>
                        </t>
                        <t t-elif="sale_order.state == 'sale'">
                            <input id="status" type="datetime" name="status" class="form-control" t-att-value="status or 'Sale Order'" readonly="1"/>
                        </t>
                    </div>
                    </t>
                </div>
                
            </div>

            <div class="row">
                <div class="col-6">
                    <t t-if="sale_order.partner_id.street2">
                    <div class="form-group">
                        <input id="street2" type="text" name="street2" class="form-control" t-att-value="street2 or sale_order.partner_id.street2 if sale_order else ''" readonly="1"/>
                    </div>
                    </t>
                </div>

                
               
            </div>

            
            <div class="row">
                <div class="col-3">
                    <t t-if="sale_order.partner_id.city">
                        <div class="form-group">
                            <input id="street" type="text" name="city" class="form-control" t-att-value="city or sale_order.partner_id.city if sale_order else ''" readonly="1"/>
                        </div>
                    </t>
                </div>

                <div class="col-3">
                    <t t-if="sale_order.partner_id.zip">
                        <div class="form-group">
                            <input id="street" name="zipcode" class="form-control" t-att-value="zipcode or sale_order.partner_id.zip if sale_order else ''" readonly="1"/>
                        </div>
                    </t>                
                </div>



            </div>

            <div class="row">
                <div class="col-3">
                    <t t-if="sale_order.partner_id.state_id">
                        <div class="form-group">
                            <input id="street" type="text" name="state_id" class="form-control" t-att-value="state_id or sale_order.partner_id.state_id.name if sale_order else ''" readonly="1"/>
                        </div>
                    </t>
                </div>
                <div class="col-3">
                    <t t-if="sale_order.partner_id.country_id">
                        <div class="form-group">
                            <input id="street" type="text" name="country_id" class="form-control" t-att-value="country_id or sale_order.partner_id.country_id.name if sale_order else ''" readonly="1"/>
                        </div>
                    </t>
                </div>
            </div>
           
             <br/>


            <nav>
                <div class="nav nav-tabs" id="nav-tab" role="tablist">
                    <a class="nav-item nav-link active" id="nav-home-tab" data-toggle="tab" href="#nav-home" role="tab" aria-controls="nav-home" aria-selected="true">Order Lines</a>
                </div>
            </nav>
            <div class="tab-content" id="nav-tabContent">
                <div class="tab-pane fade show active" id="nav-home" role="tabpanel" aria-labelledby="nav-home-tab">
                    <div class="container w-100">
                        <table class="table">
                            <thead>
                                <tr> 
                                    <th scope="col">Product</th>
                                    <th scope="col">Image</th>
                                    <th scope="col">Description</th>
                                    <th scope="col-right">Quantity</th>
                                    <th scope="col-right">Unit Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="sale_order.order_line" t-as="line">
                                    <tr>
                                        <td style="width:20%"><t t-esc="line.product_template_id.name"/></td>
                                        <td style="width:10%">
                                            <t t-if="line.order_line_image">
                                                <img style="width:25%;" t-att-src="'data:image/png;base64,' + line.order_line_image.decode('utf-8')"/>
                                            </t>
                                        </td>
                                        <td style="width:20%"><t t-esc="line.name"/></td>
                                    
                                        <td t-if="sale_order.state == 'draft'" style="width:10%">
                                            <input name="pol_product_qty[]" type="number" t-att-value="line.product_uom_qty if line.product_uom_qty else '0.0'"/>
                                        </td>

                                        <td t-else="" style="width:10%;text-align:right;">
                                            <t t-esc="line.product_uom_qty"/>
                                        </td>

                                        <td style="width:10%;text-align:right;"><t t-esc="line.price_unit"/></td>
                                        <td style="width:10%" type="hidden">
                                            <!-- Use product_id instead of product_template_id -->
                                            <input name="pol_product_id[]" type="hidden" t-att-value="line.product_id.id"/>
                                        </td>
                                    </tr>
                                </t>
                
                                <!-- order_id(sale.order) = [('partner_id','=',partner_id)] -->

                            </tbody>

                        </table>
                    </div>
                </div>


            </div>
            
        </div>
    </template>

    <!-- order Edit Parent Template  -->
    <template id="portal_edit_my_order_form">
        <t t-call="portal.portal_layout">
            <t t-call="spotbox_ai_portal.portal_breadcrumbs"/>
            <br/>
            <t t-set="additional_title">Order Details</t>
            <form actions="'/my/order-edit/' + str(partner_id) + '/' + str(edit_partner_id) + '/' + str(order_id)" method="post">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <div class="row o_portal_details">
                    <div class="col-lg">
                        <div class="row">
                            <t t-call="spotbox_ai_portal.portal_my_order_details_fields_for_edit"/>
                            <input type="hidden" name="redirect" t-att-value="redirect"/>
                        </div>
                        <t t-if="sale_order.state == 'draft'">
                            <div class="clearfix text-end mb-5">
                                <a href="/my/" class="btn btn-secondary me-2">
                                    Discard
                                </a>
                                <button type="submit" class="btn btn-primary float-end">
                                    Edit Order
                                </button>
                            </div>
                        </t>
                        
                    </div>
                </div>
            </form>
        </t>
    </template>
</odoo>