<odoo>
    <data>
        <record id="tree_view_portal_sale_order_line" model="ir.ui.view">
            <field name="name">portal.order.line.tree</field>
            <field name="model">portal.order.line</field>
                <field name="arch" type="xml">
                    <list>
                        <field name="sequence" widget="handle"/>
                        <field name="product_template_id"/>
                        <field name="name"/>
                        <field name="product_uom_qty"/>
                        <field name="product_uom"/>
                        <field name="price_unit"/>
                        <field name="active"/>
                    </list>
                </field>
        </record>

        <record id="view_portal_sale_order_line" model="ir.ui.view">
            <field name="name">portal.order.line.form</field>
            <field name="model">portal.order.line</field>
                <field name="arch" type="xml">
                    <form string="Sale Order Lines">
                        <sheet>
                            <field name="order_line_image" widget="image" class="oe_avatar"/>
                            <group>
                                <group>
                                    <field name="active"/>
                                    <field name="product_template_id"/>
                                    <field name="name"/>
                                </group>
                                <group>
                                    <field name="product_uom_qty"/>
                                    <field name="product_uom"/>
                                    <field name="price_unit"/>
                                </group>
                                
                            </group>
                        </sheet>
                    </form>
                </field>
        </record>
    </data>
</odoo>