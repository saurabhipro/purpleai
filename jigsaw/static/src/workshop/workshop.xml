<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="jigsaw.Workshop" owl="1">
        <div class="jigsaw-workshop h-100 w-100 d-flex flex-column bg-slate-50">
            <!-- New Modular Header -->
            <WorkshopHeader 
                state="state"
                onClose="() => this.onClose()"
                onExport="() => this.exportExcel()"
                onOrganize="() => this.organizeLayout()"
                onFit="() => this.fitToScreen()"
                onAddEntity="() => this.onAddEntity()"
                toggleSidebar="(sidebar) => this.toggleSidebar(sidebar)"
                toggleOwnershipMenu="() => this.toggleOwnershipMenu()"
                setOwnershipDirection="(dir) => this.setOwnershipDirection(dir)"
                clearOwnershipFilter="() => this.clearOwnershipFilter()"
                updateOwnershipFilter="() => this.updateOwnershipFilter()"
                onZoomIn="() => this.onZoomIn()"
                onZoomOut="() => this.onZoomOut()"
            />

            <!-- Tags Bar (Kept simple for now) -->
            <div class="jigsaw-tags-bar d-flex align-items-center px-3 py-2 bg-white border-bottom small position-relative z-index-10">
                <div class="d-flex align-items-center dropdown">
                    <button class="btn btn-sm btn-light border-slate-300 rounded d-flex align-items-center gap-2 me-3 shadow-sm bg-white" t-on-click="() => this.state.showFilterMenu = !this.state.showFilterMenu">
                        Fund Family is <span class="badge bg-slate-100 text-slate-700 border ms-1">Management <i class="fa fa-times ms-1"></i></span>
                    </button>
                </div>
                <div class="tag-item bg-white cursor-pointer fw-bold border-slate-300 shadow-sm me-3 px-2 py-1 rounded">
                    + Add filter
                </div>
                <div class="text-indigo-600 fw-bold cursor-pointer ms-auto">
                    <i class="fa fa-times me-1"></i> Clear Filters
                </div>
            </div>

            <div class="workshop-body d-flex flex-grow-1 overflow-hidden">
                <!-- Main Canvas Component Wrapper for Interactions -->
                <div t-ref="canvas" class="flex-grow-1 overflow-hidden h-100 position-relative">
                    <WorkshopCanvas 
                        state="state"
                        getLinkInfo="(link) => this.getLinkInfo(link)"
                        isNodeFilteredOut="(node) => this.isNodeFilteredOut(node)"
                        isLinkFilteredOut="(link) => this.isLinkFilteredOut(link)"
                        onEditEntity="(id) => this.onEditEntity(id)"
                        onDeleteEntity="(id) => this.deleteEntity(id)"
                        onLine="(id) => this.onLineClick(id)"
                        onComment="(id) => this.state.showCommentInputForNode = id"
                        onCommentKeydown="(ev) => this.onCommentKeydown(ev)"
                        hasComments="(id) => this.hasComments(id)"
                        submitComment="() => this.submitComment()"
                    />
                </div>

                <!-- Right Sidebar Component -->
                <WorkshopSidebar 
                    state="state"
                    toggleSidebar="(sidebar) => this.toggleSidebar(sidebar)"
                    toggleDataTab="(tab) => this.toggleDataTab(tab)"
                    onUpdateProperty="(id, field, val) => this.updateEntityProperty(id, field, val)"
                    onDeleteEntity="(id) => this.deleteEntity(id)"
                    onAddChild="(id) => this.onAddChild(id)"
                    onAddParent="(id) => this.onAddParent(id)"
                    onSelectNode="(id) => this.onSelectNode(id)"
                />
            </div>

            <WorkshopModals 
                state="state"
                onSaveEntity="() => this.saveEntity()"
                onSaveLink="() => this.saveLink()"
                onDeleteLink="(link) => this.deleteLink(link)"
                onCloseEntityModal="() => this.onCloseEntityModal()"
                onCloseLinkModal="() => this.onCloseLinkModal()"
                onAddChild="(id) => this.onAddChild(id)"
                onAddParent="(id) => this.onAddParent(id)"
            />

            <!-- Context Menu (Keeping it here as it's simple absolute position) -->
            <div t-if="state.contextMenu.visible" 
                 class="jigsaw-context-menu position-fixed bg-white shadow-lg border border-slate-200 rounded py-2"
                 t-att-style="'top: ' + state.contextMenu.y + 'px; left: ' + state.contextMenu.x + 'px; z-index: 1060; width: 180px; font-size: 0.8rem; pointer-events: auto;'"
                t-on-click.stop="">
                 
                <div class="dropdown-item d-flex justify-content-between align-items-center cursor-pointer py-1 px-3 hover-bg-slate-100" t-on-click="() => this.onEditEntity(state.contextMenu.nodeId)">
                    <span>Edit Entity</span>
                    <i class="fa fa-pencil text-slate-400"></i>
                </div>
                <div class="dropdown-item d-flex justify-content-between align-items-center cursor-pointer py-1 px-3 hover-bg-red-50 text-danger" t-on-click="() => this.deleteEntity(state.contextMenu.nodeId)">
                    <span>Delete Entity</span>
                    <i class="fa fa-trash"></i>
                </div>
                <div class="border-top my-1"></div>
                <div class="dropdown-item d-flex align-items-center gap-2 cursor-pointer py-1 px-3 hover-bg-slate-100 text-slate-600"
                    t-on-click="() => this.onAddChild(state.contextMenu.nodeId)">
                    <i class="fa fa-plus-circle text-success"></i> Add Child
                </div>
                <div class="dropdown-item d-flex align-items-center gap-2 cursor-pointer py-1 px-3 hover-bg-slate-100 text-slate-600 border-bottom mb-1 pb-2"
                    t-on-click="() => this.onAddParent(state.contextMenu.nodeId)">
                    <i class="fa fa-plus-circle text-primary"></i> Add Parent
                </div>
                <div class="dropdown-item d-flex align-items-center gap-2 cursor-pointer py-1 px-3 hover-bg-slate-100 text-slate-600">
                    <i class="fa fa-users"></i> Select Ownership
                </div>
            </div>
        </div>
    </t>
</templates>
