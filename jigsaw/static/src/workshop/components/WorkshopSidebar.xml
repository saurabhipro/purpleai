<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="jigsaw.WorkshopSidebar" owl="1">
        <div class="right-sidebar bg-white border-start shadow-sm d-flex flex-column" style="width: 320px;" t-if="props.state.activeSidebar">
            
            <!-- Comments Header -->
            <div class="sidebar-header p-3 border-bottom d-flex justify-content-between align-items-center" t-if="props.state.activeSidebar === 'comments'">
                <h6 class="m-0 fw-bold">Comments</h6>
                <i class="fa fa-times text-slate-400 cursor-pointer hover-text-slate-700" t-on-click="() => props.toggleSidebar(null)"></i>
            </div>

            <!-- Data Header (Node Selected) -->
            <div class="sidebar-header pt-3 px-3 d-flex flex-column" t-if="props.state.activeSidebar === 'data' and props.state.selectedNodeIds.length > 0">
                <t t-set="isSingle" t-value="props.state.selectedNodeIds.length === 1"/>
                <t t-set="selNodeId" t-value="props.state.selectedNodeIds[0]" />
                <t t-set="selNode" t-value="isSingle ? props.state.nodes.find(n => n.id === selNodeId) : null"/>
                
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="m-0 fw-bold d-flex align-items-center gap-2">
                        <t t-if="selNode">
                            <t t-esc="selNode.name" /> <i class="fa fa-unlock-alt text-slate-300 ms-1"></i>
                        </t>
                        <t t-elif="!isSingle">
                            <t t-esc="props.state.selectedNodeIds.length" /> Selected <i class="fa fa-lock text-slate-300 ms-1"></i>
                        </t>
                    </h6>
                    <i class="fa fa-times text-slate-400 cursor-pointer hover-text-slate-700 fs-5" t-on-click="() => props.toggleSidebar(null)"></i>
                </div>
                
                <!-- Tabs -->
                <div class="d-flex border-bottom text-slate-500" style="font-size: 0.85rem;" t-if="isSingle">
                    <div class="flex-grow-1 text-center pb-2 cursor-pointer position-relative hover-text-indigo-600" 
                         t-att-class="{ 'text-indigo-600 fw-bold': props.state.activeDataTab === 'properties' }"
                        t-on-click="() => props.toggleDataTab('properties')">
                        Properties
                        <div t-if="props.state.activeDataTab === 'properties'" class="position-absolute bottom-0 start-0 w-100 bg-indigo-600" style="height: 2px;"></div>
                    </div>
                    <div class="flex-grow-1 text-center pb-2 cursor-pointer position-relative hover-text-indigo-600"
                         t-att-class="{ 'text-indigo-600 fw-bold': props.state.activeDataTab === 'relationships' }"
                        t-on-click="() => props.toggleDataTab('relationships')">
                        Relationships
                        <div t-if="props.state.activeDataTab === 'relationships'" class="position-absolute bottom-0 start-0 w-100 bg-indigo-600" style="height: 2px;"></div>
                    </div>
                    <div class="flex-grow-1 text-center pb-2 cursor-pointer position-relative hover-text-indigo-600"
                         t-att-class="{ 'text-indigo-600 fw-bold': props.state.activeDataTab === 'files' }"
                        t-on-click="() => props.toggleDataTab('files')">
                        Files
                        <div t-if="props.state.activeDataTab === 'files'" class="position-absolute bottom-0 start-0 w-100 bg-indigo-600" style="height: 2px;"></div>
                    </div>
                </div>
            </div>

            <!-- Data Header (Empty) -->
            <div class="sidebar-header p-3 border-bottom d-flex justify-content-between align-items-center" t-if="props.state.activeSidebar === 'data' and props.state.selectedNodeIds.length === 0">
                <h6 class="m-0 fw-bold">Properties</h6>
                <i class="fa fa-times text-slate-400 cursor-pointer hover-text-slate-700" t-on-click="() => props.toggleSidebar(null)"></i>
            </div>
            
            <!-- Comments Sidebar Content -->
            <div class="sidebar-content p-3 flex-grow-1 overflow-auto bg-slate-50" t-if="props.state.activeSidebar === 'comments'">
                <div class="d-flex justify-content-between align-items-center mb-2 px-1">
                    <label class="form-check-label text-slate-700 fw-bold small flex-grow-1" for="showCommToggle">Show comments</label>
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input bg-indigo-500 border-indigo-500 cursor-pointer" type="checkbox" id="showCommToggle" t-model="props.state.showAllComments" />
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-4 px-1 pb-3 border-bottom">
                    <label class="form-check-label text-slate-500 small flex-grow-1" for="showResToggle">Show resolved comments</label>
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input cursor-pointer" type="checkbox" id="showResToggle" t-model="props.state.showResolvedComments" />
                    </div>
                </div>

                <!-- Comments List -->
                <t t-if="props.state.comments.length > 0">
                    <t t-foreach="props.state.comments" t-as="comment" t-key="comment.id">
                        <div class="comment-card bg-indigo-50 border border-indigo-100 rounded-3 p-3 shadow-sm mb-3">
                            <div class="small fw-bold text-slate-400 mb-2">Comment #<t t-esc="comment_index + 1"/></div>
                            <div class="d-flex align-items-start gap-2">
                                <div class="bg-indigo-500 text-white rounded-circle d-flex align-items-center justify-content-center fw-bold flex-shrink-0" style="width: 26px; height: 26px; font-size: 10px;">
                                    <t t-esc="comment.initials"/>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <span class="fw-bold fs-6 text-slate-800" style="line-height:1.2;"><t t-esc="comment.author"/></span>
                                        <span class="text-slate-400 text-end" style="font-size: 0.65rem;"><t t-esc="comment.time" /></span>
                                    </div>
                                    <div class="text-slate-700 small mb-2" style="font-size: 0.85rem;">
                                        <t t-esc="comment.text"/>
                                    </div>
                                    <div class="text-indigo-600 fw-bold cursor-pointer" style="font-size: 0.75rem;">
                                        <t t-esc="comment.replies"/> reply
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
                <div t-else="" class="text-center py-5 text-muted small">
                    No comments yet.
                </div>
            </div>

            <!-- Data Sidebar Content -->
            <div class="sidebar-content pb-3 flex-grow-1 overflow-auto" t-if="props.state.activeSidebar === 'data'">
                <div t-if="props.state.selectedNodeIds.length > 0" class="selected-node-info d-flex flex-column">
                    <t t-set="isSingle" t-value="props.state.selectedNodeIds.length === 1"/>
                    <t t-set="selNodeId" t-value="props.state.selectedNodeIds[0]"/>
                    <t t-set="selNode" t-value="isSingle ? props.state.nodes.find(n => n.id === selNodeId) : null"/>
                    
                    <!-- PROPERTIES TAB -->
                    <div t-if="props.state.activeDataTab === 'properties' and selNode" class="p-3">
                        <!-- Entity Type -->
                        <div class="d-flex border-bottom py-3 align-items-center">
                            <div class="small fw-bold text-slate-500" style="width: 110px;">Entity Type</div>
                            <div class="flex-grow-1 d-flex justify-content-between align-items-center cursor-pointer text-slate-700 small">
                                <span><t t-esc="selNode.type === 'company' ? 'Corporate' : (selNode.type === 'fund' ? 'Fund' : selNode.type === 'trust' ? 'Trust' : selNode.type === 'individual' ? 'Individual' : 'Asset')"/></span>
                                <i class="fa fa-caret-down text-slate-400"></i>
                            </div>
                        </div>
                        <!-- Jurisdiction -->
                        <div class="d-flex border-bottom py-3 align-items-center">
                            <div class="small fw-bold text-slate-500" style="width: 110px;">Jurisdiction</div>
                            <div class="flex-grow-1 d-flex justify-content-between align-items-center cursor-pointer text-slate-700 small">
                                <div class="d-flex align-items-center gap-2">
                                    <img t-if="selNode.country" t-att-src="'/base/static/img/country_flags/' + selNode.country.toLowerCase() + '.png'" style="width: 16px; height: 11px; object-fit: cover;" class="border border-slate-300"/>
                                    <span><t t-esc="selNode.jurisdiction || 'Cayman Islands'"/></span>
                                </div>
                                <i class="fa fa-caret-down text-slate-400"></i>
                            </div>
                        </div>
                        <!-- Commitment Amount -->
                        <div class="d-flex border-bottom py-3 align-items-center">
                            <div class="small fw-bold text-slate-500" style="width: 110px;">Commitment<br/>Amount</div>
                            <div class="flex-grow-1">
                                <input type="number" class="form-control form-control-sm border-0 border-bottom border-indigo-200 bg-transparent text-slate-700 fw-bold px-1" 
                                       t-att-value="selNode.commitment_amount || 0"
                                       t-on-change="(e) => props.onUpdateProperty(selNode.id, 'commitment_amount', parseFloat(e.target.value))" />
                            </div>
                        </div>
                        <!-- Capital Contributed -->
                        <div class="d-flex border-bottom py-3 align-items-center">
                            <div class="small fw-bold text-slate-500" style="width: 110px;">Capital<br/>Contributed</div>
                            <div class="flex-grow-1">
                                <input type="number" class="form-control form-control-sm border-0 border-bottom border-indigo-200 bg-transparent text-slate-700 fw-bold px-1" 
                                       t-att-value="selNode.capital_contributed || 0"
                                       t-on-change="(e) => props.onUpdateProperty(selNode.id, 'capital_contributed', parseFloat(e.target.value))" />
                            </div>
                        </div>
                        <!-- Registration Number -->
                        <div class="d-flex border-bottom py-3 align-items-center">
                            <div class="small fw-bold text-slate-500" style="width: 110px;">Registration<br/>Number</div>
                            <div class="flex-grow-1">
                                 <input type="text" class="form-control form-control-sm border-0 border-bottom border-indigo-200 bg-transparent text-slate-700 fw-bold px-1" 
                                       t-att-value="selNode.registration_no || ''"
                                       t-on-change="(e) => props.onUpdateProperty(selNode.id, 'registration_no', e.target.value)" />
                            </div>
                        </div>
                        <!-- Tax ID -->
                        <div class="d-flex border-bottom py-3 align-items-center">
                            <div class="small fw-bold text-slate-500" style="width: 110px;">Tax ID Number</div>
                            <div class="flex-grow-1">
                                 <input type="text" class="form-control form-control-sm border-0 border-bottom border-indigo-200 bg-transparent text-slate-700 fw-bold px-1" 
                                       t-att-value="selNode.tax_id_number || ''"
                                       t-on-change="(e) => props.onUpdateProperty(selNode.id, 'tax_id_number', e.target.value)" />
                            </div>
                        </div>
                        <!-- Registered Office -->
                        <div class="d-flex border-bottom py-3 align-items-center">
                            <div class="small fw-bold text-slate-500" style="width: 110px;">Registered<br/>Office</div>
                            <div class="flex-grow-1">
                                 <input type="text" class="form-control form-control-sm border-0 border-bottom border-indigo-200 bg-transparent text-slate-700 small px-1" 
                                       t-att-value="selNode.registered_office || ''"
                                       t-on-change="(e) => props.onUpdateProperty(selNode.id, 'registered_office', e.target.value)" />
                            </div>
                        </div>
                        <!-- Formation Date -->
                        <div class="d-flex border-bottom py-3 align-items-center">
                            <div class="small fw-bold text-slate-500" style="width: 110px;">Formation /<br/>Incorporation Date</div>
                            <div class="flex-grow-1 d-flex justify-content-between align-items-center">
                                 <input type="date" class="form-control form-control-sm border-0 border-bottom border-indigo-200 bg-transparent text-slate-700 small px-1" 
                                       t-att-value="selNode.formation_date || ''"
                                       t-on-change="(e) => props.onUpdateProperty(selNode.id, 'formation_date', e.target.value)" />
                            </div>
                        </div>
                        <!-- Fund Family -->
                        <div class="d-flex border-bottom py-3 align-items-center">
                            <div class="small fw-bold text-slate-500" style="width: 110px;">Fund Family</div>
                            <div class="flex-grow-1">
                                <input type="text" class="form-control form-control-sm border-0 border-bottom border-indigo-200 bg-transparent text-slate-700 fw-bold px-1" 
                                       t-att-value="selNode.fund_family_name || ''"
                                       placeholder="Management"
                                       t-on-change="(e) => props.onUpdateProperty(selNode.id, 'fund_family_name', e.target.value)" />
                            </div>
                        </div>

                        <div class="mt-4">
                            <button class="btn btn-sm btn-light border w-100 text-slate-600 fw-bold hover-bg-slate-100 p-2 shadow-sm rounded-1 d-flex align-items-center justify-content-center gap-2">
                                <i class="fa fa-plus text-slate-400"></i> New Property
                            </button>
                        </div>
                    </div>
                    
                    <!-- RELATIONSHIPS TAB -->
                    <div t-if="props.state.activeDataTab === 'relationships' and selNode" class="p-3">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="fw-bold text-slate-700 small">Ownership <span class="badge bg-slate-200 text-slate-600 border border-slate-300 ms-1 fw-bold fs-6" style="padding: 2px 6px;">Select All</span></div>
                        </div>
                        
                        <div class="text-slate-800 fw-bold mb-3" style="font-size: 0.9rem;">
                            Relevant relationships for <t t-esc="selNode.name"/>
                        </div>
                        
                        <t t-foreach="props.state.links" t-as="link" t-key="link.id || (link.source + '-' + link.target)">
                            <t t-if="link.source === selNode.id or link.target === selNode.id">
                                <!-- Existing links list item could go here if needed -->
                            </t>
                        </t>
                    </div>
                    
                    <!-- FILES TAB -->
                    <div t-if="props.state.activeDataTab === 'files' and selNode" class="p-3">
                        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-slate-100 border border-slate-200 rounded p-1 text-slate-600">
                                    <i class="fa fa-file-word-o fs-5"></i>
                                </div>
                                <div class="text-slate-700 fw-bold small">Certificate of Incorporation.docx</div>
                            </div>
                            <i class="fa fa-ellipsis-h text-slate-400 cursor-pointer fs-5 hover-text-slate-700"></i>
                        </div>
                        
                        <button class="btn btn-sm btn-outline-indigo px-3 py-1 fw-bold border-1 border-indigo-400 text-indigo-700 rounded-1" style="font-size: 0.8rem;">
                            Attach file
                        </button>
                    </div>
                </div>

                <div t-if="props.state.selectedNodeIds.length === 0" class="text-center py-5 p-3 text-muted">
                    <i class="fa fa-hand-pointer-o fs-1 mb-3 opacity-25"></i>
                    <p>Select an entity to view properties</p>
                </div>

                <div class="mt-4 px-3">
                    <h6 class="small fw-bold border-bottom pb-2 text-uppercase">Entities in View</h6>
                    <div class="entity-list mt-2">
                        <t t-foreach="props.state.nodes" t-as="n" t-key="n.id">
                            <div class="entity-list-item d-flex align-items-center p-2 rounded mb-1 cursor-pointer" 
                                 t-att-class="{ 'bg-indigo-50': props.state.selectedNodeIds.includes(n.id) }"
                                t-on-click="() => props.onSelectNode(n.id)">
                                <i class="fa fa-building me-2 text-slate-400 small"></i>
                                <span class="small flex-grow-1 text-truncate"><t t-esc="n.name"/></span>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
