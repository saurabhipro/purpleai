<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="jigsaw.WorkshopHeader" owl="1">
        <div class="jigsaw-header d-flex align-items-center px-0 bg-slate-100 border-bottom">
            <div class="nav-btn" t-on-click="props.onClose">
                <i class="fa fa-home"></i>
                <span>Home</span>
            </div>
            <div class="nav-btn">
                <i class="fa fa-check-square-o"></i>
                <span>Include</span>
            </div>
            <div class="nav-btn" t-on-click="props.onExport">
                <i class="fa fa-download"></i>
                <span>Export CSV</span>
            </div>
            <div class="nav-btn position-relative" t-on-click="props.toggleOwnershipMenu" t-att-class="{ 'active': props.state.showOwnershipMenu }">
                <i class="fa fa-users"></i>
                <span>Select Ownership</span>

                <!-- Ownership Filtering Dropdown -->
                <div t-if="props.state.showOwnershipMenu" class="dropdown-menu show shadow p-3 position-absolute bg-white border border-slate-200" style="top: calc(100% + 5px); left: -50px; width: 320px; z-index: 1050; border-radius: 8px; cursor: default;" t-on-click.stop="">
                    
                    <!-- Entity Search Input Box -->
                    <div class="border rounded px-2 py-2 mb-3 bg-white d-flex align-items-center position-relative border-indigo-400 shadow-sm" style="height: 36px;">
                        <div class="rounded-pill border border-indigo-200 me-2" style="width: 22px; height: 14px; background: white;"></div>
                        <input type="text" class="form-control border-0 p-0 shadow-none text-slate-700 fw-bold" style="font-size: 0.85rem;" placeholder="Select Entity..." 
                               t-att-value="props.state.selectedNodeIds.length ? props.state.nodes.find(n => n.id === props.state.selectedNodeIds[0])?.name + ' (' + (props.state.nodes.find(n => n.id === props.state.selectedNodeIds[0])?.jurisdiction || 'Unknown') + ')' : ''" readonly="1" />
                        <i class="fa fa-times text-slate-400 cursor-pointer ms-2 hover-text-slate-600" t-on-click="props.clearOwnershipFilter"></i>
                    </div>
                    
                    <!-- Direction Toggles: Up | Down | Both -->
                    <div class="btn-group w-100 mb-3" role="group">
                        <button type="button" class="btn btn-sm border fw-bold text-indigo-700 p-2" t-att-class="props.state.ownershipDirection === 'up' ? 'bg-indigo-50 border-indigo-200' : 'bg-slate-50 border-slate-200 hover-bg-slate-100'" t-on-click="() => props.setOwnershipDirection('up')">Up</button>
                        <button type="button" class="btn btn-sm border fw-bold text-slate-700 p-2" t-att-class="props.state.ownershipDirection === 'down' ? 'bg-white border-slate-300 shadow-sm' : 'bg-slate-50 border-slate-200 hover-bg-slate-100'" t-on-click="() => props.setOwnershipDirection('down')">Down</button>
                        <button type="button" class="btn btn-sm border fw-bold text-slate-700 p-2" t-att-class="props.state.ownershipDirection === 'both' ? 'bg-white border-slate-300 shadow-sm' : 'bg-slate-50 border-slate-200 hover-bg-slate-100'" t-on-click="() => props.setOwnershipDirection('both')">Both</button>
                    </div>

                    <!-- Threshold Filtering Row -->
                    <div class="d-flex align-items-center mb-3 text-slate-700" style="font-size: 0.85rem; font-weight: 500;">
                        <input type="checkbox" class="form-check-input mt-0 me-2 shadow-none cursor-pointer" id="ownPctToggle" t-model="props.state.ownershipFilterEnabled" t-on-change="props.updateOwnershipFilter" />
                        <label for="ownPctToggle" class="me-2 mb-0 cursor-pointer">Ownership of</label>
                        
                        <!-- Embedded percent input -->
                        <div class="d-flex align-items-center border rounded px-1 me-2 bg-white flex-grow-1" style="max-width: 60px;">
                            <input type="number" class="form-control border-0 p-0 text-center shadow-none" style="font-size: 0.85rem;" t-model="props.state.ownershipPctThreshold" t-on-change="props.updateOwnershipFilter" t-on-input="props.updateOwnershipFilter" />
                            <span class="me-2 fw-bold">%</span>
                        </div>
                        <span class="me-2">or</span>
                        
                        <!-- More/Less dropdown -->
                        <select class="form-select form-select-sm border-0 border-start bg-transparent ps-2 pe-4 py-0 text-slate-700 fw-bold shadow-none cursor-pointer" style="width: auto; appearance: none; background-image: url('data:image/svg+xml;utf8,&lt;svg xmlns=\'http://www.w3.org/2000/svg\' width=\'10\' height=\'10\' fill=\'%23a1a1aa\' viewBox=\'0 0 16 16\'&gt;&lt;path d=\'M8 10.5L3.5 6h9L8 10.5z\'/&gt;&lt;/svg&gt;'); background-repeat: no-repeat; background-position: right center; outline: none; border-radius: 0;" t-model="props.state.ownershipPctType" t-on-change="props.updateOwnershipFilter">
                            <option value="more">More</option>
                            <option value="less">Less</option>
                        </select>
                    </div>
                    
                    <!-- Indirect Ownership Row -->
                    <div class="d-flex align-items-center text-slate-700" style="font-size: 0.85rem; font-weight: 500;">
                        <input type="checkbox" class="form-check-input mt-0 me-2 shadow-none cursor-pointer" id="indirectOwnToggle" />
                        <label for="indirectOwnToggle" class="mb-0 cursor-pointer">Display indirect ownership %</label>
                    </div>
                </div>
            </div>
            <div class="nav-btn">
                <i class="fa fa-scissors"></i>
                <span>Extract Selection</span>
            </div>
            <div class="nav-btn" t-on-click="() => props.toggleSidebar('filter')" t-att-class="{ 'active': props.state.showFilter }">
                <i class="fa fa-filter"></i>
                <span>Filter</span>
            </div>
            <div class="nav-btn" t-on-click="() => props.toggleSidebar('data')" t-att-class="{ 'active': props.state.activeSidebar === 'data' }">
                <i class="fa fa-database"></i>
                <span>Data</span>
            </div>
            <div class="nav-btn" t-on-click="props.onOrganize">
                <i class="fa fa-sitemap"></i>
                <span>Auto-Layout</span>
            </div>
            <div class="nav-btn" t-on-click="props.onFit">
                <i class="fa fa-compress"></i>
                <span>Fit to Screen</span>
            </div>
            <div class="nav-btn" t-on-click="() => props.toggleSidebar('comments')" t-att-class="{ 'active': props.state.activeSidebar === 'comments' }">
                <i class="fa fa-comment-o"></i>
                <span>Comments</span>
            </div>
            
            <div class="ms-auto pe-3 d-flex align-items-center gap-3">
                <div class="zoom-controls d-flex align-items-center bg-white rounded-pill px-2 border">
                    <i class="fa fa-minus-circle cursor-pointer text-slate-400" t-on-click="props.onZoomOut"></i>
                    <span class="mx-2 small fw-bold"><t t-esc="Math.round(props.state.zoom * 100)"/>%</span>
                    <i class="fa fa-plus-circle cursor-pointer text-slate-400" t-on-click="props.onZoomIn"></i>
                </div>
                <button class="btn btn-primary btn-sm rounded-pill px-3" t-on-click="props.onAddEntity">
                    <i class="fa fa-plus me-1"></i> New Entity
                </button>
                <span class="text-slate-400 small">Release Ribbon <i class="fa fa-thumb-tack ms-1"></i></span>
            </div>
        </div>
    </t>
</templates>
