<odoo>
    <!-- Create a custom category for Arada groups -->
    <record id="module_category_arada" model="ir.module.category">
        <field name="name">Arada Groups</field>
        <field name="description">Security groups for the Arada module</field>
        <field name="sequence">10</field>
    </record>

    <!-- Leasing Team -->
    <record id="group_arada_leasing_team" model="res.groups">
        <field name="name">Leasing Team</field>
        <field name="category_id" ref="module_category_arada"/>
    </record>

    <!-- Leasing Director -->
    <record id="group_arada_leasing_director" model="res.groups">
        <field name="name">Leasing Director</field>
        <field name="category_id" ref="module_category_arada"/>
    </record>

    <!-- RDD -->
    <record id="group_arada_rdd" model="res.groups">
        <field name="name">RDD</field>
        <field name="category_id" ref="module_category_arada"/>
    </record>

    <!-- Tenant -->
    <record id="group_arada_tenant" model="res.groups">
        <field name="name">Tenant</field>
        <field name="category_id" ref="module_category_arada"/>
    </record>
</odoo>
