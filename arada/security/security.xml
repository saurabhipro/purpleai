<odoo>
    <data>
        <!-- Arada Workflow Group -->
        <record id="group_arada_workflow_user" model="res.groups">
            <field name="name">Arada Workflow User</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_arada_workflow_manager" model="res.groups">
            <field name="name">Arada Workflow Manager</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="implied_ids" eval="[(4, ref('group_arada_workflow_user'))]"/>
        </record>
    </data>
</odoo> 