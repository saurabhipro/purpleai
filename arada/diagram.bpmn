<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:bioc="http://www.omg.org/spec/BPMN/20100524/BI"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn">

  <!-- Collaboration and Participant -->
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" processRef="Process_1"/>
  </bpmn:collaboration>

  <!-- Process with lanes -->
  <bpmn:process id="Process_1" isExecutable="false">

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_LeasingTeam" name="Leasing Team">
        <bpmn:flowNodeRef>StartEvent_PTL_Issued</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PTL_Issued</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PTL_Approved</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_RDD" name="RDD">
        <bpmn:flowNodeRef>Task_Form_Verification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Pending_RDD</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Tenant" name="Tenant">
        <bpmn:flowNodeRef>Task_Kick_Off_Meeting</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Start Event -->
    <bpmn:startEvent id="StartEvent_PTL_Issued" name="PTL Issued">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Tasks -->
    <bpmn:task id="Task_PTL_Issued" name="PTL Issued by Leasing Team">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_PTL_Approved" name="PTL Approved by Leasing Director">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Form_Verification" name="Form Verification by RDD">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Kick_Off_Meeting" name="Kick Off Meeting with Tenant">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_Pending_RDD" name="Pending With RDD">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>

    <!-- End Event -->
    <bpmn:endEvent id="EndEvent_Process_Complete" name="Process Complete">
      <bpmn:incoming>Flow_6</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_PTL_Issued" targetRef="Task_PTL_Issued"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_PTL_Issued" targetRef="Task_PTL_Approved"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_PTL_Approved" targetRef="Task_Form_Verification"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Form_Verification" targetRef="Task_Kick_Off_Meeting"/>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_Kick_Off_Meeting" targetRef="Task_Pending_RDD"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_Pending_RDD" targetRef="EndEvent_Process_Complete"/>

  </bpmn:process>

  <!-- BPMN Diagram (visual info and lane colors) -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">

      <!-- Swimlane: Leasing Team (color: lightblue) -->
      <bpmndi:BPMNShape id="Lane_LeasingTeam_di" bpmnElement="Lane_LeasingTeam" isHorizontal="true">
        <dc:Bounds x="140" y="50" width="930" height="150" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="145" y="50" width="120" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Swimlane: RDD (color: lightgreen) -->
      <bpmndi:BPMNShape id="Lane_RDD_di" bpmnElement="Lane_RDD" isHorizontal="true">
        <dc:Bounds x="140" y="200" width="930" height="150" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="145" y="200" width="50" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Swimlane: Tenant (color: lightpink) -->
      <bpmndi:BPMNShape id="Lane_Tenant_di" bpmnElement="Lane_Tenant" isHorizontal="true">
        <dc:Bounds x="140" y="350" width="930" height="150" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="145" y="350" width="50" height="20" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_PTL_Issued_di" bpmnElement="StartEvent_PTL_Issued">
        <dc:Bounds x="180" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Tasks Leasing Team -->
      <bpmndi:BPMNShape id="Task_PTL_Issued_di" bpmnElement="Task_PTL_Issued">
        <dc:Bounds x="240" y="110" width="140" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_PTL_Approved_di" bpmnElement="Task_PTL_Approved">
        <dc:Bounds x="400" y="110" width="140" height="80" />
      </bpmndi:BPMNShape>

      <!-- Tasks RDD -->
      <bpmndi:BPMNShape id="Task_Form_Verification_di" bpmnElement="Task_Form_Verification">
        <dc:Bounds x="240" y="260" width="140" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_Pending_RDD_di" bpmnElement="Task_Pending_RDD">
        <dc:Bounds x="560" y="260" width="140" height="80" />
      </bpmndi:BPMNShape>

      <!-- Tasks Tenant -->
      <bpmndi:BPMNShape id="Task_Kick_Off_Meeting_di" bpmnElement="Task_Kick_Off_Meeting">
        <dc:Bounds x="400" y="410" width="140" height="80" />
      </bpmndi:BPMNShape>

      <!-- End Event -->
      <bpmndi:BPMNShape id="EndEvent_Process_Complete_di" bpmnElement="EndEvent_Process_Complete">
        <dc:Bounds x="740" y="290" width="36" height="36" />
      </bpmndi:BPMNShape>

      <!-- Sequence Flows -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="216" y="138" />
        <di:waypoint x="240" y="150" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="380" y="150" />
        <di:waypoint x="400" y="150" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="540" y="150" />
        <di:waypoint x="540" y="300" />
        <di:waypoint x="240" y="300" />
        <di:waypoint x="240" y="300" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="380" y="300" />
        <di:waypoint x="400" y="450" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="540" y="450" />
        <di:waypoint x="560" y="300" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="700" y="300" />
        <di:waypoint x="740" y="300" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
