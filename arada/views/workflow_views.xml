<odoo>
    <data>
        <!-- Workflow List View -->
        <record id="view_arada_workflow_tree" model="ir.ui.view">
            <field name="name">arada.workflow.tree</field>
            <field name="model">arada_workflow</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="workflow_type"/>
                    <field name="status"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <!-- Workflow Form View -->
        <record id="view_arada_workflow_form" model="ir.ui.view">
            <field name="name">arada.workflow.form</field>
            <field name="model">arada_workflow</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="workflow_type"/>
                                <field name="status"/>
                            </group>
                            <group>
                                <field name="company_id"/>
                            </group>
                        </group>
                        <field name="description"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Workflow State List View -->
        <record id="view_arada_workflow_state_tree" model="ir.ui.view">
            <field name="name">arada.workflow.state.tree</field>
            <field name="model">arada_workflow_state</field>
            <field name="arch" type="xml">
                <list>
                    <field name="workflow_id"/>
                    <field name="state_name"/>
                    <field name="state_enum"/>
                    <field name="sequence"/>
                    <field name="is_initial"/>
                    <field name="is_final"/>
                </list>
            </field>
        </record>

        <!-- Workflow Action List View -->
        <record id="view_arada_workflow_action_tree" model="ir.ui.view">
            <field name="name">arada.workflow.action.tree</field>
            <field name="model">arada_workflow_action</field>
            <field name="arch" type="xml">
                <list>
                    <field name="action_name"/>
                    <field name="action_type"/>
                    <field name="phase"/>
                </list>
            </field>
        </record>

        <!-- Workflow State Transition List View -->
        <record id="view_arada_workflow_state_transition_tree" model="ir.ui.view">
            <field name="name">arada.workflow.state.transition.tree</field>
            <field name="model">arada_workflow_state_transition</field>
            <field name="arch" type="xml">
                <list>
                    <field name="workflow_id"/>
                    <field name="current_state_id"/>
                    <field name="action_id"/>
                    <field name="next_state_id"/>
                    <field name="action_owner"/>
                </list>
            </field>
        </record>

        <!-- Actions -->
        <record id="action_arada_workflow" model="ir.actions.act_window">
            <field name="name">Workflows</field>
            <field name="res_model">arada_workflow</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_arada_workflow_state" model="ir.actions.act_window">
            <field name="name">Workflow States</field>
            <field name="res_model">arada_workflow_state</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_arada_workflow_action" model="ir.actions.act_window">
            <field name="name">Workflow Actions</field>
            <field name="res_model">arada_workflow_action</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_arada_workflow_state_transition" model="ir.actions.act_window">
            <field name="name">Workflow Transitions</field>
            <field name="res_model">arada_workflow_state_transition</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu Items -->
        </data>
</odoo> 