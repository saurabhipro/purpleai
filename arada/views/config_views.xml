<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_arada_config_list" model="ir.ui.view">
            <field name="name">arada.config.list</field>
            <field name="model">arada.config</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="description"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_arada_config_form" model="ir.ui.view">
            <field name="name">arada.config.form</field>
            <field name="model">arada.config</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_arada_config" model="ir.actions.act_window">
            <field name="name">Configuration</field>
            <field name="res_model">arada.config</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo> 