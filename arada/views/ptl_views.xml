<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- PTL Approval Wizard Form -->
        <record id="view_ptl_approval_wizard_form" model="ir.ui.view">
            <field name="name">ptl.approval.wizard.form</field>
            <field name="model">ptl.approval.wizard</field>
            <field name="arch" type="xml">
                <form string="Approval/Rejection">
                    <div class="alert alert-info" role="alert">
                        <strong>Action Required:</strong> Please provide your comments for this <field name="section_name" readonly="1"/> action.
                    </div>
                    <group>
                        <field name="ptl_form_id" invisible="1"/>
                        <field name="action_type" invisible="1"/>
                        <field name="section_name" invisible="1"/>
                        <field name="comments" placeholder="Enter your detailed comments here..." style="min-height: 100px;"/>
                    </group>
                    <footer>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- PTL Form List View -->
        <record id="view_ptl_form_list" model="ir.ui.view">
            <field name="name">ptl.form.list</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <list string="PTL Forms">
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="tenant_name"/>
                    <field name="approve_form_name"/>
                    <field name="submitted_date"/>
                    <field name="priority"/>
                    <field name="global_status"/>
                </list>
            </field>
        </record>

        <!-- PTL Form Kanban View -->
        <record id="view_ptl_form_kanban" model="ir.ui.view">
            <field name="name">ptl.form.kanban</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <kanban default_group_by="global_status" class="o_kanban_small_column">
                    <field name="global_status"/>
                    <field name="tenant_name"/>
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="submitted_date"/>
                    <field name="priority"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_image">
                                    <i class="fa fa-building fa-2x text-primary" title="PTL Form"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <div class="o_kanban_record_top mb-2">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="tenant_name"/>
                                            </strong>
                                            <small class="o_kanban_record_subtitle text-muted">
                                                <i class="fa fa-map-marker text-warning"/> <field name="unit_no"/> - <field name="development"/>
                                            </small>
                                        </div>
                                        <div class="o_kanban_manage_button_section">
                                            <field name="priority" widget="priority"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <i class="fa fa-calendar text-info"/> <field name="submitted_date"/>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <field name="global_status" widget="label_selection"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- PTL Form Form View - Complete with All Sections -->
        <record id="view_ptl_form_form" model="ir.ui.view">
            <field name="name">ptl.form.form</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <form string="PTL Form">
                    <header>
                        <!-- Auto-updating Global Workflow Status (No Buttons) -->
                        <field name="global_status" widget="statusbar" 
                               statusbar_visible="ptl,form_verification,kick_off_meeting,pending_with_rdd,pending_with_tenant,rdd_review,noc,site_inspection_submission,handover" readonly="1"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="form_name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="📋 Basic Information">
                                <field name="unit_no"/>
                                <field name="development"/>
                                <field name="tenant_name"/>
                                <field name="approve_form_name"/>
                            </group>
                            <group string="📊 Status &amp; Priority">
                                <field name="priority" widget="priority"/>
                                <field name="submitted_date"/>
                            </group>
                        </group>

                        <notebook>
                            <!-- PTL Section Tab with Approve/Reject Buttons -->
                            <page string="📄 PTL Section" name="ptl_section_tab">
                             image.png   <!-- PTL Section Status with Approve/Reject Actions -->
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom mb-3" style="min-height: 40px;">
                                    <span class="font-weight-bold text-muted" style="font-size: 14px;">PTL Section Status</span>
                                    <div class="d-flex align-items-center">
                                        <div class="mr-3" style="min-width: 200px;">
                                            <field name="ptl_section_status" widget="statusbar" statusbar_visible="new,pending,approved,rejected" nolabel="1"/>
                                        </div>
                                        <div>
                                            <button name="action_set_ptl_pending" type="object" string="Set Pending" 
                                                    class="btn btn-warning btn-sm" invisible="ptl_section_status != 'new'"/>
                                            <button name="action_approve_ptl_section" type="object" string="✅ Approve" 
                                                    class="btn btn-success btn-sm" invisible="ptl_section_status not in ['pending', 'rejected']"/>
                                            <button name="action_reject_ptl_section" type="object" string="❌ Reject" 
                                                    class="btn btn-danger btn-sm" invisible="ptl_section_status not in ['pending', 'approved']"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Tenancy location and details -->
                                <div class="row">
                                    <div class="col-12">
                                        <h5 class="text-primary">Tenancy location and details</h5>
                                        <hr/>
                                    </div>
                                </div>
                                <group>
                                    <group>
                                        <field name="development" string="Development" placeholder="Placeholder"/>
                                        <field name="unit_no" string="Unit no." placeholder="Placeholder"/>
                                        <field name="ground_floor" string="Ground floor" placeholder="Placeholder"/>
                                        <field name="outdoor_area_gf" string="Outdoor area - GF" placeholder="Placeholder"/>
                                        <field name="outdoor_area_mezz" string="Outdoor area - Mezz" placeholder="Placeholder"/>
                                    </group>
                                </group>

                                <!-- Tenant contact details -->
                                <div class="row mt-4">
                                    <div class="col-12">
                                        <h5 class="text-primary">Tenant contact details</h5>
                                        <hr/>
                                    </div>
                                </div>
                                <group>
                                    <group>
                                        <field name="tenant" string="Tenant" placeholder="Placeholder"/>
                                        <field name="proposed_shop" string="Proposed shop" placeholder="Placeholder"/>
                                        <field name="permitted_use" string="Permitted use" placeholder="Placeholder"/>
                                        <field name="lease_term" string="Lease term"/>
                                        <field name="contact_person" string="Contact person" placeholder="Placeholder"/>
                                        <field name="designation" string="Designation" placeholder="Placeholder"/>
                                    </group>
                                    <group>
                                        <field name="address" string="Address (Physical address)" placeholder="Placeholder"/>
                                        <field name="telephone" string="Telephone"/>
                                        <field name="mobile" string="Mobile"/>
                                        <field name="email" string="Email" placeholder="Placeholder"/>
                                    </group>
                                </group>

                                <!-- Key dates as per offer letter -->
                                <div class="row mt-4">
                                    <div class="col-12">
                                        <h5 class="text-primary">Key dates as per offer letter</h5>
                                        <hr/>
                                    </div>
                                </div>
                                <group>
                                    <group>
                                        <field name="pit_out_commencement_date" string="Pit out commencement date"/>
                                        <field name="fit_out_period" string="Fit-out period"/>
                                        <field name="concept_design_submission_date" string="Concept design submission date"/>
                                        <field name="detail_design_submission_date" string="Detail design submission date"/>
                                        <field name="trade_start_date" string="Trade start date"/>
                                    </group>
                                    <group>
                                        <field name="late_opening_penalty" string="Late opening penalty (LOP)" placeholder="Placeholder"/>
                                        <field name="note" string="Note" placeholder="Note..."/>
                                    </group>
                                </group>

                                <!-- Special requirements -->
                                <div class="row mt-4">
                                    <div class="col-12">
                                        <h5 class="text-primary">Special requirements</h5>
                                        <hr/>
                                        <field name="special_requirements" placeholder="Description..." nolabel="1"/>
                                    </div>
                                </div>

                                <!-- Attach -->
                                <div class="row mt-4">
                                    <div class="col-12">
                                        <h5 class="text-primary">Attach</h5>
                                        <hr/>
                                        <field name="attachment" filename="attachment_name" nolabel="1"/>
                                    </div>
                                </div>
                            </page>

                            <!-- Critical Path Section Tab - Complete 2-Column Layout -->
                            <page string="🗺️ Critical Path Section" name="critical_path_section_tab" 
                                  invisible="global_status in ['ptl', 'form_verification']">
                                <!-- Critical Path Section Status with Approve/Reject Actions -->
                                <div class="d-flex justify-content-end align-items-center py-2 border-bottom mb-3" style="min-height: 40px;">
                                    <div class="d-flex align-items-center">
                                        <div class="mr-3" style="min-width: 200px;">
                                            <field name="critical_path_section_status" widget="statusbar" statusbar_visible="new,pending,approved,rejected" nolabel="1"/>
                                        </div>
                                        <div>
                                            <button name="action_set_critical_path_pending" type="object" string="Set Pending" 
                                                    class="btn btn-warning btn-sm" invisible="critical_path_section_status != 'new'"/>
                                            <button name="action_approve_critical_path_section" type="object" string="✅ Approve" 
                                                    class="btn btn-success btn-sm" invisible="critical_path_section_status not in ['pending', 'rejected']"/>
                                            <button name="action_reject_critical_path_section" type="object" string="❌ Reject" 
                                                    class="btn btn-danger btn-sm" invisible="critical_path_section_status not in ['pending', 'approved']"/>
                                        </div>
                                    </div>
                                </div>

                                <!-- Professional 2-Column Layout with Colors -->
                                <div class="container-fluid">
                                    <!-- Table Header -->
                                    <div class="row border-bottom bg-light py-2 font-weight-bold" style="background-color: #f8f9fa;">
                                        <div class="col-md-3">
                                            <span style="color: #495057; font-size: 13px;">Description</span>
                                        </div>
                                        <div class="col-md-1 text-center">
                                            <span style="color: #495057; font-size: 13px;">Days</span>
                                        </div>
                                        <div class="col-md-2 text-center">
                                            <span style="color: #495057; font-size: 13px;">Date</span>
                                        </div>
                                        <div class="col-md-3">
                                            <span style="color: #495057; font-size: 13px;">Description</span>
                                        </div>
                                        <div class="col-md-1 text-center">
                                            <span style="color: #495057; font-size: 13px;">Days</span>
                                        </div>
                                        <div class="col-md-2 text-center">
                                            <span style="color: #495057; font-size: 13px;">Date</span>
                                        </div>
                                    </div>

                                    <!-- DESIGN Section - Blue Theme -->
                                    <div class="row mt-3" style="background: linear-gradient(135deg, #007bff 0%, #0056b3 100%); padding: 8px 15px; border-radius: 5px; margin: 15px 0;">
                                        <div class="col-12">
                                            <h6 class="font-weight-bold text-uppercase mb-0" style="color: white; font-size: 12px; letter-spacing: 1px;">
                                                🎨 DESIGN ACTIVITIES
                                            </h6>
                                        </div>
                                    </div>
                                    
                                    <!-- Design Activities Rows - 2 Column Layout -->
                                    <div class="row border-bottom py-2" style="min-height: 45px;">
                                        <!-- Column 1 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Kick-Off meeting / Project handover</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="kickoff_meeting_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="kickoff_meeting_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                        <!-- Column 2 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Concept design submissions</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="concept_design_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="concept_design_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                    </div>

                                    <div class="row border-bottom py-2" style="min-height: 45px;">
                                        <!-- Column 1 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Arch detailed design submission</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="arch_detailed_design_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="arch_detailed_design_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                        <!-- Column 2 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">MEP design submission</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="mep_design_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="mep_design_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                    </div>

                                    <!-- AUTHORITY Section - Orange Theme -->
                                    <div class="row mt-4" style="background: linear-gradient(135deg, #fd7e14 0%, #e55a00 100%); padding: 8px 15px; border-radius: 5px; margin: 15px 0;">
                                        <div class="col-12">
                                            <h6 class="font-weight-bold text-uppercase mb-0" style="color: white; font-size: 12px; letter-spacing: 1px;">
                                                🏛️ AUTHORITY ACTIVITIES
                                            </h6>
                                        </div>
                                    </div>

                                    <div class="row border-bottom py-2" style="min-height: 45px;">
                                        <!-- Column 1 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Civil defence approval</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="civil_defence_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="civil_defence_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                        <!-- Column 2 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Municipality fit-out permit/Authority submissions</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="municipality_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="municipality_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                    </div>

                                    <div class="row border-bottom py-2" style="min-height: 45px;">
                                        <!-- Column 1 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">SEWA / Water &amp; power approval</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="sewa_approval_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="sewa_approval_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                        <!-- Empty Column 2 for Authority -->
                                        <div class="col-md-6"></div>
                                    </div>

                                    <!-- EXECUTION Section - Green Theme -->
                                    <div class="row mt-4" style="background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%); padding: 8px 15px; border-radius: 5px; margin: 15px 0;">
                                        <div class="col-12">
                                            <h6 class="font-weight-bold text-uppercase mb-0" style="color: white; font-size: 12px; letter-spacing: 1px;">
                                                🚧 EXECUTION ACTIVITIES
                                            </h6>
                                        </div>
                                    </div>

                                    <div class="row border-bottom py-2" style="min-height: 45px;">
                                        <!-- Column 1 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Site mobilization</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="site_mobilization_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="site_mobilization_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                        <!-- Column 2 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Fitout works</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="fitout_works_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="fitout_works_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                    </div>

                                    <div class="row border-bottom py-2" style="min-height: 45px;">
                                        <!-- Column 1 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Final inspection</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="final_inspection_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="final_inspection_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                        <!-- Column 2 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Snag completion</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="snag_completion_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="snag_completion_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                    </div>

                                    <div class="row border-bottom py-2" style="min-height: 45px;">
                                        <!-- Column 1 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Handover of all approvals</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="handover_approvals_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="handover_approvals_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                        <!-- Column 2 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Merchandising start</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="trading_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="trade_date_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                    </div>

                                    <div class="row border-bottom py-2" style="min-height: 45px;">
                                        <!-- Column 1 -->
                                        <div class="col-md-3 d-flex align-items-center">
                                            <span style="font-size: 12px; color: #495057;">Trade date</span>
                                        </div>
                                        <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                            <field name="trading_days" nolabel="1" style="max-width: 50px; text-align: center;"/>
                                        </div>
                                        <div class="col-md-2 d-flex align-items-center justify-content-center">
                                            <field name="trade_date_date" nolabel="1" style="max-width: 120px;"/>
                                        </div>
                                        <!-- Empty Column 2 -->
                                        <div class="col-md-6"></div>
                                    </div>

                                    <!-- Late Opening Penalty Row -->
                                    <div class="row py-3 mt-3" style="background-color: #f8f9fa;">
                                        <div class="col-md-6 d-flex align-items-center">
                                            <span style="font-size: 13px; color: #495057; font-weight: 500;">Late opening penalty (LOP) AED per calendar day</span>
                                        </div>
                                        <div class="col-md-6 d-flex align-items-center">
                                            <field name="late_opening_penalty" nolabel="1" style="max-width: 150px;" placeholder="0.00 AED"/>
                                        </div>
                                    </div>

                                    <!-- Comments Section -->
                                    <div class="row mt-4">
                                        <div class="col-12">
                                            <h6 class="font-weight-bold text-uppercase" style="color: #6c757d; font-size: 12px; letter-spacing: 1px;">Comments</h6>
                                            <field name="comments" nolabel="1" placeholder="Comments..." style="min-height: 80px;"/>
                                        </div>
                                    </div>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- PTL Form Action -->
        <record id="action_ptl_form" model="ir.actions.act_window">
            <field name="name">PTL Forms</field>
            <field name="res_model">ptl.form</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first PTL Form
                </p>
                <p>
                    Get started by creating a new PTL (Permission to Lease) form for tenant management.
                </p>
            </field>
        </record>

        <!-- PTL Form Search View -->
        <record id="view_ptl_form_search" model="ir.ui.view">
            <field name="name">ptl.form.search</field>
            <field name="model">ptl.form</field>
