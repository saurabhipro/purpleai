<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- PTL Form List View -->
        <record id="view_ptl_form_list" model="ir.ui.view">
            <field name="name">ptl.form.list</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <list string="PTL Forms">
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="tenant_name"/>
                    <field name="approve_form_name"/>
                    <field name="submitted_date"/>
                    <field name="priority"/>
                    <field name="global_status"/>
                </list>
            </field>
        </record>

        <!-- PTL Form Kanban View -->
        <record id="view_ptl_form_kanban" model="ir.ui.view">
            <field name="name">ptl.form.kanban</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <kanban default_group_by="global_status" class="o_kanban_small_column">
                    <field name="global_status"/>
                    <field name="tenant_name"/>
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="submitted_date"/>
                    <field name="priority"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_image">
                                    <i class="fa fa-building fa-2x text-primary" title="PTL Form"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <div class="o_kanban_record_top mb-2">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="tenant_name"/>
                                            </strong>
                                            <small class="o_kanban_record_subtitle text-muted">
                                                <i class="fa fa-map-marker text-warning"/> <field name="unit_no"/> - <field name="development"/>
                                            </small>
                                        </div>
                                        <div class="o_kanban_manage_button_section">
                                            <field name="priority" widget="priority"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <i class="fa fa-calendar text-info"/> <field name="submitted_date"/>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <field name="global_status" widget="label_selection"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- PTL Form Form View with Detailed Global Breadcrumbs -->
        <record id="view_ptl_form_form" model="ir.ui.view">
            <field name="name">ptl.form.form</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <form string="PTL Form">
                    <header>
                        <!-- Detailed Global Workflow Status Breadcrumbs -->
                        <field name="global_status" widget="statusbar" 
                               statusbar_visible="ptl,form_verification,kick_off_meeting,pending_with_rdd,pending_with_tenant,rdd_review,noc,site_inspection_submission,handover"/>
                        
                        <!-- Stage Navigation Buttons -->
                        <button name="action_move_to_form_verification" type="object" string="Move to Form Verification" 
                                class="btn-primary" invisible="global_status != 'ptl'"/>
                        <button name="action_move_to_kick_off_meeting" type="object" string="Move to Kick Off Meeting" 
                                class="btn-primary" invisible="global_status != 'form_verification'"/>
                        <button name="action_move_to_pending_with_rdd" type="object" string="Move to Pending With RDD" 
                                class="btn-primary" invisible="global_status != 'kick_off_meeting'"/>
                        <button name="action_move_to_pending_with_tenant" type="object" string="Move to Pending With Tenant" 
                                class="btn-primary" invisible="global_status != 'pending_with_rdd'"/>
                        <button name="action_move_to_rdd_review" type="object" string="Move to RDD Review" 
                                class="btn-primary" invisible="global_status != 'pending_with_tenant'"/>
                        <button name="action_move_to_noc" type="object" string="Move to NOC" 
                                class="btn-primary" invisible="global_status != 'rdd_review'"/>
                        <button name="action_move_to_site_inspection" type="object" string="Move to Site Inspection" 
                                class="btn-primary" invisible="global_status != 'noc'"/>
                        <button name="action_move_to_handover" type="object" string="Move to Handover" 
                                class="btn-success" invisible="global_status != 'site_inspection_submission'"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="form_name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="📋 Basic Information">
                                <field name="unit_no"/>
                                <field name="development"/>
                                <field name="tenant_name"/>
                                <field name="approve_form_name"/>
                            </group>
                            <group string="📊 Status &amp; Priority">
                                <field name="priority" widget="priority"/>
                                <field name="submitted_date"/>
                            </group>
                        </group>

                        <notebook>
                            <!-- PTL Section Tab -->
                            <page string="📄 PTL Section" name="ptl_section_tab">
                                <!-- Compact PTL Section Status Row -->
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom mb-3" style="min-height: 40px;">
                                    <span class="font-weight-bold text-muted" style="font-size: 14px;">PTL Section Status</span>
                                    <div class="d-flex align-items-center">
                                        <div class="mr-3" style="min-width: 200px;">
                                            <field name="ptl_section_status" widget="statusbar" statusbar_visible="new,pending,approved" nolabel="1"/>
                                        </div>
                                        <div>
                                            <button name="action_set_ptl_pending" type="object" string="Set Pending" 
                                                    class="btn btn-warning btn-sm" invisible="ptl_section_status != 'new'"/>
                                            <button name="action_approve_ptl_section" type="object" string="Approve PTL" 
                                                    class="btn btn-success btn-sm" invisible="ptl_section_status != 'pending'"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <group>
                                    <group string="Design Activities">
                                        <field name="kickoff_meeting_days" style="max-width: 100px;"/>
                                        <field name="kickoff_meeting_date"/>
                                        <field name="concept_design_days" style="max-width: 100px;"/>
                                        <field name="concept_design_date"/>
                                        <field name="arch_detailed_design_days" style="max-width: 100px;"/>
                                        <field name="arch_detailed_design_date"/>
                                        <field name="mep_design_days" style="max-width: 100px;"/>
                                        <field name="mep_design_date"/>
                                    </group>
                                    <group string="Authority Activities">
                                        <field name="civil_defence_days" style="max-width: 100px;"/>
                                        <field name="civil_defence_date"/>
                                        <field name="municipality_days" style="max-width: 100px;"/>
                                        <field name="municipality_date"/>
                                        <field name="sewa_approval_days" style="max-width: 100px;"/>
                                        <field name="sewa_approval_date"/>
                                    </group>
                                </group>
                            </page>

                            <!-- Critical Path Section Tab -->
                            <page string="🗺️ Critical Path Section" name="critical_path_section_tab" 
                                  invisible="global_status in ['ptl', 'form_verification']">
                                <!-- Compact Critical Path Section Status Row -->
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom mb-3" style="min-height: 40px;">
                                    <span class="font-weight-bold text-muted" style="font-size: 14px;">Critical Path Section Status</span>
                                    <div class="d-flex align-items-center">
                                        <div class="mr-3" style="min-width: 200px;">
                                            <field name="critical_path_section_status" widget="statusbar" statusbar_visible="new,pending,approved" nolabel="1"/>
                                        </div>
                                        <div>
                                            <button name="action_set_critical_path_pending" type="object" string="Set Pending" 
                                                    class="btn btn-warning btn-sm" invisible="critical_path_section_status != 'new'"/>
                                            <button name="action_approve_critical_path_section" type="object" string="Approve Critical Path" 
                                                    class="btn btn-success btn-sm" invisible="critical_path_section_status != 'pending'"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <group>
                                    <group string="Execution Activities">
                                        <field name="site_mobilization_days" style="max-width: 100px;"/>
                                        <field name="site_mobilization_date"/>
                                        <field name="fitout_works_days" style="max-width: 100px;"/>
                                        <field name="fitout_works_date"/>
                                        <field name="final_inspection_days" style="max-width: 100px;"/>
                                        <field name="final_inspection_date"/>
                                        <field name="snag_completion_days" style="max-width: 100px;"/>
                                        <field name="snag_completion_date"/>
                                        <field name="handover_approvals_days" style="max-width: 100px;"/>
                                        <field name="handover_approvals_date"/>
                                        <field name="trading_days" style="max-width: 100px;"/>
                                        <field name="trade_date_date"/>
                                    </group>
                                    <group string="Financial">
                                        <field name="late_opening_penalty"/>
                                    </group>
                                </group>
                                
                                <group string="Comments">
                                    <field name="comments" nolabel="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- PTL Form Action -->
        <record id="action_ptl_form" model="ir.actions.act_window">
            <field name="name">PTL Forms</field>
            <field name="res_model">ptl.form</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first PTL Form
                </p>
                <p>
                    Get started by creating a new PTL (Permission to Lease) form for tenant management.
                </p>
            </field>
        </record>

        <!-- PTL Form Search View -->
        <record id="view_ptl_form_search" model="ir.ui.view">
            <field name="name">ptl.form.search</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <search>
                    <field name="tenant_name"/>
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="approve_form_name"/>
                    <filter string="🆕 PTL" name="filter_ptl" domain="[('global_status', '=', 'ptl')]"/>
                    <filter string="📋 Form Verification" name="filter_form_verification" domain="[('global_status', '=', 'form_verification')]"/>
                    <filter string="🤝 Kick Off Meeting" name="filter_kick_off" domain="[('global_status', '=', 'kick_off_meeting')]"/>
                    <filter string="⏳ Pending With RDD" name="filter_pending_rdd" domain="[('global_status', '=', 'pending_with_rdd')]"/>
                    <filter string="👥 Pending With Tenant" name="filter_pending_tenant" domain="[('global_status', '=', 'pending_with_tenant')]"/>
                    <filter string="📝 RDD Review" name="filter_rdd_review" domain="[('global_status', '=', 'rdd_review')]"/>
                    <filter string="📜 NOC" name="filter_noc" domain="[('global_status', '=', 'noc')]"/>
                    <filter string="🔍 Site Inspection" name="filter_site_inspection" domain="[('global_status', '=', 'site_inspection_submission')]"/>
                    <filter string="🤝 Handover" name="filter_handover" domain="[('global_status', '=', 'handover')]"/>
                    <separator/>
                    <filter string="🆕 NEW" name="filter_new" domain="[('ptl_section_status', '=', 'new')]"/>
                    <filter string="⏳ PENDING" name="filter_pending" domain="[('ptl_section_status', '=', 'pending')]"/>
                    <filter string="✅ APPROVED" name="filter_approved" domain="[('ptl_section_status', '=', 'approved')]"/>
                    <separator/>
                    <group expand="1" string="Group By">
                        <filter string="Global Status" name="group_global_status" context="{'group_by': 'global_status'}"/>
                        <filter string="PTL Section Status" name="group_ptl_status" context="{'group_by': 'ptl_section_status'}"/>
                        <filter string="Development" name="group_development" context="{'group_by': 'development'}"/>
                        <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo> 