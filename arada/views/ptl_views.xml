<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- PTL Form List View -->
        <record id="view_ptl_form_list" model="ir.ui.view">
            <field name="name">ptl.form.list</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <list string="PTL Forms">
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="tenant_name"/>
                    <field name="approve_form_name"/>
                    <field name="submitted_date"/>
                    <field name="status"/>
                </list>
            </field>
        </record>

        <!-- PTL Form Kanban View -->
        <record id="view_ptl_form_kanban" model="ir.ui.view">
            <field name="name">ptl.form.kanban</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column">
                    <field name="status"/>
                    <field name="tenant_name"/>
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="submitted_date"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_content">
                                    <div class="o_kanban_record_title">
                                        <strong><field name="tenant_name"/></strong>
                                    </div>
                                    <div class="o_kanban_record_subtitle">
                                        Unit: <field name="unit_no"/> - <field name="development"/>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <field name="submitted_date"/>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <field name="status" widget="label_selection"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- PTL Form Form View - COMPLETE VERSION -->
        <record id="view_ptl_form_form" model="ir.ui.view">
            <field name="name">ptl.form.form</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <form string="Initial Notification - Confirmed offer (Form - PTL)">
                    <header>
                        <field name="status" widget="statusbar" statusbar_visible="new,in_progress,approved,completed"/>
                        <button name="action_start_progress" string="Start Progress" type="object" 
                                class="oe_highlight" 
                                invisible="status != 'new'"/>
                        <button name="action_approve" string="Approve" type="object" 
                                class="btn-primary" 
                                invisible="status != 'in_progress'"/>
                        <button name="action_complete" string="Complete" type="object" 
                                class="btn-success" 
                                invisible="status != 'approved'"/>
                        <button name="action_return" string="Return" type="object" 
                                class="btn-warning" 
                                invisible="status in ['new', 'completed']"/>
                        <button name="action_reset_to_new" string="Reset to New" type="object" 
                                class="btn-secondary" 
                                invisible="status == 'new'"/>
                        
                        <!-- Critical Path Button - only visible when PTL is approved -->
                        <button name="action_open_critical_path" string="Open Critical Path" type="object" 
                                class="btn-info" 
                                invisible="status != 'approved' or not has_critical_path"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="form_name" readonly="1"/>
                            </h1>
                        </div>
                        
                        <!-- Critical Path Information -->
                        <div class="alert alert-info" role="alert" invisible="status != 'approved' or not has_critical_path">
                            <strong>Critical Path Created!</strong> You can now proceed with the Critical Path approval process.
                        </div>
                        
                        <notebook>
                            <!-- PTL Tab - Everything in one tab -->
                            <page string="PTL" name="ptl_main">
                                <!-- Tenancy location and details -->
                                <group string="TENANCY LOCATION AND DETAILS" name="tenancy_location">
                                    <group>
                                        <field name="development" placeholder="Development"/>
                                        <field name="unit_no" placeholder="Unit Number"/>
                                        <field name="ground_floor" placeholder="Ground Floor"/>
                                    </group>
                                    <group>
                                        <field name="mezzanine_floor" placeholder="Mezzanine Floor"/>
                                        <field name="outdoor_area_gf" placeholder="Outdoor Area - GF"/>
                                        <field name="outdoor_area_mezz" placeholder="Outdoor Area - Mezz"/>
                                    </group>
                                </group>

                                <!-- Tenant contact details -->
                                <group string="TENANT CONTACT DETAILS" name="tenant_contact">
                                    <group>
                                        <field name="tenant_name" placeholder="Tenant Name"/>
                                        <field name="proposed_shop_name" placeholder="Proposed Shop Name"/>
                                        <field name="permitted_use" placeholder="Permitted Use"/>
                                        <field name="lease_term" placeholder="0"/>
                                    </group>
                                    <group>
                                        <field name="contact_person_name" placeholder="Contact Person Name"/>
                                        <field name="designation" placeholder="Designation"/>
                                        <field name="company_name" placeholder="Company Name"/>
                                    </group>
                                </group>

                                <!-- Contact Information -->
                                <group string="Contact Information" name="contact_info">
                                    <field name="address" placeholder="Physical Address" colspan="2"/>
                                    <group>
                                        <field name="telephone" placeholder="+971 55 223 3444"/>
                                        <field name="mobile" placeholder="+971 55 223 3444"/>
                                    </group>
                                    <group>
                                        <field name="email" placeholder="Email Address"/>
                                    </group>
                                </group>

                                <!-- Key dates as per offer letter -->
                                <group string="Key dates as per offer letter" name="key_dates_group">
                                    <group>
                                        <field name="fit_out_commencement_date"/>
                                        <field name="fit_out_period"/>
                                        <field name="concept_design_submission_date"/>
                                    </group>
                                    <group>
                                        <field name="detail_design_submission_date"/>
                                        <field name="trade_start_date"/>
                                        <field name="late_opening_penalty"/>
                                    </group>
                                </group>

                                <!-- Notes -->
                                <group string="Notes" name="notes_group">
                                    <field name="notes" placeholder="Note..." nolabel="1" colspan="2"/>
                                </group>

                                <!-- Special requirements -->
                                <group string="Special requirements" name="special_requirements_group">
                                    <field name="special_requirements" placeholder="Description..." nolabel="1" colspan="2"/>
                                </group>

                                <!-- Simple Attachment Upload -->
                                <group string="Attachment" name="attachment_group">
                                    <field name="ptl_attachment" filename="ptl_attachment_filename" colspan="2"/>
                                    <field name="ptl_attachment_filename" invisible="1"/>
                                </group>

                                <!-- Status & Tracking -->
                                <group string="Status &amp; Tracking" name="form_status">
                                    <group>
                                        <field name="status"/>
                                        <field name="submitted_date"/>
                                    </group>
                                    <group>
                                        <field name="approve_form_name" placeholder="Approve Form Name"/>
                                    </group>
                                </group>
                                
                                <!-- Hidden fields for computation -->
                                <field name="has_critical_path" invisible="1"/>
                                <field name="critical_path_id" invisible="1"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- PTL Form Search View with Status Filters -->
        <record id="view_ptl_form_search" model="ir.ui.view">
            <field name="name">ptl.form.search</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <search string="Search PTL Forms">
                    <field name="tenant_name"/>
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="approve_form_name"/>
                    
                    <!-- Status Filters -->
                    <filter string="New" name="filter_new" domain="[('status', '=', 'new')]"/>
                    <filter string="In Progress" name="filter_in_progress" domain="[('status', '=', 'in_progress')]"/>
                    <filter string="Approved" name="filter_approved" domain="[('status', '=', 'approved')]"/>
                    <filter string="Completed" name="filter_completed" domain="[('status', '=', 'completed')]"/>
                    <filter string="Returned" name="filter_returned" domain="[('status', '=', 'returned')]"/>
                    
                    <separator/>
                    
                    <!-- Date Filters -->
                    <filter string="Today" name="filter_today" domain="[('submitted_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                    <filter string="This Week" name="filter_week" domain="[('submitted_date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                    <filter string="This Month" name="filter_month" domain="[('submitted_date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                    
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                        <filter string="Development" name="group_by_development" context="{'group_by': 'development'}"/>
                        <filter string="Submitted Date" name="group_by_date" context="{'group_by': 'submitted_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- PTL Form Action -->
        <record id="action_ptl_form" model="ir.actions.act_window">
            <field name="name">PTL Forms</field>
            <field name="res_model">ptl.form</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{'search_default_filter_new': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first PTL form!
                </p>
                <p>
                    PTL (Permission to Lease) forms are used for initial notifications of confirmed offers.
                </p>
            </field>
        </record>

        <!-- Individual Status Actions -->
        <record id="action_ptl_form_new" model="ir.actions.act_window">
            <field name="name">New PTL Forms</field>
            <field name="res_model">ptl.form</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('status', '=', 'new')]</field>
            <field name="context">{'default_status': 'new'}</field>
        </record>

        <record id="action_ptl_form_in_progress" model="ir.actions.act_window">
            <field name="name">In Progress PTL Forms</field>
            <field name="res_model">ptl.form</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('status', '=', 'in_progress')]</field>
            <field name="context">{'default_status': 'in_progress'}</field>
        </record>

        <record id="action_ptl_form_approved" model="ir.actions.act_window">
            <field name="name">Approved PTL Forms</field>
            <field name="res_model">ptl.form</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('status', '=', 'approved')]</field>
            <field name="context">{'default_status': 'approved'}</field>
        </record>

        <record id="action_ptl_form_completed" model="ir.actions.act_window">
            <field name="name">Completed PTL Forms</field>
            <field name="res_model">ptl.form</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('status', '=', 'completed')]</field>
            <field name="context">{'default_status': 'completed'}</field>
        </record>

        <record id="action_ptl_form_returned" model="ir.actions.act_window">
            <field name="name">Returned PTL Forms</field>
            <field name="res_model">ptl.form</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('status', '=', 'returned')]</field>
            <field name="context">{'default_status': 'returned'}</field>
        </record>
    </data>
</odoo> 