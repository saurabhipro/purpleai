<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- PTL Approval Wizard Form -->
        <record id="view_ptl_approval_wizard_form" model="ir.ui.view">
            <field name="name">ptl.approval.wizard.form</field>
            <field name="model">ptl.approval.wizard</field>
            <field name="arch" type="xml">
                <form string="Approval/Rejection">
                    <div class="alert alert-info" role="alert">
                        <strong>Action Required:</strong> Please provide your comments for this <field name="section_name" readonly="1"/> action.
                    </div>
                    <group>
                        <field name="action_type" widget="radio" readonly="1"/>
                        <field name="comments" placeholder="Enter your comments here..." required="1"/>
                    </group>
                    <footer>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- PTL Approval Wizard Action -->
        <record id="action_ptl_approval_wizard" model="ir.actions.act_window">
            <field name="name">PTL Approval/Rejection</field>
            <field name="res_model">ptl.approval.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- PTL Form List View -->
        <record id="view_ptl_form_list" model="ir.ui.view">
            <field name="name">ptl.form.list</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <list string="PTL Forms">
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="tenant_name"/>
                    <field name="approve_form_name"/>
                    <field name="submitted_date"/>
                    <field name="priority"/>
                    <field name="global_status"/>
                </list>
            </field>
        </record>

        <!-- PTL Form Kanban View with Card Template -->
        <record id="view_ptl_form_kanban" model="ir.ui.view">
            <field name="name">ptl.form.kanban</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <kanban default_group_by="global_status" class="o_kanban_small_column">
                    <field name="global_status"/>
                    <field name="tenant_name"/>
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="submitted_date"/>
                    <field name="priority"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_image">
                                    <i class="fa fa-building fa-2x text-primary" title="PTL Form"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <div class="o_kanban_record_top mb-2">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="tenant_name"/>
                                            </strong>
                                            <small class="o_kanban_record_subtitle text-muted">
                                                <i class="fa fa-map-marker text-warning"/> <field name="unit_no"/> - <field name="development"/>
                                            </small>
                                        </div>
                                        <div class="o_kanban_manage_button_section">
                                            <field name="priority" widget="priority"/>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <i class="fa fa-calendar text-info"/> <field name="submitted_date"/>
                                        </div>
                                        <div class="oe_kanban_bottom_right">
                                            <field name="global_status" widget="label_selection"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- PTL Form Form View -->
        <record id="view_ptl_form_form" model="ir.ui.view">
            <field name="name">ptl.form.form</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <form string="PTL Form">
                    <header>
                        <!-- Global Workflow Status Breadcrumb - Force Right Aligned -->
                        <div style="display: flex; justify-content: flex-end; margin-bottom: 10px; width: 100%;">
                            <div class="border rounded p-2" style="background-color: #f8f9fa; margin-left: auto;">
                                <field name="global_status" widget="statusbar" 
                                       statusbar_visible="ptl,form_verification,kick_off_meeting,pending_with_rdd,pending_with_tenant,rdd_review,noc,site_inspection_submission,handover"
                                       nolabel="1"/>
                            </div>
                        </div>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="form_name" readonly="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="📋 Basic Information">
                                <field name="unit_no"/>
                                <field name="development"/>
                                <field name="tenant_name"/>
                                <field name="approve_form_name"/>
                            </group>
                            <group string="📊 Status &amp; Priority">
                                <field name="priority" widget="priority"/>
                                <field name="submitted_date"/>
                            </group>
                        </group>

                        <notebook>
                            <!-- PTL Section Tab -->
                            <page string="📄 PTL Section" name="ptl_section_tab">
                                <!-- PTL Section Status with Approve/Reject Buttons - Right Aligned -->
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; padding: 15px; background-color: #e3f2fd; border-radius: 5px;">
                                    <div style="display: flex; align-items: center;">
                                        <strong>PTL Section Status: </strong>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 15px;">
                                        <div class="border rounded p-1" style="background-color: #ffffff;">
                                            <field name="ptl_section_status" widget="statusbar" statusbar_visible="new,pending,approved,rejected" nolabel="1"/>
                                        </div>
                                        <div>
                                            <button name="action_approve_ptl_section" type="object" string="✅ Approve" 
                                                    class="btn btn-success btn-sm mr-2" 
                                                    invisible="ptl_section_status not in ['new', 'pending']" 
                                                    context="{'section_name': 'PTL Section', 'action_type': 'approve'}"/>
                                            <button name="action_reject_ptl_section" type="object" string="❌ Reject" 
                                                    class="btn btn-danger btn-sm" 
                                                    invisible="ptl_section_status not in ['new', 'pending']"
                                                    context="{'section_name': 'PTL Section', 'action_type': 'reject'}"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <group>
                                    <group string="🏢 Tenancy Location Details">
                                        <field name="ground_floor"/>
                                        <field name="outdoor_area_gf"/>
                                        <field name="outdoor_area_mezz"/>
                                    </group>
                                    <group string="👤 Tenant Contact Details">
                                        <field name="tenant"/>
                                        <field name="proposed_shop"/>
                                        <field name="permitted_use"/>
                                        <field name="lease_term"/>
                                    </group>
                                </group>
                                
                                <group>
                                    <group string="📞 Contact Information">
                                        <field name="contact_person"/>
                                        <field name="designation"/>
                                        <field name="telephone"/>
                                        <field name="mobile"/>
                                        <field name="email"/>
                                    </group>
                                    <group string="📅 Key Dates">
                                        <field name="pit_out_commencement_date"/>
                                        <field name="fit_out_period"/>
                                        <field name="concept_design_submission_date"/>
                                        <field name="detail_design_submission_date"/>
                                        <field name="trade_start_date"/>
                                    </group>
                                </group>
                                
                                <group>
                                    <group string="📍 Address &amp; Special Requirements">
                                        <field name="address" nolabel="1"/>
                                        <field name="special_requirements" nolabel="1"/>
                                    </group>
                                    <group string="💰 Financial Details">
                                        <field name="late_opening_penalty"/>
                                        <field name="note" nolabel="1"/>
                                    </group>
                                </group>
                            </page>

                            <!-- Critical Path Section Tab -->
                            <page string="🗺️ Critical Path Section" name="critical_path_section_tab" 
                                  invisible="global_status not in ['kick_off_meeting', 'pending_with_rdd', 'pending_with_tenant', 'rdd_review', 'noc', 'site_inspection_submission', 'handover']">
                                <!-- Critical Path Section Status with Approve/Reject Buttons - Right Aligned -->
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; padding: 15px; background-color: #e8f5e8; border-radius: 5px;">
                                    <div style="display: flex; align-items: center;">
                                        <strong>Critical Path Status: </strong>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 15px;">
                                        <div class="border rounded p-1" style="background-color: #ffffff;">
                                            <field name="critical_path_section_status" widget="statusbar" statusbar_visible="new,pending,approved,rejected" nolabel="1"/>
                                        </div>
                                        <div>
                                            <button name="action_approve_critical_path_section" type="object" string="✅ Approve" 
                                                    class="btn btn-success btn-sm mr-2" 
                                                    invisible="critical_path_section_status not in ['new', 'pending']"
                                                    context="{'section_name': 'Critical Path Section', 'action_type': 'approve'}"/>
                                            <button name="action_reject_critical_path_section" type="object" string="❌ Reject" 
                                                    class="btn btn-danger btn-sm" 
                                                    invisible="critical_path_section_status not in ['new', 'pending']"
                                                    context="{'section_name': 'Critical Path Section', 'action_type': 'reject'}"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="container-fluid">
                                    <!-- Design Activities Section -->
                                    <div class="card mb-4" style="border-left: 4px solid #2196F3;">
                                        <div class="card-header" style="background-color: #e3f2fd; font-weight: bold; font-size: 16px;">
                                            🎨 Design Activities
                                        </div>
                                        <div class="card-body p-3">
                                            <div class="row font-weight-bold border-bottom pb-2 mb-2" style="background-color: #f5f5f5; font-size: 14px;">
                                                <div class="col-md-3 text-center"><strong>Activity</strong></div>
                                                <div class="col-md-1 text-center"><strong>Days</strong></div>
                                                <div class="col-md-2 text-center"><strong>Date</strong></div>
                                                <div class="col-md-3 text-center"><strong>Activity</strong></div>
                                                <div class="col-md-1 text-center"><strong>Days</strong></div>
                                                <div class="col-md-2 text-center"><strong>Date</strong></div>
                                            </div>
                                            
                                            <div class="row border-bottom py-2" style="min-height: 45px; font-size: 14px;">
                                                <!-- Column 1 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Kick-Off meeting / Project handover</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="kickoff_meeting_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="kickoff_meeting_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                                <!-- Column 2 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Concept design submissions</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="concept_design_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="concept_design_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                            </div>

                                            <div class="row border-bottom py-2" style="min-height: 45px; font-size: 14px;">
                                                <!-- Column 1 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Arch detailed design submission</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="arch_detailed_design_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="arch_detailed_design_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                                <!-- Column 2 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">MEP design submission</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="mep_design_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="mep_design_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Authority Activities Section -->
                                    <div class="card mb-4" style="border-left: 4px solid #FF9800;">
                                        <div class="card-header" style="background-color: #fff3e0; font-weight: bold; font-size: 16px;">
                                            🏛️ Authority Activities
                                        </div>
                                        <div class="card-body p-3">
                                            <div class="row font-weight-bold border-bottom pb-2 mb-2" style="background-color: #f5f5f5; font-size: 14px;">
                                                <div class="col-md-3 text-center"><strong>Activity</strong></div>
                                                <div class="col-md-1 text-center"><strong>Days</strong></div>
                                                <div class="col-md-2 text-center"><strong>Date</strong></div>
                                                <div class="col-md-3 text-center"><strong>Activity</strong></div>
                                                <div class="col-md-1 text-center"><strong>Days</strong></div>
                                                <div class="col-md-2 text-center"><strong>Date</strong></div>
                                            </div>
                                            
                                            <div class="row border-bottom py-2" style="min-height: 45px; font-size: 14px;">
                                                <!-- Column 1 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Civil defence approval submission</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="civil_defence_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="civil_defence_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                                <!-- Column 2 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Municipality approval submission</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="municipality_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="municipality_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                            </div>

                                            <div class="row border-bottom py-2" style="min-height: 45px; font-size: 14px;">
                                                <!-- Column 1 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">SEWA approval submission</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="sewa_approval_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="sewa_approval_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                                <!-- Column 2 - Empty for now -->
                                                <div class="col-md-3"></div>
                                                <div class="col-md-1"></div>
                                                <div class="col-md-2"></div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Execution Activities Section -->
                                    <div class="card mb-4" style="border-left: 4px solid #4CAF50;">
                                        <div class="card-header" style="background-color: #e8f5e8; font-weight: bold; font-size: 16px;">
                                            🚧 Execution Activities
                                        </div>
                                        <div class="card-body p-3">
                                            <div class="row font-weight-bold border-bottom pb-2 mb-2" style="background-color: #f5f5f5; font-size: 14px;">
                                                <div class="col-md-3 text-center"><strong>Activity</strong></div>
                                                <div class="col-md-1 text-center"><strong>Days</strong></div>
                                                <div class="col-md-2 text-center"><strong>Date</strong></div>
                                                <div class="col-md-3 text-center"><strong>Activity</strong></div>
                                                <div class="col-md-1 text-center"><strong>Days</strong></div>
                                                <div class="col-md-2 text-center"><strong>Date</strong></div>
                                            </div>
                                            
                                            <div class="row border-bottom py-2" style="min-height: 45px; font-size: 14px;">
                                                <!-- Column 1 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Site mobilization</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="site_mobilization_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="site_mobilization_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                                <!-- Column 2 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Fit-out works completion</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="fitout_works_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="fitout_works_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                            </div>

                                            <div class="row border-bottom py-2" style="min-height: 45px; font-size: 14px;">
                                                <!-- Column 1 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Final inspection</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="final_inspection_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="final_inspection_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                                <!-- Column 2 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Snag completion</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="snag_completion_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="snag_completion_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                            </div>

                                            <div class="row border-bottom py-2" style="min-height: 45px; font-size: 14px;">
                                                <!-- Column 1 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Handover &amp; approvals</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="handover_approvals_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="handover_approvals_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                                <!-- Column 2 -->
                                                <div class="col-md-3 d-flex align-items-center">
                                                    <span style="font-size: 14px; color: #495057; font-weight: 500;">Trading commencement</span>
                                                </div>
                                                <div class="col-md-1 text-center d-flex align-items-center justify-content-center">
                                                    <field name="trading_days" nolabel="1" style="max-width: 60px; text-align: center; font-size: 14px;"/>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-center justify-content-center">
                                                    <field name="trade_date_date" nolabel="1" style="max-width: 130px; font-size: 14px;"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- PTL Form Action -->
        <record id="action_ptl_form" model="ir.actions.act_window">
            <field name="name">PTL Forms</field>
            <field name="res_model">ptl.form</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first PTL Form
                </p>
                <p>
                    Get started by creating a new PTL (Permission to Lease) form for tenant management.
                </p>
            </field>
        </record>

        <!-- PTL Form Search View -->
        <record id="view_ptl_form_search" model="ir.ui.view">
            <field name="name">ptl.form.search</field>
            <field name="model">ptl.form</field>
            <field name="arch" type="xml">
                <search>
                    <field name="tenant_name"/>
                    <field name="unit_no"/>
                    <field name="development"/>
                    <field name="approve_form_name"/>
                    <filter string="🆕 PTL" name="filter_ptl" domain="[('global_status', '=', 'ptl')]"/>
                    <filter string="📋 Form Verification" name="filter_form_verification" domain="[('global_status', '=', 'form_verification')]"/>
                    <filter string="🤝 Kick Off Meeting" name="filter_kick_off" domain="[('global_status', '=', 'kick_off_meeting')]"/>
                    <separator/>
                    <filter string="🆕 NEW" name="filter_new" domain="[('ptl_section_status', '=', 'new')]"/>
                    <filter string="⏳ PENDING" name="filter_pending" domain="[('ptl_section_status', '=', 'pending')]"/>
                    <filter string="✅ APPROVED" name="filter_approved" domain="[('ptl_section_status', '=', 'approved')]"/>
                    <filter string="❌ REJECTED" name="filter_rejected" domain="[('ptl_section_status', '=', 'rejected')]"/>
                    <separator/>
                    <group expand="1" string="Group By">
