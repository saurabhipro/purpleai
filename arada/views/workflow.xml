<odoo>
    <data>
        <record id="view_arada_workflow_list" model="ir.ui.view">
            <field name="name">arada.workflow.list</field>
            <field name="model">arada.workflow</field>
            <field name="arch" type="xml">
                <list string="Colonies">
                    <field name="approval_for"/>
                    <field name="user_id"/>
                </list>
            </field>
        </record>

        <record id="view_arada_workflow_form" model="ir.ui.view">
            <field name="name">arada.workflow.form</field>
            <field name="model">arada.workflow</field>
            <field name="arch" type="xml">
                <form string="Colony">
                    <sheet>
                        <group>
                            <field name="approval_for"/>
                            <field name="user_id"/>
                        </group>
                    </sheet>
                    <chatter/>

                </form>
            </field>
        </record>

        <record id="action_arada_workflow" model="ir.actions.act_window">
            <field name="name">Workflow</field>
            <field name="res_model">arada.workflow</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_arada_workflow_list"/>
        </record>
    </data>
</odoo>