<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client Action for Editor -->
    <record id="doc_editor_client_action" model="ir.actions.client">
        <field name="name">DocEditor</field>
        <field name="tag">doceditor.Editor</field>
    </record>

    <record id="action_doc_document" model="ir.actions.act_window">
        <field name="name">Word Documents</field>
        <field name="res_model">doc.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_doc_document_tree" model="ir.ui.view">
        <field name="name">doc.document.list</field>
        <field name="model">doc.document</field>
        <field name="arch" type="xml">
            <list string="Documents">
                <field name="name"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_doc_document_form" model="ir.ui.view">
        <field name="name">doc.document.form</field>
        <field name="model">doc.document</field>
        <field name="arch" type="xml">
            <form string="Document">
                <header>
                    <button name="%(doc_editor_client_action)d" string="Open in DocEditor" type="action" class="oe_highlight" context="{'default_document_id': id}"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Document Title..."/></h1>
                    </div>
                    <group>
                        <field name="content" widget="binary" filename="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
