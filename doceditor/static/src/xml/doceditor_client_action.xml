<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="doceditor.Editor">
        <div class="o_doceditor_container h-100 d-flex flex-column overflow-hidden bg-light">
            <!-- Header with minimal Odoo actions -->
            <div class="p-2 px-3 bg-white border-bottom shadow-sm d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <i class="fa fa-file-text text-primary fs-5"/>
                    <strong class="text-dark" t-esc="state.document?.name || 'New Document'"/>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary btn-sm" t-on-click="saveDocument">
                        <i class="fa fa-save me-1"/> Save
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" t-on-click="downloadDocument">
                        <i class="fa fa-download me-1"/> Word
                    </button>
                </div>
            </div>

            <!-- CKEditor 5 Main Layout -->
            <div class="o_doceditor_main_layout d-flex flex-grow-1 overflow-hidden">
                <div class="o_doceditor_content_pane flex-grow-1 overflow-auto p-4 d-flex justify-content-center">
                    <div class="o_ckeditor5_wrapper shadow-lg bg-white" style="width: 8.5in; min-height: 11in;">
                        <!-- Decoupled Editor Toolbar Container -->
                        <div t-ref="toolbar_container" style="background: #f8f9fa; border-bottom: 1px solid #ced4da; padding: 5px;"></div>
                        
                        <!-- CKEditor 5 targets this -->
                        <div t-ref="editor_area" class="p-5" style="min-height: 10.5in;"></div>
                    </div>
                </div>

                <!-- Review Sidebar (Still needed for Track Changes visualization) -->
                <div class="o_doceditor_review_sidebar shadow-sm bg-light border-start" style="width: 320px;">
                    <div class="p-3 border-bottom bg-white">
                        <strong class="small text-muted text-uppercase">Review Pane</strong>
                    </div>
                    <div class="o_sidebar_cards p-3">
                        <t t-foreach="state.trackedChanges" t-as="change" t-key="change.id">
                            <div t-attf-class="o_sidebar_card o_card_{{change.type}} mb-3 shadow-sm bg-white p-2 border-start border-4 rounded">
                                <div class="d-flex align-items-center mb-1">
                                    <span class="fw-bold smaller" t-esc="change.author"/>
                                    <span class="ms-auto text-muted" style="font-size: 9px;" t-esc="change.date"/>
                                </div>
                                <div class="small" t-esc="change.comment"/>
                                <div class="d-flex gap-2 mt-2 border-top pt-1 opacity-75">
                                    <i class="fa fa-check text-success cursor-pointer" title="Accept" t-on-click="() => this.resolveChange(change.id, 'accept')"/>
                                    <i class="fa fa-times text-danger cursor-pointer" title="Reject" t-on-click="() => this.resolveChange(change.id, 'reject')"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
